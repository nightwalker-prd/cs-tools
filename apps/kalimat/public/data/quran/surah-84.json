Num":3,"word":"اِتَّسَقَ","meaning":"it became complete (moon)","transliteration":"ittasaqa","root":"وسق","lemmaId":null},{"id":"84:19:1","ayahNum":19,"wordNum":1,"word":"لَتَرْكَبُنَّ","meaning":"you will most certainly ride (referring to stages humans will pass through)","transliteration":"latarkabunna","root":"ركب","lemmaId":1790},{"id":"84:19:2","ayahNum":19,"wordNum":2,"word":"طَبَقًا","meaning":"a stage (object of لَتَرْكَبُنَّ - you will surely mount)","transliteration":"ṭabaqan","root":"طبق","lemmaId":null},{"id":"84:19:3","ayahNum":19,"wordNum":3,"word":"عَن","meaning":"from/away from (connects طَبَقًا to طَبَقٍ)","transliteration":"ʿan","root":"","lemmaId":4713},{"id":"84:19:4","ayahNum":19,"wordNum":4,"word":"طَبَقٍ","meaning":"a stage or state (that comes after طَبَقًا)","transliteration":"ṭabaqin","root":"طبق","lemmaId":null},{"id":"84:20:1","ayahNum":20,"wordNum":1,"word":"فَمَا","meaning":"Then what (connects to لَا يُؤْمِنُونَ - they do not believe)","transliteration":"famā","root":"","lemmaId":3215},{"id":"84:20:2","ayahNum":20,"wordNum":2,"word":"لَهُمْ","meaning":"for/to them (subject of لَا يُؤْمِنُونَ)","transliteration":"lahum","root":"","lemmaId":3146},{"id":"84:20:3","ayahNum":20,"wordNum":3,"word":"لَا","meaning":"no/not (negates يُؤْمِنُونَ - they believe)","transliteration":"lā","root":"","lemmaId":3147},{"id":"84:20:4","ayahNum":20,"wordNum":4,"word":"يُؤْمِنُونَ","meaning":"they believe","transliteration":"yu'minūna","root":"أمن","lemmaId":null},{"id":"84:21:1","ayahNum":21,"wordNum":1,"word":"وَإِذَا","meaning":"and when (connects to previous statement)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"84:21:2","ayahNum":21,"wordNum":2,"word":"قُرِئَ","meaning":"it was read/recited (referring to القُرْءَانُ - the Quran)","transliteration":"quri-a","root":"قرأ","lemmaId":2942},{"id":"84:21:3","ayahNum":21,"wordNum":3,"word":"عَلَيْهِمُ","meaning":"upon them (subject of لَا يَسْجُدُونَ)","transliteration":"ʿalayhimu","root":"","lemmaId":2582},{"id":"84:21:4","ayahNum":21,"wordNum":4,"word":"ٱلْقُرْءَانُ","meaning":"the Quran (the divine recitation)","transliteration":"l-qur'ānu","root":"قرأ","lemmaId":2942},{"id":"84:21:5","ayahNum":21,"wordNum":5,"word":"لَا","meaning":"not (negates يَسْجُدُونَ)","transliteration":"lā","root":"","lemmaId":3147},{"id":"84:21:6","ayahNum":21,"wordNum":6,"word":"يَسْجُدُونَ","meaning":"they bow down (in worship)","transliteration":"yasjudūna","root":"سجد","lemmaId":null},{"id":"84:22:1","ayahNum":22,"wordNum":1,"word":"بَلِ","meaning":"rather/but rather (connects to ٱلَّذِينَ)","transliteration":"bali","root":"","lemmaId":4661},{"id":"84:22:2","ayahNum":22,"wordNum":2,"word":"ٱلَّذِينَ","meaning":"those who (subject of كَفَرُوا۟)","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"84:22:3","ayahNum":22,"wordNum":3,"word":"كَفَرُوا۟","meaning":"they rejected/denied (subject of يُكَذِّبُونَ)","transliteration":"kafarū","root":"كفر","lemmaId":3087},{"id":"84:22:4","ayahNum":22,"wordNum":4,"word":"يُكَذِّبُونَ","meaning":"they deny intensely/repeatedly (referring to those who disbelieved in previous ayah)","transliteration":"yukadhibūna","root":"كذب","lemmaId":null},{"id":"84:23:1","ayahNum":23,"wordNum":1,"word":"وَٱللَّهُ","meaning":"And Allah (as the subject of أَعْلَمُ/knows best)","transliteration":"wal-lahu","root":"","lemmaId":650},{"id":"84:23:2","ayahNum":23,"wordNum":2,"word":"أَعْلَمُ","meaning":"most knowing (describing اللَّهُ - Allah)","transliteration":"aʿlamu","root":"علم","lemmaId":2583},{"id":"84:23:3","ayahNum":23,"wordNum":3,"word":"بِمَا","meaning":"with what/with whatever (they are keeping hidden in يُوعُونَ)","transliteration":"bimā","root":"","lemmaId":3215},{"id":"84:23:4","ayahNum":23,"wordNum":4,"word":"يُوعُونَ","meaning":"they retain/preserve","transliteration":"yūʿūna","root":"وعي","lemmaId":null},{"id":"84:24:1","ayahNum":24,"wordNum":1,"word":"فَبَشِّرْهُم","meaning":"so give them news! (of عَذَابٍ أَلِيمٍ - a painful punishment)","transliteration":"fabashir'hum","root":"بشر","lemmaId":null},{"id":"84:24:2","ayahNum":24,"wordNum":2,"word":"بِعَذَابٍ","meaning":"with a punishment (connected to فَبَشِّرْهُم - then give them news)","transliteration":"biʿadhābin","root":"عذب","lemmaId":2524},{"id":"84:24:3","ayahNum":24,"wordNum":3,"word":"أَلِيمٍ","meaning":"a painful (describes عَذَابٍ/punishment)","transliteration":"alīmin","root":"ألم","lemmaId":null},{"id":"84:25:1","ayahNum":25,"wordNum":1,"word":"إِلَّا","meaning":"except (introduces الَّذِينَ - those who)","transliteration":"illā","root":"","lemmaId":486},{"id":"84:25:2","ayahNum":25,"wordNum":2,"word":"ٱلَّذِينَ","meaning":"those who (describing the believers in ءَامَنُوا۟)","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"84:25:3","ayahNum":25,"wordNum":3,"word":"ءَامَنُوا۟","meaning":"they believed (connected to وَعَمِلُوا۟ - and they did)","transliteration":"āmanū","root":"أمن","lemmaId":null},{"id":"84:25:4","ayahNum":25,"wordNum":4,"word":"وَعَمِلُوا۟","meaning":"and they did/worked (righteously) (connected to ءَامَنُوا۟ - believed)","transliteration":"waʿamilū","root":"عمل","lemmaId":2592},{"id":"84:25:5","ayahNum":25,"wordNum":5,"word":"ٱلصَّالِحَاتِ","meaning":"the righteous deeds (object of وَعَمِلُوا)","transliteration":"l-ṣāliḥāti","root":"صلح","lemmaId":2292},{"id":"84:25:6","ayahNum":25,"wordNum":6,"word":"لَهُمْ","meaning":"for them (who have أَجْرٌ/reward)","transliteration":"lahum","root":"","lemmaId":3146},{"id":"84:25:7","ayahNum":25,"wordNum":7,"word":"أَجْرٌ","meaning":"a reward (subject of لَهُمْ)","transliteration":"ajrun","root":"أجر","lemmaId":74},{"id":"84:25:8","ayahNum":25,"wordNum":8,"word":"غَيْرُ","meaning":"other than (describes أَجْرٌ 'reward')","transliteration":"ghayru","root":"غير","lemmaId":null},{"id":"84:25:9","ayahNum":25,"wordNum":9,"word":"مَمْنُونٍۭ","meaning":"cut off, endless (describing أَجْرٌ/reward)","transliteration":"mamnūnin","root":"منن","lemmaId":null}]