n","root":"سعر","lemmaId":2074},{"id":"84:13:1","ayahNum":13,"wordNum":1,"word":"إِنَّهُۥ","meaning":"indeed he (subject of كَانَ - was)","transliteration":"innahu","root":"","lemmaId":502},{"id":"84:13:2","ayahNum":13,"wordNum":2,"word":"كَانَ","meaning":"he was/existed","transliteration":"kāna","root":"كون","lemmaId":null},{"id":"84:13:3","ayahNum":13,"wordNum":3,"word":"فِىٓ","meaning":"in (location within أَهْلِهِۦ - his family)","transliteration":"fī","root":"","lemmaId":2887},{"id":"84:13:4","ayahNum":13,"wordNum":4,"word":"أَهْلِهِۦ","meaning":"his family (after في)","transliteration":"ahlihi","root":"أهل","lemmaId":null},{"id":"84:13:5","ayahNum":13,"wordNum":5,"word":"مَسْرُورًا","meaning":"joyfully, in a happy state (describing his state in أَهْلِهِۦ)","transliteration":"masrūran","root":"سرر","lemmaId":null},{"id":"84:14:1","ayahNum":14,"wordNum":1,"word":"إِنَّهُۥ","meaning":"indeed he (subject of ظَنَّ - he thought)","transliteration":"innahu","root":"","lemmaId":502},{"id":"84:14:2","ayahNum":14,"wordNum":2,"word":"ظَنَّ","meaning":"he thought/assumed (subject of يَحُورَ)","transliteration":"ẓanna","root":"ظنن","lemmaId":null},{"id":"84:14:3","ayahNum":14,"wordNum":3,"word":"أَن","meaning":"that (connects to what follows ظَنَّ/he thought)","transliteration":"an","root":"","lemmaId":368},{"id":"84:14:4","ayahNum":14,"wordNum":4,"word":"لَّن","meaning":"will not (negates يَحُورَ - return)","transliteration":"lan","root":"","lemmaId":3212},{"id":"84:14:5","ayahNum":14,"wordNum":5,"word":"يَحُورَ","meaning":"he returns back (object of ظَنَّ - he thought)","transliteration":"yaḥūra","root":"حور","lemmaId":1454},{"id":"84:15:1","ayahNum":15,"wordNum":1,"word":"بَلَىٰٓ","meaning":"yes indeed! (contradicting a negative, with emphasis)","transliteration":"balā","root":"","lemmaId":4662},{"id":"84:15:2","ayahNum":15,"wordNum":2,"word":"إِنَّ","meaning":"indeed/truly (emphasizing رَبَّهُۥ)","transliteration":"inna","root":"","lemmaId":502},{"id":"84:15:3","ayahNu