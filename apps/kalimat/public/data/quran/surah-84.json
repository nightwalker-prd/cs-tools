[{"id":"84:1:1","ayahNum":1,"wordNum":1,"word":"إِذَا","meaning":"when (referring to future events, introducing 'ٱنشَقَّتْ' - splits apart)","transliteration":"idhā","root":"","lemmaId":461},{"id":"84:1:2","ayahNum":1,"wordNum":2,"word":"ٱلسَّمَآءُ","meaning":"the vast sky (as subject)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"84:1:3","ayahNum":1,"wordNum":3,"word":"ٱنشَقَّتْ","meaning":"it (feminine) split by itself","transliteration":"inshaqqat","root":"شقق","lemmaId":null},{"id":"84:2:1","ayahNum":2,"wordNum":1,"word":"وَأَذِنَتْ","meaning":"and she listened/obeyed (subject: the sky)","transliteration":"wa-adhinat","root":"أذن","lemmaId":null},{"id":"84:2:2","ayahNum":2,"wordNum":2,"word":"لِرَبِّهَا","meaning":"to/for her nurturer/sustainer (possessed by the sky/heaven)","transliteration":"lirabbihā","root":"ربب","lemmaId":null},{"id":"84:2:3","ayahNum":2,"wordNum":3,"word":"وَحُقَّتْ","meaning":"and she/it was made true/proper (connected to أَذِنَتْ/obeyed)","transliteration":"waḥuqqat","root":"حقق","lemmaId":1387},{"id":"84:3:1","ayahNum":3,"wordNum":1,"word":"وَإِذَا","meaning":"and when","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"84:3:2","ayahNum":3,"wordNum":2,"word":"ٱلْأَرْضُ","meaning":"the earth (as the doer of مُدَّتْ/was spread out)","transliteration":"l-arḍu","root":"أرض","lemmaId":null},{"id":"84:3:3","ayahNum":3,"wordNum":3,"word":"مُدَّتْ","meaning":"it (the earth) was stretched out","transliteration":"muddat","root":"مدد","lemmaId":3287},{"id":"84:4:1","ayahNum":4,"wordNum":1,"word":"وَأَلْقَتْ","meaning":"and she made (something) be thrown","transliteration":"wa-alqat","root":"لقي","lemmaId":null},{"id":"84:4:2","ayahNum":4,"wordNum":2,"word":"مَا","meaning":"what (is in it)","transliteration":"mā","root":"","lemmaId":3215},{"id":"84:4:3","ayahNum":4,"wordNum":3,"word":"فِيهَا","meaning":"in it (referring to the earth)","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"84:4:4","ayahNum":4,"wordNu