)","transliteration":"yuḥibbūna","root":"حبب","lemmaId":1324},{"id":"76:27:4","ayahNum":27,"wordNum":4,"word":"ٱلْعَاجِلَةَ","meaning":"the worldly life (object of يُحِبُّونَ - they love)","transliteration":"l-ʿājilata","root":"عجل","lemmaId":null},{"id":"76:27:5","ayahNum":27,"wordNum":5,"word":"وَيَذَرُونَ","meaning":"and they leave behind (subject of يُحِبُّونَ - they love)","transliteration":"wayadharūna","root":"وذر","lemmaId":null},{"id":"76:27:6","ayahNum":27,"wordNum":6,"word":"وَرَآءَهُمْ","meaning":"behind them","transliteration":"warāahum","root":"وري","lemmaId":null},{"id":"76:27:7","ayahNum":27,"wordNum":7,"word":"يَوْمًا","meaning":"a day (object of يَذَرُونَ - they leave)","transliteration":"yawman","root":"يوم","lemmaId":null},{"id":"76:27:8","ayahNum":27,"wordNum":8,"word":"ثَقِيلًا","meaning":"heavy, weighty (describing يَوْمًا - day)","transliteration":"thaqīlan","root":"ثقل","lemmaId":null},{"id":"76:28:1","ayahNum":28,"wordNum":1,"word":"نَّحْنُ","meaning":"indeed we (subject of خَلَقْنٰهُمْ/we created them)","transliteration":"naḥnu","root":"","lemmaId":4762},{"id":"76:28:2","ayahNum":28,"wordNum":2,"word":"خَلَقْنٰهُمْ","meaning":"we created them","transliteration":"khalaqnāhum","root":"خلق","lemmaId":1555},{"id":"76:28:3","ayahNum":28,"wordNum":3,"word":"وَشَدَدْنَآ","meaning":"and we strengthened","transliteration":"washadadnā","root":"شدد","lemmaId":2142},{"id":"76:28:4","ayahNum":28,"wordNum":4,"word":"أَسْرَهُمْ","meaning":"their joints/strength (object of شَدَدْنَا)","transliteration":"asrahum","root":"أسر","lemmaId":162},{"id":"76:28:5","ayahNum":28,"wordNum":5,"word":"وَإِذَا","meaning":"and when (connecting to شِئْنَا - we will)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"76:28:6","ayahNum":28,"wordNum":6,"word":"شِئْنَا","meaning":"we wanted/wished","transliteration":"shi'nā","root":"شيأ","lemmaId":2123},{"id":"76:28:7","ayahNum":28,"wordNum":7,"word":"بَدَّلْنَآ","meaning":"we changed/replaced completely","translit