"meaning":"who (subject of يُدْخِلُ)","transliteration":"man","root":"","lemmaId":3464},{"id":"76:31:3","ayahNum":31,"wordNum":3,"word":"يَشَآءُ","meaning":"he wants/wishes (subject of يُدْخِلُ - he admits)","transliteration":"yashāu","root":"شيأ","lemmaId":null},{"id":"76:31:4","ayahNum":31,"wordNum":4,"word":"فِى","meaning":"in/within (connects يُدْخِلُ with رَحْمَتِهِ)","transliteration":"fī","root":"","lemmaId":null},{"id":"76:31:5","ayahNum":31,"wordNum":5,"word":"رَحْمَتِهِۦ","meaning":"His mercy (referring to Allah's mercy)","transliteration":"raḥmatihi","root":"رحم","lemmaId":null},{"id":"76:31:6","ayahNum":31,"wordNum":6,"word":"وَٱلظَّالِمِينَ","meaning":"and the people who act unfairly (who will receive عَذَابًا أَلِيمًۢا)","transliteration":"wal-ẓālimīna","root":"ظلم","lemmaId":null},{"id":"76:31:7","ayahNum":31,"wordNum":7,"word":"أَعَدَّ","meaning":"he prepared (for them)","transliteration":"aʿadda","root":"عدد","lemmaId":null},{"id":"76:31:8","ayahNum":31,"wordNum":8,"word":"لَهُمْ","meaning":"for them (referring to الظَّالِمِينَ - the wrongdoers)","transliteration":"lahum","root":"","lemmaId":3146},{"id":"76:31:9","ayahNum":31,"wordNum":9,"word":"عَذَابًا","meaning":"a punishment (being prepared)","transliteration":"ʿadhāban","root":"عذب","lemmaId":2524},{"id":"76:31:10","ayahNum":31,"wordNum":10,"word":"أَلِيمًۢا","meaning":"painful (describes the punishment عَذَابًا)","transliteration":"alīman","root":"ألم","lemmaId":null}]