5},{"id":"70:5:2","ayahNum":5,"wordNum":2,"word":"صَبْرًا","meaning":"patience (as the object of فَٱصْبِرْ - have patience)","transliteration":"ṣabran","root":"صبر","lemmaId":null},{"id":"70:5:3","ayahNum":5,"wordNum":3,"word":"جَمِيلًا","meaning":"beautifully (describes how to be patient)","transliteration":"jamīlan","root":"جمل","lemmaId":1230},{"id":"70:6:1","ayahNum":6,"wordNum":1,"word":"إِنَّهُمْ","meaning":"indeed they (emphasizes يَرَوْنَهُ - they see it)","transliteration":"innahum","root":"","lemmaId":502},{"id":"70:6:2","ayahNum":6,"wordNum":2,"word":"يَرَوْنَهُۥ","meaning":"they see him/it (acted on)","transliteration":"yarawnahu","root":"رأي","lemmaId":null},{"id":"70:6:3","ayahNum":6,"wordNum":3,"word":"بَعِيدًا","meaning":"distant (object of يَرَوْنَ/they see it)","transliteration":"baʿīdan","root":"بعد","lemmaId":null},{"id":"70:7:1","ayahNum":7,"wordNum":1,"word":"وَنَرَىٰهُ","meaning":"and we see him","transliteration":"wanarāhu","root":"رأي","lemmaId":1735},{"id":"70:7:2","ayahNum":7,"wordNum":2,"word":"قَرِيبًا","meaning":"near (object of نَرَىٰهُ - we see it)","transliteration":"qarīban","root":"قرب","lemmaId":null},{"id":"70:8:1","ayahNum":8,"wordNum":1,"word":"يَوْمَ","meaning":"a day (in accusative case)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"70:8:2","ayahNum":8,"wordNum":2,"word":"تَكُونُ","meaning":"she becomes/you become","transliteration":"takūnu","root":"كون","lemmaId":null},{"id":"70:8:3","ayahNum":8,"wordNum":3,"word":"ٱلسَّمَآءُ","meaning":"the sky (subject of تَكُونُ - it becomes)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"70:8:4","ayahNum":8,"wordNum":4,"word":"كَٱلْمُهْلِ","meaning":"like the molten substance (describing how the sky will look)","transliteration":"kal-muh'li","root":"مهل","lemmaId":null},{"id":"70:9:1","ayahNum":9,"wordNum":1,"word":"وَتَكُونُ","meaning":"and she/it becomes (subject of كَٱلْعِهْنِ)","transliteration":"watakūnu","root":"كون","lemmaId":null},{"id":"70:9:2","ayahNum":9,"wordNum":2,"word":"ٱلْجِبَالُ","meaning":"the mountains (subject of تَكُونُ)","transliteration":"l-jibālu","root":"جبل","lemmaId":null},{"id":"70:9:3","ayahNum":9,"wordNum":3,"word":"كَٱلْعِهْنِ","meaning":"like the wool (describing how the mountains will become) (subject of تَكُونُ)","transliteration":"kal-ʿih'ni","root":"عهن","lemmaId":null},{"id":"70:10:1","ayahNum":10,"wordNum":1,"word":"وَلَا","meaning":"and no/not (negates يَسْـَٔلُ - asks/inquires)","transliteration":"walā","root":"","lemmaId":3147},{"id":"70:10:2","ayahNum":10,"wordNum":2,"word":"يَسْأَلُ","meaning":"he asks (about حَمِيمٌ)","transliteration":"yasalu","root":"سأل","lemmaId":1964},{"id":"70:10:3","ayahNum":10,"wordNum":3,"word":"حَمِيمٌ","meaning":"a close intimate one (subject of يَسْـَٔلُ - asks about)","transliteration":"ḥamīmun","root":"حمم","lemmaId":null},{"id":"70:10:4","ayahNum":10,"wordNum":4,"word":"حَمِيمًا","meaning":"a close friend (object of يَسْـَٔلُ/asks about)","transliteration":"ḥamīman","root":"حمم","lemmaId":null},{"id":"70:11:1","ayahNum":11,"wordNum":1,"word":"يُبَصَّرُونَهُمْ","meaning":"they are made to see them (the sinners will see their loved ones but can't help them)","transliteration":"yubaṣṣarūnahum","root":"بصر","lemmaId":null},{"id":"70:11:2","ayahNum":11,"wordNum":2,"word":"يَوَدُّ","meaning":"he wishes intensely","transliteration":"yawaddu","root":"ودد","lemmaId":null},{"id":"70:11:3","ayahNum":11,"wordNum":3,"word":"ٱلْمُجْرِمُ","meaning":"the criminal (doer of يَوَدُّ - wishes)","transliteration":"l-muj'rimu","root":"جرم","lemmaId":1216},{"id":"70:11:4","ayahNum":11,"wordNum":4,"word":"لَوْ","meaning":"if (introduces an impossible wish in يَوَدُّ/wishes)","transliteration":"law","root":"","lemmaId":3187},{"id":"70:11:5","ayahNum":11,"wordNum":5,"word":"يَفْتَدِي","meaning":"he redeems himself (wishes to do in this ayah)","transliteration":"yaftadī","root":"فدي","lemmaId":null},{"id":"70:11:6","ayahNum":11,"wordNum":6,"word":"مِنْ","meaning":"from (connects عَذَابِ to يَفْتَدِى)","transliteration":"min","root":"","lemmaId":3464},{"id":"70:11:7","ayahNum":11,"wordNum":7,"word":"عَذَابِ","meaning":"punishment of (يَوْمِئِذٍ)","transliteration":"ʿadhābi","root":"عذب","lemmaId":null},{"id":"70:11:8","ayahNum":11,"wordNum":8,"word":"يَوْمِئِذٍۭ","meaning":"that day, on that day","transliteration":"yawmi-idhin","root":"يوم","lemmaId":null},{"id":"70:11:9","ayahNum":11,"wordNum":9,"word":"بِبَنِيهِ","meaning":"with/by his sons (object of يَفْتَدِى)","transliteration":"bibanīhi","root":"بني","lemmaId":null},{"id":"70:12:1","ayahNum":12,"wordNum":1,"word":"وَصٰحِبَتِهِۦ","meaning":"and his female companion","transliteration":"waṣāḥibatihi","root":"صحب","lemmaId":null},{"id":"70:12:2","ayahNum":12,"wordNum":2,"word":"وَأَخِيهِ","meaning":"and his brother (owned by صاحبة)","transliteration":"wa-akhīhi","root":"أخو","lemmaId":null},{"id":"70:13:1","ayahNum":13,"wordNum":1,"word":"وَفَصِيلَتِهِ","meaning":"and his family unit (that shelters him)","transliteration":"wafaṣīlatihi","root":"فصل","lemmaId":null},{"id":"70:13:2","ayahNum":13,"wordNum":2,"word":"ٱلَّتِى","meaning":"which (referring to فَصِيلَتِهِ - his closest relatives)","transliteration":"allatī","root":"","lemmaId":null},{"id":"70:13:3","ayahNum":13,"wordNum":3,"word":"تُؤْوِيهِ","meaning":"she shelters/protects him","transliteration":"tu'wīhi","root":"أوي","lemmaId":null},{"id":"70:14:1","ayahNum":14,"wordNum":1,"word":"وَمَن","meaning":"and whoever (subject of يُنجِيهِ)","transliteration":"waman","root":"","lemmaId":3464},{"id":"70:14:2","ayahNum":14,"wordNum":2,"word":"فِى","meaning":"in (connects to ٱلْأَرْضِ - the earth)","transliteration":"fī","root":"","lemmaId":2887},{"id":"70:14:3","ayahNum":14,"wordNum":3,"word":"ٱلْأَرْضِ","meaning":"the earth (possessed by/belonging to something mentioned after)","transliteration":"l-arḍi","root":"أرض","lemmaId":149},{"id":"70:14:4","ayahNum":14,"wordNum":4,"word":"جَمِيعًا","meaning":"all together (describing how something happens)","transliteration":"jamīʿan","root":"جمع","lemmaId":1229},{"id":"70:14:5","ayahNum":14,"wordNum":5,"word":"ثُمَّ","meaning":"then (connects to يُنجِيهِ - saves him)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"70:14:6","ayahNum":14,"wordNum":6,"word":"يُنجِيهِ","meaning":"he saves him","transliteration":"yunjīhi","root":"نجو","lemmaId":null},{"id":"70:15:1","ayahNum":15,"wordNum":1,"word":"كَلَّآ","meaning":"no indeed! (strongly rejecting what came before إِنَّهَا لَظَىٰ)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"70:15:2","ayahNum":15,"wordNum":2,"word":"إِنَّهَا","meaning":"indeed it (referring to لَظَىٰ)","transliteration":"innahā","root":"","lemmaId":502},{"id":"70:15:3","ayahNum":15,"wordNum":3,"word":"لَظَىٰ","meaning":"Blazing Fire (as a proper name for a level of Hell)","transliteration":"laẓā","root":"","lemmaId":3168},{"id":"70:16:1","ayahNum":16,"wordNum":1,"word":"نَزَّاعَةً","meaning":"a female who pulls out repeatedly and forcefully (describes جَهَنَّمَ/Hell)","transliteration":"nazzāʿatan","root":"نزع","lemmaId":null},{"id":"70:16:2","ayahNum":16,"wordNum":2,"word":"لِّلشَّوَىٰ","meaning":"surely for the extremities","transliteration":"lilshawā","root":"شوي","lemmaId":null},{"id":"70:17:1","ayahNum":17,"wordNum":1,"word":"تَدْعُوا۟","meaning":"you (all) call/invite","transliteration":"tadʿū","root":"دعو","lemmaId":null},{"id":"70:17:2","ayahNum":17,"wordNum":2,"word":"مَنْ","meaning":"whoever (object of تَدْعُوا۟)","transliteration":"man","root":"","lemmaId":3464},{"id":"70:17:3","ayahNum":17,"wordNum":3,"word":"أَدْبَرَ","meaning":"he turned away completely (connected to وَتَوَلَّىٰ - and turned away)","transliteration":"adbara","root":"دبر","lemmaId":null},{"id":"70:17:4","ayahNum":17,"wordNum":4,"word":"وَتَوَلَّىٰ","meaning":"and he turned away","transliteration":"watawallā","root":"ولي","lemmaId":null},{"id":"70:18:1","ayahNum":18,"wordNum":1,"word":"وَجَمَعَ","meaning":"and he gathered (followed by فَأَوْعَىٰٓ - and stored it up)","transliteration":"wajamaʿa","root":"جمع","lemmaId":null},{"id":"70:18:2","ayahNum":18,"wordNum":2,"word":"فَأَوْعَىٰٓ","meaning":"and then he hoarded (greedily)","transliteration":"fa-awʿā","root":"وعي","lemmaId":null},{"id":"70:19:1","ayahNum":19,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly/certainly (emphasizes 'ٱلْإِنسٰنَ' - mankind)","transliteration":"inna","root":"","lemmaId":502},{"id":"70:19:2","ayahNum":19,"wordNum":2,"word":"ٱلْإِنسٰنَ","meaning":"the human being (being acted upon by خُلِقَ - was created)","transliteration":"l-insāna","root":"أنس","lemmaId":null},{"id":"70:19:3","ayahNum":19,"wordNum":3,"word":"خُلِقَ","meaning":"he was created (subject of هَلُوعًا/anxious)","transliteration":"khuliqa","root":"خلق","lemmaId":1555},{"id":"70:19:4","ayahNum":19,"wordNum":4,"word":"هَلُوعًا","meaning":"as very anxious/panicky (describing how mankind was created)","transliteration":"halūʿan","root":"هلع","lemmaId":null},{"id":"70:20:1","ayahNum":20,"wordNum":1,"word":"إِذَا","meaning":"when (referring to a future event)","transliteration":"idhā","root":"","lemmaId":461},{"id":"70:20:2","ayahNum":20,"wordNum":2,"word":"مَسَّهُ","meaning":"affected/harmed him (referring to الشَّرُّ evil/harm)","transliteration":"massahu","root":"مسس","lemmaId":null},{"id":"70:20:3","ayahNum":20,"wordNum":3,"word":"ٱلشَّرُّ","meaning":"the harmful thing (subject of مَسَّهُ - touched him)","transliteration":"l-sharu","root":"شرر","lemmaId":null},{"id":"70:20:4","ayahNum":20,"wordNum":4,"word":"جَزُوعًا","meaning":"very panicky (describing the state of مَسَّهُ ٱلشَّرُّ - when evil touches him)","transliteration":"jazūʿan","root":"جزع","lemmaId":null},{"id":"70:21:1","ayahNum":21,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introducing the condition مَسَّهُ ٱلْخَيْرُ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"70:21:2","ayahNum":21,"wordNum":2,"word":"مَسَّهُ","meaning":"touched him (referring to الْخَيْرُ/goo