erties (referring to those who have a known right in their wealth)","transliteration":"amwālihim","root":"مول","lemmaId":null},{"id":"70:24:4","ayahNum":24,"wordNum":4,"word":"حَقٌّ","meaning":"a truth/right","transliteration":"ḥaqqun","root":"حقق","lemmaId":null},{"id":"70:24:5","ayahNum":24,"wordNum":5,"word":"مَّعْلُومٌ","meaning":"a well-known thing","transliteration":"maʿlūmun","root":"علم","lemmaId":null},{"id":"70:25:1","ayahNum":25,"wordNum":1,"word":"لِّلسَّآئِلِ","meaning":"for the one who asks (connected to والمحروم)","transliteration":"lilssāili","root":"سأل","lemmaId":null},{"id":"70:25:2","ayahNum":25,"wordNum":2,"word":"وَٱلْمَحْرُومِ","meaning":"and the deprived one (connected to لِّلسَّآئِلِ)","transliteration":"wal-maḥrūmi","root":"حرم","lemmaId":null},{"id":"70:26:1","ayahNum":26,"wordNum":1,"word":"وَٱلَّذِينَ","meaning":"and those who (subject of يُصَدِّقُونَ)","transliteration":"wa-alladhīna","root":"","lemmaId":null},{"id":"70:26:2","ayahNum":26,"wordNum":2,"word":"يُصَدِّقُونَ","meaning":"they strongly confirm/believe (referring to those who believe in the Day of Judgment)","transliteration":"yuṣaddiqūna","root":"صدق","lemmaId":2256},{"id":"70:26:3","ayahNum":26,"wordNum":3,"word":"بِيَوْمِ","meaning":"in/by the day (of الدِّينِ)","transliteration":"biyawmi","root":"يوم","lemmaId":null},{"id":"70:26:4","ayahNum":26,"wordNum":4,"word":"ٱلدِّينِ","meaning":"of the judgment (connected to يَوْمِ - day)","transliteration":"l-dīni","root":"دين","lemmaId":null},{"id":"70:27:1","ayahNum":27,"wordNum":1,"word":"وَٱلَّذِينَ","meaning":"and those who (who are fearful of their Lord's punishment)","transliteration":"wa-alladhīna","root":"","lemmaId":null},{"id":"70:27:2","ayahNum":27,"wordNum":2,"word":"هُم","meaning":"they/them (subject of مُّشْفِقُونَ)","transliteration":"hum","root":"","lemmaId":4150},{"id":"70:27:3","ayahNum":27,"wordNum":3,"word":"مِّنْ","meaning":"from/of (connected to عَذَابِ)","transliteration":"min","root":"","lemmaId":3464},{"id