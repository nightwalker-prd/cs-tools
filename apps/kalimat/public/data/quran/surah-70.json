[{"id":"70:1:1","ayahNum":1,"wordNum":1,"word":"سَأَلَ","meaning":"he asked (subject of بِعَذَابٍ وَاقِعٍ)","transliteration":"sa-ala","root":"سأل","lemmaId":null},{"id":"70:1:2","ayahNum":1,"wordNum":2,"word":"سَآئِلٌۢ","meaning":"an asker (subject of بِعَذَابٍ)","transliteration":"sāilun","root":"سأل","lemmaId":1964},{"id":"70:1:3","ayahNum":1,"wordNum":3,"word":"بِعَذَابٍ","meaning":"with/by a punishment (connected to سَأَلَ - he asked)","transliteration":"biʿadhābin","root":"عذب","lemmaId":2524},{"id":"70:1:4","ayahNum":1,"wordNum":4,"word":"وَاقِعٍ","meaning":"falling/occurring (describing punishment)","transliteration":"wāqiʿin","root":"وقع","lemmaId":null},{"id":"70:2:1","ayahNum":2,"wordNum":1,"word":"لِّلْكٰفِرِينَ","meaning":"for the disbelievers (who will face a punishment)","transliteration":"lil'kāfirīna","root":"كفر","lemmaId":null},{"id":"70:2:2","ayahNum":2,"wordNum":2,"word":"لَيْسَ","meaning":"is not (negates دَافِعٌ)","transliteration":"laysa","root":"ليس","lemmaId":null},{"id":"70:2:3","ayahNum":2,"wordNum":3,"word":"لَهُۥ","meaning":"for him (connected to دَافِعٌ)","transliteration":"lahu","root":"","lemmaId":3146},{"id":"70:2:4","ayahNum":2,"wordNum":4,"word":"دَافِعٌ","meaning":"a repeller/one who repels (subject of لَيْسَ)","transliteration":"dāfiʿun","root":"دفع","lemmaId":null},{"id":"70:3:1","ayahNum":3,"wordNum":1,"word":"مِّنَ","meaning":"from (connected to اللَّهِ)","transliteration":"mina","root":"","lemmaId":3464},{"id":"70:3:2","ayahNum":3,"wordNum":2,"word":"ٱللَّهِ","meaning":"of Allah (possessed by مِّنَ)","transliteration":"l-lahi","root":"أله","lemmaId":650},{"id":"70:3:3","ayahNum":3,"wordNum":3,"word":"ذِى","meaning":"owner of/possessor of (describes اللَّهِ - Allah)","transliteration":"dhī","root":"","lemmaId":1704},{"id":"70:3:4","ayahNum":3,"wordNum":4,"word":"ٱلْمَعَارِجِ","meaning":"the ways of ascending (possessed by ذِى)","transliteration":"l-maʿāriji","root":"عرج","lemmaId":null},{"id":"70:4:1","ayahNum":4,"wordNum":1,