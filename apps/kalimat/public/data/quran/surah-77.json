[{"id":"77:1:1","ayahNum":1,"wordNum":1,"word":"وَٱلْمُرْسَلَاتِ","meaning":"By the ones (feminine) who are sent","transliteration":"wal-mur'salāti","root":"رسل","lemmaId":null},{"id":"77:1:2","ayahNum":1,"wordNum":2,"word":"عُرْفًا","meaning":"in a customary manner (describing المرسلات)","transliteration":"ʿur'fan","root":"عرف","lemmaId":null},{"id":"77:2:1","ayahNum":2,"wordNum":1,"word":"فَٱلْعٰصِفٰتِ","meaning":"and the ones who blow forcefully (related to عَصْفًا)","transliteration":"fal-ʿāṣifāti","root":"عصف","lemmaId":null},{"id":"77:2:2","ayahNum":2,"wordNum":2,"word":"عَصْفًا","meaning":"forcefully (describing how العاصفات blow)","transliteration":"ʿaṣfan","root":"عصف","lemmaId":null},{"id":"77:3:1","ayahNum":3,"wordNum":1,"word":"وَٱلنَّاشِرٰتِ","meaning":"and the female spreaders (with emphasis) (subject of نَشْرًا)","transliteration":"wal-nāshirāti","root":"نشر","lemmaId":null},{"id":"77:3:2","ayahNum":3,"wordNum":2,"word":"نَشْرًا","meaning":"a spreading (object of النَّاشِرٰتِ - those who spread)","transliteration":"nashran","root":"نشر","lemmaId":null},{"id":"77:4:1","ayahNum":4,"wordNum":1,"word":"فَارِقَاتِ","meaning":"female ones who separate/divide (in genitive case)","transliteration":"fal-fāriqāti","root":"فرق","lemmaId":null},{"id":"77:4:2","ayahNum":4,"wordNum":2,"word":"فَرْقًا","meaning":"a separation (object of فَٱلْفٰرِقٰتِ)","transliteration":"farqan","root":"فرق","lemmaId":null},{"id":"77:5:1","ayahNum":5,"wordNum":1,"word":"فَٱلْمُلْقِيٰتِ","meaning":"and by/so the female ones who throw/deliver (referring to angels delivering ذِكْرًا)","transliteration":"fal-mul'qiyāti","root":"لقي","lemmaId":null},{"id":"77:5:2","ayahNum":5,"wordNum":2,"word":"ذِكْرًا","meaning":"a remembrance/mention (object of الْمُلْقِيٰتِ - those who deliver)","transliteration":"dhik'ran","root":"ذكر","lemmaId":null},{"id":"77:6:1","ayahNum":6,"wordNum":1,"word":"عُذْرًا","meaning":"as an excuse (connected to نُذْرًا - as a warning)","transliteration":"ʿudh'ran","root":"عذر","lemmaId":null},{"id":"77:6:2","ayahNum":6,"wordNum":2,"word":"أَوْ","meaning":"or (connecting عُذْرًا and نُذْرًا)","transliteration":"aw","root":"","lemmaId":4642},{"id":"77:6:3","ayahNum":6,"wordNum":3,"word":"نُذْرًا","meaning":"warnings (as excuses)","transliteration":"nudh'ran","root":"نذر","lemmaId":null},{"id":"77:7:1","ayahNum":7,"wordNum":1,"word":"إِنَّمَا","meaning":"indeed only (emphasizes تُوعَدُونَ لَوٰقِعٌ)","transliteration":"innamā","root":"","lemmaId":502},{"id":"77:7:2","ayahNum":7,"wordNum":2,"word":"تُوعَدُونَ","meaning":"you (all) are promised","transliteration":"tūʿadūna","root":"وعد","lemmaId":4243},{"id":"77:7:3","ayahNum":7,"wordNum":3,"word":"لَوٰقِعٌ","meaning":"surely occurring (predicate of إِنَّ)","transliteration":"lawāqiʿun","root":"وقع","lemmaId":null},{"id":"77:8:1","ayahNum":8,"wordNum":1,"word":"فَإِذَا","meaning":"and when/then when (followed by ٱلنُّجُومُ طُمِسَتْ)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"77:8:2","ayahNum":8,"wordNum":2,"word":"ٱلنُّجُومُ","meaning":"the stars (subject of طُمِسَتْ/were erased)","transliteration":"l-nujūmu","root":"نجم","lemmaId":null},{"id":"77:8:3","ayahNum":8,"wordNum":3,"word":"طُمِسَتْ","meaning":"it (referring to stars) was erased (passive subject of إِذَا/when)","transliteration":"ṭumisat","root":"طمس","lemmaId":null},{"id":"77:9:1","ayahNum":9,"wordNum":1,"word":"وَإِذَا","meaning":"and when","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"77:9:2","ayahNum":9,"wordNum":2,"word":"ٱلسَّمَآءُ","meaning":"the sky (subject of فُرِجَتْ)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"77:9:3","ayahNum":9,"wordNum":3,"word":"فُرِجَتْ","meaning":"it (the sky) was split open","transliteration":"furijat","root":"فرج","lemmaId":null},{"id":"77:10:1","ayahNum":10,"wordNum":1,"word":"إِذَا","meaning":"when","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"77:10:2","ayahNum":10,"wordNum":2,"word":"ٱلْجِبَالُ","meaning":"the mountains (subject of نُسِفَتْ - were blown away)","transliteration":"l-jibālu","root":"جبل","lemmaId":null},{"id":"77:10:3","ayahNum":10,"wordNum":3,"word":"نُسِفَتْ","meaning":"it (feminine) was blown away (referring to الْجِبَالُ/the mountains)","transliteration":"nusifat","root":"نسف","lemmaId":4006},{"id":"77:11:1","ayahNum":11,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time when ٱلرُّسُلُ أُقِّتَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"77:11:2","ayahNum":11,"wordNum":2,"word":"ٱلرُّسُلُ","meaning":"the messengers (subject of أُقِّتَتْ - were appointed a time)","transliteration":"l-rusulu","root":"رسل","lemmaId":null},{"id":"77:11:3","ayahNum":11,"wordNum":3,"word":"أُقِّتَتْ","meaning":"was firmly appointed (feminine)","transliteration":"uqqitat","root":"وقت","lemmaId":null},{"id":"77:12:1","ayahNum":12,"wordNum":1,"word":"لِأَيِّ","meaning":"for which (day) (asking about يَوْمٍ)","transliteration":"li-ayyi","root":"أيي","lemmaId":null},{"id":"77:12:2","ayahNum":12,"wordNum":2,"word":"يَوْمٍ","meaning":"a day (owned by أَىِّ - which)","transliteration":"yawmin","root":"يوم","lemmaId":null},{"id":"77:12:3","ayahNum":12,"wordNum":3,"word":"أُجِّلَتْ","meaning":"it was postponed (referring to يَوْمٍ - the Day)","transliteration":"ujjilat","root":"أجل","lemmaId":null},{"id":"77:13:1","ayahNum":13,"wordNum":1,"word":"لِيَوْمِ","meaning":"for the day (of الفَصْلِ)","transliteration":"liyawmi","root":"يوم","lemmaId":null},{"id":"77:13:2","ayahNum":13,"wordNum":2,"word":"ٱلْفَصْلِ","meaning":"the separation/decision (owned by يَوْمِ)","transliteration":"l-faṣli","root":"فصل","lemmaId":null},{"id":"77:14:1","ayahNum":14,"wordNum":1,"word":"وَمَآ","meaning":"and what (introducing the question أَدْرَىٰكَ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"77:14:2","ayahNum":14,"wordNum":2,"word":"أَدْرَىٰكَ","meaning":"made you know","transliteration":"adrāka","root":"دري","lemmaId":null},{"id":"77:14:3","ayahNum":14,"wordNum":3,"word":"مَا","meaning":"what (asking about يَوْمُ ٱلْفَصْلِ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"77:14:4","ayahNum":14,"wordNum":4,"word":"يَوْمُ","meaning":"Day (of الفصل)","transliteration":"yawmu","root":"يوم","lemmaId":null},{"id":"77:14:5","ayahNum":14,"wordNum":5,"word":"ٱلْفَصْلِ","meaning":"of the separation (part of يَوْمُ الفَصْلِ - Day of Separation)","transliteration":"l-faṣli","root":"فصل","lemmaId":null},{"id":"77:15:1","ayahNum":15,"wordNum":1,"word":"وَيْلٌ","meaning":"woe! (warning to those who deny the truth)","transliteration":"waylun","root":"","lemmaId":4272},{"id":"77:15:2","ayahNum":15,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (followed by لِّلْمُكَذِّبِينَ - for the deniers)","transliteration":"yawma-idhin","root":"يوم","lemmaId":4512},{"id":"77:15:3","ayahNum":15,"wordNum":3,"word":"لِّلْمُكَذِّبِينَ","meaning":"for the ones who deny repeatedly","transliteration":"lil'mukadhibīna","root":"كذب","lemmaId":null},{"id":"77:16:1","ayahNum":16,"wordNum":1,"word":"أَلَمْ","meaning":"did not (expecting 'yes' as answer)","transliteration":"alam","root":"","lemmaId":3177},{"id":"77:16:2","ayahNum":16,"wordNum":2,"word":"نُهْلِكِ","meaning":"we destroy (of أَلَمْ)","transliteration":"nuh'liki","root":"هلك","lemmaId":4145},{"id":"77:16:3","ayahNum":16,"wordNum":3,"word":"ٱلْأَوَّلِينَ","meaning":"the first ones (object of نُهْلِكِ)","transliteration":"l-awalīna","root":"أول","lemmaId":null},{"id":"77:17:1","ayahNum":17,"wordNum":1,"word":"ثُمَّ","meaning":"then (connects to نُتْبِعُهُمُ - We will make follow)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"77:17:2","ayahNum":17,"wordNum":2,"word":"نُتْبِعُهُمُ","meaning":"we make them follow (before ٱلْءَاخِرِينَ)","transliteration":"nut'biʿuhumu","root":"تبع","lemmaId":875},{"id":"77:17:3","ayahNum":17,"wordNum":3,"word":"ٱلْءَاخِرِينَ","meaning":"the last ones (object of نُتْبِعُهُمُ - we will make them follow)","transliteration":"l-ākhirīna","root":"أخر","lemmaId":106},{"id":"77:18:1","ayahNum":18,"wordNum":1,"word":"كَذٰلِكَ","meaning":"like that/in that way (referring to how We deal with the criminals mentioned in نَفْعَلُ بِٱلْمُجْرِمِينَ)","transliteration":"kadhālika","root":"","lemmaId":3032},{"id":"77:18:2","ayahNum":18,"wordNum":2,"word":"نَفْعَلُ","meaning":"we do/make (to the criminals)","transliteration":"nafʿalu","root":"فعل","lemmaId":2836},{"id":"77:18:3","ayahNum":18,"wordNum":3,"word":"بِٱلْمُجْرِمِينَ","meaning":"with the people who do wrong things (object of نَفْعَلُ)","transliteration":"bil-muj'rimīna","root":"جرم","lemmaId":null},{"id":"77:19:1","ayahNum":19,"wordNum":1,"word":"وَيْلٌ","meaning":"woe (is the punishment for المُكَذِّبِينَ - the deniers)","transliteration":"waylun","root":"","lemmaId":4272},{"id":"77:19:2","ayahNum":19,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (followed by لِّلْمُكَذِّبِينَ - for the deniers)","transliteration":"yawma-idhin","root":"يوم","lemmaId":4512},{"id":"77:19:3","ayahNum":19,"wordNum":3,"word":"لِّلْمُكَذِّبِينَ","meaning":"for the deniers (with emphasis)","transliteration":"lil'mukadhibīna","root":"كذب","lemmaId":null},{"id":"77:20:1","ayahNum":20,"wordNum":1,"word":"أَلَمْ","meaning":"did not indeed (expecting 'yes' as answer)","transliteration":"alam","root":"","lemmaId":31},{"id":"77:20:2","ayahNum":20,"wordNum":2,"word":"نَخْلُقكُّم","meaning":"we create you all (referring to Allah creating humans)","transliteration":"nakhluqkkum","root":"خلق","lemmaId":null},{"id":"77:20:3","ayahNum":20,"wordNum":3,"word":"مِّن","meaning":"from/of (connects مَّآءٍ to نَخْلُقكُّم)","transliteration":"min","root":"","lemmaId":3464},{"id":"77:20:4","ayahNum":20,"wordNum":4,"word":"مَّآءٍ","meaning":"water (indefinite)","transliteration":"māin","root":"موه","lemmaId":null},{"id":"77:20:5","ayahNum":20,"wordNum":5,"word":"مَّهِينٍ","meaning":"a very weak/worthless thing (describing مَّآءٍ/water)","transliteration":"mahīnin","root":"مهن","lemmaId":null},{"id":"77:21:1","ayahNum":21,"wordNum":1,"word":"فَجَعَلْنٰهُ","meaning":"so we made/placed it/him","transliteration":"fajaʿalnāhu","root":"جعل","lemmaId":null},{"id":"77:21:2","ayahNum":21,"wordNum":2,"word":"فِى","meaning":"in (something that will be mentioned after)","transliteration":"fī","root":"","lemmaId":2761},{"id":"77:21:3","ayahNum":21,"wordNum":3,"word":"قَرَارٍ","meaning":"a settled place (after في/in)","transliteration":"qarārin","root":"قرر","lemmaId":null},{"id":"77:21:4","ayahNum":21,"wordNum":4,"word":"مَّكِينٍ","meaning":"firmly established (with emphasis)","transliteration":"makīnin","root":"مكن","lemmaId":null},{"id":"77:22:1","ayahNum":22,"wordNum":1,"word":"إِلَىٰ","meaning":"to (pointing to قَدَرٍ مَّعْلُومٍ - a known measure)","transliteration":"ilā","root":"","lemmaId":485},{"id":"77:22:2","ayahNum":22,"wordNum":2,"word":"قَدَرٍ","meaning":"a measure/amount (object of إِلَىٰ/to)","transliteration":"qadarin","root":"قدر","lemmaId":2931},{"id":"77:22:3","ayahNum":22,"wordNum":3,"word":"مَّعْلُومٍ","meaning":"a known/determined thing (with emphasis)","transliteration":"maʿlūmin","root":"علم","lemmaId":2583},{"id":"77:23:1","ayahNum":23,"wordNum":1,"word":"فَقَدَرْنَا","meaning":"and so We measured/determined (referring to Allah)","transliteration":"faqadarnā","root":"قدر","lemmaId":null},{"id":"77:23:2","ayahNum":23,"wordNum":2,"word":"فَنِعْمَ","meaning":"and how excellent (is the ability of Allah)!","transliteration":"faniʿ'ma","root":"نعم","lemmaId":null},{"id":"77:23:3","ayahNum":23,"wordNum":3,"word":"ٱلْقٰدِرُونَ","meaning":"the ones who have power (subject of فَقَدَرْنَا)","transliteration":"l-qādirūna","root":"قدر","lemmaId":null},{"id":"77:24:1","ayahNum":24,"wordNum":1,"word":"وَيْلٌ","meaning":"woe! (as a threat of destruction to المُكَذِّبِينَ - the deniers)","transliteration":"waylun","root":"","lemmaId":4272},{"id":"77:24:2","ayahNum":24,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (referring to the Day of Judgment mentioned in context)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"77:24:3","ayahNum":24,"wordNum":3,"word":"لِّلْمُكَذِّبِينَ","meaning":"for the ones who deny intensely (with emphasis)","transliteration":"lil'mukadhibīna","root":"كذب","lemmaId":null},{"id":"77:25:1","ayahNum":25,"wordNum":1,"word":"أَلَمْ","meaning":"did not? (expecting 'yes')","transliteration":"alam","root":"","lemmaId":3177},{"id":"77:25:2","ayahNum":25,"wordNum":2,"word":"نَجْعَلِ","meaning":"we make/put/set (jussive)","transliteration":"najʿali","root":"جعل","lemmaId":1223},{"id":"77:25:3","ayahNum":25,"wordNum":3,"word":"ٱلْأَرْضَ","meaning":"the earth (object of نَجْعَلِ)","transliteration":"l-arḍa","root":"أرض","lemmaId":149},{"id":"77:25:4","ayahNum":25,"wordNum":4,"word":"كِفَاتًا","meaning":"a container/gathering place (object of نَجْعَلِ - 'Did We not make the earth...')","transliteration":"kifātan","root":"كفت","lemmaId":null},{"id":"77:26:1","ayahNum":26,"wordNum":1,"word":"أَحْيَآءً","meaning":"living ones (as a direct object)","transliteration":"aḥyāan","root":"حيي","lemmaId":null},{"id":"77:26:2","ayahNum":26,"wordNum":2,"word":"وَأَمْوٰتًا","meaning":"and dead ones (as objects) (connected to أَحْيَآءً)","transliteration":"wa-amwātan","root":"موت","lemmaId":null},{"id":"77:27:1","ayahNum":27,"wordNum":1,"word":"وَجَعَلْنَا","meaning":"and we made/placed/set up (mountains in فِيهَا)","transliteration":"wajaʿalnā","root":"جعل","lemmaId":null},{"id":"77:27:2","ayahNum":27,"wordNum":2,"word":"فِيهَا","meaning":"in it/her (referring to الْأَرْضَ 'the earth' mentioned earlier)","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"77:27:3","ayahNum":27,"wordNum":3,"word":"رَوٰسِىَ","meaning":"mountains (objects of جَعَلْنَا/We made)","transliteration":"rawāsiya","root":"رسو","lemmaId":null},{"id":"77:27:4","ayahNum":27,"wordNum":4,"word":"شٰمِخٰتٍ","meaning":"tall/lofty ones (feminine plural)","transliteration":"shāmikhātin","root":"شمخ","lemmaId":null},{"id":"