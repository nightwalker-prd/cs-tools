d not (negating شَرَابًا 'drink')","transliteration":"walā","root":"","lemmaId":4170},{"id":"78:24:6","ayahNum":24,"wordNum":6,"word":"شَرَابًا","meaning":"any drink (as something tasted)","transliteration":"sharāban","root":"شرب","lemmaId":2149},{"id":"78:25:1","ayahNum":25,"wordNum":1,"word":"إِلَّا","meaning":"except (what follows حَمِيمًا وَغَسَّاقًا)","transliteration":"illā","root":"","lemmaId":486},{"id":"78:25:2","ayahNum":25,"wordNum":2,"word":"حَمِيمًا","meaning":"boiling water (object of إِلَّا)","transliteration":"ḥamīman","root":"حمم","lemmaId":null},{"id":"78:25:3","ayahNum":25,"wordNum":3,"word":"وَغَسَّاقًا","meaning":"and flowing pus","transliteration":"waghassāqan","root":"غسق","lemmaId":null},{"id":"78:26:1","ayahNum":26,"wordNum":1,"word":"جَزَآءً","meaning":"a repayment (as the object being given)","transliteration":"jazāan","root":"جزي","lemmaId":null},{"id":"78:26:2","ayahNum":26,"wordNum":2,"word":"وِفَاقًا","meaning":"as a fitting consequence (describes جَزَآءً - recompense)","transliteration":"wifāqan","root":"وفق","lemmaId":null},{"id":"78:27:1","ayahNum":27,"wordNum":1,"word":"إِنَّهُمْ","meaning":"indeed they (subject of كَانُوا)","transliteration":"innahum","root":"","lemmaId":502},{"id":"78:27:2","ayahNum":27,"wordNum":2,"word":"كَانُوا۟","meaning":"they were (subject of لَا يَرْجُونَ - they do not expect)","transliteration":"kānū","root":"كون","lemmaId":null},{"id":"78:27:3","ayahNum":27,"wordNum":3,"word":"لَا","meaning":"not (negates يَرْجُونَ)","transliteration":"lā","root":"","lemmaId":3147},{"id":"78:27:4","ayahNum":27,"wordNum":4,"word":"يَرْجُو","meaning":"he hopes/expects","transliteration":"yarjūna","root":"رجو","lemmaId":null},{"id":"78:27:5","ayahNum":27,"wordNum":5,"word":"حِسَابًا","meaning":"a reckoning (object of لَا يَرْجُونَ - they were not expecting)","transliteration":"ḥisāban","root":"حسب","lemmaId":1360},{"id":"78:28:1","ayahNum":28,"wordNum":1,"word":"وَكَذَّبُوا۟","meaning":"and they strongly denied/rejected (بِـَٔايٰتِنَا)","transliteration":"wakadhabū","root":"كذب","lemmaId":3069},{"id":"78:28:2","ayahNum":28,"wordNum":2,"word":"بِـَٔايٰتِنَا","meaning":"with/by our signs","transliteration":"biāyātinā","root":"أيي","lemmaId":30},{"id":"78:28:3","ayahNum":28,"wordNum":3,"word":"كِذَّابًا","meaning":"an intense/habitual liar (object of كَذَّبُوا/they denied)","transliteration":"kidhāban","root":"كذب","lemmaId":3069},{"id":"78:29:1","ayahNum":29,"wordNum":1,"word":"وَكُلَّ","meaning":"and every/all (object of أَحْصَيْنٰهُ)","transliteration":"wakulla","root":"كلل","lemmaId":null},{"id":"78:29:2","ayahNum":29,"wordNum":2,"word":"شَىْءٍ","meaning":"thing (possessed by كُلَّ - every/all)","transliteration":"shayin","root":"شيأ","lemmaId":null},{"id":"78:29:3","ayahNum":29,"wordNum":3,"word":"أَحْصَيْنٰهُ","meaning":"we counted it completely (referring to كُلَّ شَىْءٍ - everything)","transliteration":"aḥṣaynāhu","root":"حصي","lemmaId":null},{"id":"78:29:4","ayahNum":29,"wordNum":4,"word":"كِتٰبًا","meaning":"a record (being enumerated)","transliteration":"kitāban","root":"كتب","lemmaId":3060},{"id":"78:30:1","ayahNum":30,"wordNum":1,"word":"فَذُوقُوا۟","meaning":"so taste! (all of you)","transliteration":"fadhūqū","root":"ذوق","lemmaId":null},{"id":"78:30:2","ayahNum":30,"wordNum":2,"word":"فَلَن","meaning":"so never/will not (negates نَّزِيدَكُمْ)","transliteration":"falan","root":"","lemmaId":2761},{"id":"78:30:3","ayahNum":30,"wordNum":3,"word":"نَّزِيدَكُمْ","meaning":"we will surely increase you all","transliteration":"nazīdakum","root":"زيد","lemmaId":null},{"id":"78:30:4","ayahNum":30,"wordNum":4,"word":"إِلَّا","meaning":"except (connects to عَذَابًا - punishment)","transliteration":"illā","root":"","lemmaId":486},{"id":"78:30:5","ayahNum":30,"wordNum":5,"word":"عَذَابًا","meaning":"a punishment (object of نَّزِيدَكُمْ - we will increase you)","transliteration":"ʿadhāban","root":"عذب","lemmaId":2524},{"id":"78:31:1","ayahNum":31,"wordNum":1,"word":"إِنَّ","meaning":"ind