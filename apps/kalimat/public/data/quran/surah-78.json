less talk (object of يَسْمَعُونَ - they hear)","transliteration":"laghwan","root":"لغو","lemmaId":null},{"id":"78:35:5","ayahNum":35,"wordNum":5,"word":"وَلَا","meaning":"and not (negates كِذَّابًا)","transliteration":"walā","root":"","lemmaId":4170},{"id":"78:35:6","ayahNum":35,"wordNum":6,"word":"كِذَّابًا","meaning":"a liar (being described in لَّا يَسْمَعُونَ)","transliteration":"kidhāban","root":"كذب","lemmaId":3069},{"id":"78:36:1","ayahNum":36,"wordNum":1,"word":"جَزَآءً","meaning":"a reward/compensation (as the object of عَطَآءً - a gift)","transliteration":"jazāan","root":"جزي","lemmaId":null},{"id":"78:36:2","ayahNum":36,"wordNum":2,"word":"مِّن","meaning":"from (source of عَطَآءً - a gift)","transliteration":"min","root":"","lemmaId":3464},{"id":"78:36:3","ayahNum":36,"wordNum":3,"word":"رَّبِّكَ","meaning":"your Lord","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"78:36:4","ayahNum":36,"wordNum":4,"word":"عَطَآءً","meaning":"a gift (as the object of جَزَآءً/reward)","transliteration":"ʿaṭāan","root":"عطو","lemmaId":null},{"id":"78:36:5","ayahNum":36,"wordNum":5,"word":"حِسَابًا","meaning":"as a calculation (describes the gift/giving)","transliteration":"ḥisāban","root":"حسب","lemmaId":null},{"id":"78:37:1","ayahNum":37,"wordNum":1,"word":"رَّبِّ","meaning":"Lord of (connected to السَّمٰوٰتِ - the heavens)","transliteration":"rabbi","root":"ربب","lemmaId":null},{"id":"78:37:2","ayahNum":37,"wordNum":2,"word":"ٱلسَّمٰوٰتِ","meaning":"the skies/heavens (possessed by رَبِّ)","transliteration":"l-samāwāti","root":"سمو","lemmaId":null},{"id":"78:37:3","ayahNum":37,"wordNum":3,"word":"وَٱلْأَرْضِ","meaning":"and the earth (possessed by رَّبِّ)","transliteration":"wal-arḍi","root":"أرض","lemmaId":null},{"id":"78:37:4","ayahNum":37,"wordNum":4,"word":"وَمَا","meaning":"and what (that is between them)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"78:37:5","ayahNum":37,"wordNum":5,"word":"بَيْنَهُمَا","meaning":"between them both","tra