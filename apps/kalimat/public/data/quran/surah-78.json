:"نبت","lemmaId":null},{"id":"78:16:1","ayahNum":16,"wordNum":1,"word":"وَجَنَّاتٍ","meaning":"and gardens (connected to أَلْفَافًا - densely growing)","transliteration":"wajannātin","root":"جنن","lemmaId":null},{"id":"78:16:2","ayahNum":16,"wordNum":2,"word":"أَلْفَافًا","meaning":"densely grown (describing جَنَّاتٍ/gardens)","transliteration":"alfāfan","root":"لفف","lemmaId":null},{"id":"78:17:1","ayahNum":17,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly (emphasizes يَوْمَ ٱلْفَصْلِ)","transliteration":"inna","root":"","lemmaId":502},{"id":"78:17:2","ayahNum":17,"wordNum":2,"word":"يَوْمَ","meaning":"day (affected by إِنَّ)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"78:17:3","ayahNum":17,"wordNum":3,"word":"ٱلْفَصْلِ","meaning":"the separation (owned by يَوْم/day)","transliteration":"l-faṣli","root":"فصل","lemmaId":null},{"id":"78:17:4","ayahNum":17,"wordNum":4,"word":"كَانَ","meaning":"he/it was (describing مِيقٰتًا)","transliteration":"kāna","root":"كون","lemmaId":null},{"id":"78:17:5","ayahNum":17,"wordNum":5,"word":"مِيقٰتًا","meaning":"an appointed time (object of كَانَ)","transliteration":"mīqātan","root":"وقت","lemmaId":null},{"id":"78:18:1","ayahNum":18,"wordNum":1,"word":"يَوْمَ","meaning":"day (object of يُنفَخُ)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"78:18:2","ayahNum":18,"wordNum":2,"word":"يُنفَخُ","meaning":"it is blown (into الصُّورِ/the Horn)","transliteration":"yunfakhu","root":"نفخ","lemmaId":null},{"id":"78:18:3","ayahNum":18,"wordNum":3,"word":"فِى","meaning":"in (connects to ٱلصُّورِ - the Horn)","transliteration":"fī","root":"","lemmaId":2887},{"id":"78:18:4","ayahNum":18,"wordNum":4,"word":"ٱلصُّورِ","meaning":"in the horn/trumpet (after فِى)","transliteration":"l-ṣūri","root":"صور","lemmaId":null},{"id":"78:18:5","ayahNum":18,"wordNum":5,"word":null,"meaning":"and then you (all) come (after the trumpet is blown)","transliteration":"fatatūna","root":"أتي","lemmaId":null},{"id":"78:18:6","ayahN