","meaning":"no indeed, absolutely not! (shows strong denial or rejection of what was mentioned before ثُمَّ)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"78:5:3","ayahNum":5,"wordNum":3,"word":"سَيَعْلَمُونَ","meaning":"they will know","transliteration":"sayaʿlamūna","root":"علم","lemmaId":2583},{"id":"78:6:1","ayahNum":6,"wordNum":1,"word":"أَلَمْ","meaning":"Did not...? (expecting 'yes' as answer)","transliteration":"alam","root":"","lemmaId":3177},{"id":"78:6:2","ayahNum":6,"wordNum":2,"word":"نَجْعَلِ","meaning":"we make (jussive)","transliteration":"najʿali","root":"جعل","lemmaId":1223},{"id":"78:6:3","ayahNum":6,"wordNum":3,"word":"ٱلْأَرْضَ","meaning":"the earth (object of نَجْعَلِ/we made)","transliteration":"l-arḍa","root":"أرض","lemmaId":null},{"id":"78:6:4","ayahNum":6,"wordNum":4,"word":"مِهٰدًا","meaning":"a smooth spread-out place (2nd object of نَجْعَلِ - what the earth was made into)","transliteration":"mihādan","root":"مهد","lemmaId":null},{"id":"78:7:1","ayahNum":7,"wordNum":1,"word":"وَٱلْجِبَالَ","meaning":"and the mountains (object of an implied verb 'made')","transliteration":"wal-jibāla","root":"جبل","lemmaId":null},{"id":"78:7:2","ayahNum":7,"wordNum":2,"word":"أَوْتَادًا","meaning":"as pegs/stakes (object of 'We made')","transliteration":"awtādan","root":"وتد","lemmaId":null},{"id":"78:8:1","ayahNum":8,"wordNum":1,"word":"وَخَلَقْنٰكُمْ","meaning":"and we created you all (as pairs/mates)","transliteration":"wakhalaqnākum","root":"خلق","lemmaId":null},{"id":"78:8:2","ayahNum":8,"wordNum":2,"word":"أَزْوٰجًا","meaning":"as pairs/spouses (object of خَلَقْنٰ - We created)","transliteration":"azwājan","root":"زوج","lemmaId":null},{"id":"78:9:1","ayahNum":9,"wordNum":1,"word":"وَجَعَلْنَا","meaning":"and we made/put","transliteration":"wajaʿalnā","root":"جعل","lemmaId":null},{"id":"78:9:2","ayahNum":9,"wordNum":2,"word":"نَوْمَكُمْ","meaning":"your (plural) sleep (object of جَعَلْنَا)","transliteration":"nawmakum","root":"نوم","lem