y guide us","transliteration":"yahdūnanā","root":"هدي","lemmaId":null},{"id":"64:6:10","ayahNum":6,"wordNum":10,"word":"فَكَفَرُوا۟","meaning":"so they disbelieved","transliteration":"fakafarū","root":"كفر","lemmaId":null},{"id":"64:6:11","ayahNum":6,"wordNum":11,"word":"وَتَوَلَّوا۟","meaning":"and they turned themselves away","transliteration":"watawallaw","root":"ولي","lemmaId":4264},{"id":"64:6:12","ayahNum":6,"wordNum":12,"word":"وَّٱسْتَغْنَى","meaning":"and he sought to be self-sufficient","transliteration":"wa-is'taghnā","root":"غني","lemmaId":null},{"id":"64:6:13","ayahNum":6,"wordNum":13,"word":"ٱللَّهُ","meaning":"Allah (The One True God)","transliteration":"l-lahu","root":"أله","lemmaId":490},{"id":"64:6:14","ayahNum":6,"wordNum":14,"word":"وَاللَّهُ","meaning":"And Allah (as the subject)","transliteration":"wal-lahu","root":"","lemmaId":650},{"id":"64:6:15","ayahNum":6,"wordNum":15,"word":"غَنِىٌّ","meaning":"Self-Sufficient (describing اللَّهُ)","transliteration":"ghaniyyun","root":"غني","lemmaId":2728},{"id":"64:6:16","ayahNum":6,"wordNum":16,"word":"حَمِيدٌ","meaning":"praiseworthy (describing اللَّهُ - Allah)","transliteration":"ḥamīdun","root":"حمد","lemmaId":1406},{"id":"64:7:1","ayahNum":7,"wordNum":1,"word":"زَعَمَ","meaning":"he claimed (subject of كَفَرُوٓا۟)","transliteration":"zaʿama","root":"زعم","lemmaId":null},{"id":"64:7:2","ayahNum":7,"wordNum":2,"word":"ٱلَّذِينَ","meaning":"those who (subject of كَفَرُوا)","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"64:7:3","ayahNum":7,"wordNum":3,"word":"كَفَرُوٓا۟","meaning":"they disbelieved (with emphasis)","transliteration":"kafarū","root":"كفر","lemmaId":3087},{"id":"64:7:4","ayahNum":7,"wordNum":4,"word":"أَن","meaning":"that (introduces what كَفَرُوا believed)","transliteration":"an","root":"","lemmaId":368},{"id":"64:7:5","ayahNum":7,"wordNum":5,"word":"لَّن","meaning":"will never (negates يُبْعَثُوا۟ - be resurrected)","transliteration":"lan","root":"","lemmaId":null},{"id":"64:7:6","ayahNum":7,"wordNum":6,"word":"يُبْعَثُوا۟","meaning":"they will be sent forth/raised/resurrected","transliteration":"yub'ʿathū","root":"بعث","lemmaId":null},{"id":"64:7:7","ayahNum":7,"wordNum":7,"word":"قُلْ","meaning":"say! (a command to Prophet Muhammad ﷺ)","transliteration":"qul","root":"قول","lemmaId":2986},{"id":"64:7:8","ayahNum":7,"wordNum":8,"word":"بَلَىٰ","meaning":"yes indeed (contradicting 'they will not be resurrected')","transliteration":"balā","root":"","lemmaId":4661},{"id":"64:7:9","ayahNum":7,"wordNum":9,"word":"وَرَبِّى","meaning":"and by my Lord (used in an oath)","transliteration":"warabbī","root":"ربب","lemmaId":null},{"id":"64:7:10","ayahNum":7,"wordNum":10,"word":"لَتُبْعَثُنَّ","meaning":"surely you will definitely be raised up","transliteration":"latub'ʿathunna","root":"بعث","lemmaId":null},{"id":"64:7:11","ayahNum":7,"wordNum":11,"word":"ثُمَّ","meaning":"then (after a gap in time, connecting to لَتُنَبَّؤُنَّ)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"64:7:12","ayahNum":7,"wordNum":12,"word":"لَتُنَبَّؤُنَّ","meaning":"you will surely be informed thoroughly","transliteration":"latunabba-unna","root":"نبأ","lemmaId":null},{"id":"64:7:13","ayahNum":7,"wordNum":13,"word":"بِمَا","meaning":"with what (you did)","transliteration":"bimā","root":"","lemmaId":692},{"id":"64:7:14","ayahNum":7,"wordNum":14,"word":"عَمِلْتُمْ","meaning":"you (plural) did/worked/acted","transliteration":"ʿamil'tum","root":"عمل","lemmaId":2592},{"id":"64:7:15","ayahNum":7,"wordNum":15,"word":"وَذٰلِكَ","meaning":"and that","transliteration":"wadhālika","root":"","lemmaId":null},{"id":"64:7:16","ayahNum":7,"wordNum":16,"word":"عَلَى","meaning":"upon (connected to يَسِيرٌ)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"64:7:17","ayahNum":7,"wordNum":17,"word":"ٱللَّهِ","meaning":"of Allah","transliteration":"l-lahi","root":"أله","lemmaId":490},{"id":"64:7:18","ayahNum":7,"wordNum":18,"word":"يَسِيرٌ","meaning":"easy (describes something that is easy for Allah)","transliteration":"yasīrun","root":"يسر","lemmaId":4397},{"id":"64:8:1","ayahNum":8,"wordNum":1,"word":"فَآمِنُوا","meaning":"so (all of you) believe! (command to a group)","transliteration":"faāminū","root":"أمن","lemmaId":null},{"id":"64:8:2","ayahNum":8,"wordNum":2,"word":"بِٱللَّهِ","meaning":"in/by/with Allah (object of believe in فَـَٔامِنُوا۟)","transliteration":"bil-lahi","root":"","lemmaId":null},{"id":"64:8:3","ayahNum":8,"wordNum":3,"word":"وَرَسُولِهِۦ","meaning":"and His messenger (belonging to Allah)","transliteration":"warasūlihi","root":"رسل","lemmaId":null},{"id":"64:8:4","ayahNum":8,"wordNum":4,"word":"وَالنُّورِ","meaning":"and the light","transliteration":"wal-nūri","root":"نور","lemmaId":null},{"id":"64:8:5","ayahNum":8,"wordNum":5,"word":"ٱلَّذِىٓ","meaning":"the one who/which/that (describes النُّورِ)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"64:8:6","ayahNum":8,"wordNum":6,"word":"أَنزَلْنَا","meaning":"We sent down","transliteration":"anzalnā","root":"نزل","lemmaId":3993},{"id":"64:8:7","ayahNum":8,"wordNum":7,"word":"وَٱللَّهُ","meaning":"and Allah (as the subject of خَبِيرٌ)","transliteration":"wal-lahu","root":"","lemmaId":650},{"id":"64:8:8","ayahNum":8,"wordNum":8,"word":"بِمَا","meaning":"with what (that تَعْمَلُونَ you do)","transliteration":"bimā","root":"","lemmaId":692},{"id":"64:8:9","ayahNum":8,"wordNum":9,"word":"تَعْمَلُونَ","meaning":"you all work (referring to the believers being addressed in this ayah)","transliteration":"taʿmalūna","root":"عمل","lemmaId":2592},{"id":"64:8:10","ayahNum":8,"wordNum":10,"word":"خَبِيرٌ","meaning":"All-Aware (a name/attribute of اللَّهِ)","transliteration":"khabīrun","root":"خبر","lemmaId":null},{"id":"64:9:1","ayahNum":9,"wordNum":1,"word":"يَوْمَ","meaning":"the day (object of يَجْمَعُكُمْ - He will gather you)","transliteration":"yawma","root":"يوم","lemmaId":4512},{"id":"64:9:2","ayahNum":9,"wordNum":2,"word":"يَجْمَعُكُمْ","meaning":