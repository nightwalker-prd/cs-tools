2:9","ayahNum":2,"wordNum":9,"word":"بِمَا","meaning":"with what/whatever (connected to تَعْمَلُونَ)","transliteration":"bimā","root":"","lemmaId":3215},{"id":"64:2:10","ayahNum":2,"wordNum":10,"word":"تَعْمَلُونَ","meaning":"you (all) act/work (in the present) (object of بِمَا)","transliteration":"taʿmalūna","root":"عمل","lemmaId":2592},{"id":"64:2:11","ayahNum":2,"wordNum":11,"word":"بَصِيرٌ","meaning":"All-Seeing (describing اللَّهُ)","transliteration":"baṣīrun","root":"بصر","lemmaId":null},{"id":"64:3:1","ayahNum":3,"wordNum":1,"word":"خَلَقَ","meaning":"he created (subject of the sentence about creating heavens and earth)","transliteration":"khalaqa","root":"خلق","lemmaId":null},{"id":"64:3:2","ayahNum":3,"wordNum":2,"word":"ٱلسَّمٰوٰتِ","meaning":"the heavens (object of خَلَقَ - He created)","transliteration":"l-samāwāti","root":"سمو","lemmaId":null},{"id":"64:3:3","ayahNum":3,"wordNum":3,"word":"وَٱلْأَرْضَ","meaning":"and the earth (object of خَلَقَ - He created)","transliteration":"wal-arḍa","root":"أرض","lemmaId":null},{"id":"64:3:4","ayahNum":3,"wordNum":4,"word":"بِالْحَقِّ","meaning":"with/by the truth","transliteration":"bil-ḥaqi","root":"حقق","lemmaId":null},{"id":"64:3:5","ayahNum":3,"wordNum":5,"word":"وَصَوَّرَكُمْ","meaning":"and He formed you all (perfectly)","transliteration":"waṣawwarakum","root":"صور","lemmaId":null},{"id":"64:3:6","ayahNum":3,"wordNum":6,"word":"فَأَحْسَنَ","meaning":"and then He made (them) beautiful (the صُوَرَكُمْ/your forms)","transliteration":"fa-aḥsana","root":"حسن","lemmaId":1357},{"id":"64:3:7","ayahNum":3,"wordNum":7,"word":"صُوَرَكُمْ","meaning":"your forms (referring to how Allah shaped you)","transliteration":"ṣuwarakum","root":"صور","lemmaId":null},{"id":"64:3:8","ayahNum":3,"wordNum":8,"word":"وَإِلَيْهِ","meaning":"and to Him (referring to Allah)","transliteration":"wa-ilayhi","root":"","lemmaId":485},{"id":"64:3:9","ayahNum":3,"wordNum":9,"word":"ٱلْمَصِيرُ","meaning":"the final destination (where everything returns to Allah)","transliteration":"l-maṣīru","root":"صير","lemmaId":null},{"id":"64:4:1","ayahNum":4,"wordNum":1,"word":"يَعْلَمُ","meaning":"he knows (what is in the heavens and earth)","transliteration":"yaʿlamu","root":"علم","lemmaId":2583},{"id":"64:4:2","ayahNum":4,"wordNum":2,"word":"مَا","meaning":"what (object of يَعْلَمُ - He knows)","transliteration":"mā","root":"","lemmaId":3215},{"id":"64:4:3","ayahNum":4,"wordNum":3,"word":"فِى","meaning":"in/within (connects ما to السَّمٰوٰتِ)","transliteration":"fī","root":"","lemmaId":2887},{"id":"64:4:4","ayahNum":4,"wordNum":4,"word":"ٱلسَّمٰوٰتِ","meaning":"the heavens (possessed by/connected to something)","transliteration":"l-samāwāti","root":"سمو","lemmaId":null},{"id":"64:4:5","ayahNum":4,"wordNum":5,"word":"وَٱلْأَرْضِ","meaning":"and the earth (connected to فِى)","transliteration":"wal-arḍi","root":"أرض","lemmaId":149},{"id":"64:4:6","ayahNum":4,"wordNum":6,"word":"وَيَعْلَمُ","meaning":"and he knows (connected to يَعْلَمُ before it)","transliteration":"wayaʿlamu","root":"علم","lemmaId":2583},{"id":"64:4:7","ayahNum":4,"wordNum":7,"word":"مَا","meaning":"that which (object of يَعْلَمُ - He knows)","transliteration":"mā","root":"","lemmaId":3215},{"id":"64:4:8","ayahNum":4,"wordNum":8,"word":"تُسِرُّونَ","meaning":"you (all) keep secret (subject of يَعْلَمُ)","transliteration":"tusirrūna","root":"سرر","lemmaId":null},{"id":"64:4:9","ayahNum":4,"wordNum":9,"word":"وَمَا","meaning":"and what (that you conceal in تُسِرُّونَ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"64:4:10","ayahNum":4,"wordNum":10,"word":"تُعْلِنُونَ","meaning":"you (all) announce openly","transliteration":"tuʿ'linūna","root":"علن","lemmaId":null},{"id":"64:4:11","ayahNum":4,"wordNum":11,"word":"وَٱللَّهُ","meaning":"And Allah (as the subject of عَلِيمٌ)","transliteration":"wal-lahu","root":"","lemmaId":650},{"id":"64:4:12","ayahNum":4,"wordNum":12,"word":"عَلِيمٌۢ","meaning":"All-Knowing One (divine attribute of اللَّهُ)","