,"word":"ثُمَّ","meaning":"then/thereafter (connecting فَلَهُمْ عَذَابُ with what came before)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"85:10:7","ayahNum":10,"wordNum":7,"word":"لَمْ","meaning":"not (in the past, before يَتُوبُوا۟)","transliteration":"lam","root":"","lemmaId":3146},{"id":"85:10:8","ayahNum":10,"wordNum":8,"word":"يَتُوبُوا۟","meaning":"they return back (to what is right)","transliteration":"yatūbū","root":"توب","lemmaId":853},{"id":"85:10:9","ayahNum":10,"wordNum":9,"word":"فَلَهُمْ","meaning":"then for them (connected to عَذَابُ - punishment)","transliteration":"falahum","root":"","lemmaId":null},{"id":"85:10:10","ayahNum":10,"wordNum":10,"word":"عَذَابُ","meaning":"punishment (of جَهَنَّمَ)","transliteration":"ʿadhābu","root":"عذب","lemmaId":2524},{"id":"85:10:11","ayahNum":10,"wordNum":11,"word":"جَهَنَّمَ","meaning":"Hell (object of عَذَابُ)","transliteration":"jahannama","root":"","lemmaId":1246},{"id":"85:10:12","ayahNum":10,"wordNum":12,"word":"وَلَهُمْ","meaning":"and for them (connected to عَذَابُ - punishment)","transliteration":"walahum","root":"","lemmaId":3146},{"id":"85:10:13","ayahNum":10,"wordNum":13,"word":"عَذَابُ","meaning":"punishment (subject of فَلَهُمْ)","transliteration":"ʿadhābu","root":"عذب","lemmaId":2524},{"id":"85:10:14","ayahNum":10,"wordNum":14,"word":"ٱلْحَرِيقِ","meaning":"the intense fire (describing عَذَابُ/punishment)","transliteration":"l-ḥarīqi","root":"حرق","lemmaId":1345},{"id":"85:11:1","ayahNum":11,"wordNum":1,"word":"إِنَّ","meaning":"indeed/verily (emphasizes ٱلَّذِينَ ءَامَنُوا۟)","transliteration":"inna","root":"","lemmaId":502},{"id":"85:11:2","ayahNum":11,"wordNum":2,"word":"ٱلَّذِينَ","meaning":"those who - connects descriptions to people or things","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"85:11:3","ayahNum":11,"wordNum":3,"word":"ءَامَنُوا۟","meaning":"they believed (connected to وَعَمِلُوا۟ - and they did)","transliteration":"āmanū","root":"أمن","lemmaId":nu