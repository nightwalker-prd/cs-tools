null},{"id":"85:8:1","ayahNum":8,"wordNum":1,"word":"وَمَا","meaning":"and not (connects this negation to previous statement)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"85:8:2","ayahNum":8,"wordNum":2,"word":"نَقَمُوا۟","meaning":"they hated (subject of وَمَا)","transliteration":"naqamū","root":"نقم","lemmaId":null},{"id":"85:8:3","ayahNum":8,"wordNum":3,"word":"مِنْهُمْ","meaning":"from them","transliteration":"min'hum","root":"","lemmaId":null},{"id":"85:8:4","ayahNum":8,"wordNum":4,"word":"إِلَّآ","meaning":"except (connects to أَن يُؤْمِنُوا۟)","transliteration":"illā","root":"","lemmaId":486},{"id":"85:8:5","ayahNum":8,"wordNum":5,"word":"أَن","meaning":"that (connects to يُؤْمِنُوا - they believe)","transliteration":"an","root":"","lemmaId":368},{"id":"85:8:6","ayahNum":8,"wordNum":6,"word":"يُؤْمِنُوا۟","meaning":"they believe (in اللَّهِ)","transliteration":"yu'minū","root":"أمن","lemmaId":19},{"id":"85:8:7","ayahNum":8,"wordNum":7,"word":"بِٱللَّهِ","meaning":"in/by/with Allah","transliteration":"bil-lahi","root":"","lemmaId":null},{"id":"85:8:8","ayahNum":8,"wordNum":8,"word":"ٱلْعَزِيزِ","meaning":"The Mighty One (describing اللَّهِ)","transliteration":"l-ʿazīzi","root":"عزز","lemmaId":null},{"id":"85:8:9","ayahNum":8,"wordNum":9,"word":"ٱلْحَمِيدِ","meaning":"of the praiseworthy","transliteration":"l-ḥamīdi","root":"حمد","lemmaId":1406},{"id":"85:9:1","ayahNum":9,"wordNum":1,"word":"ٱلَّذِى","meaning":"The one who/which (owns مُلْكُ)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"85:9:2","ayahNum":9,"wordNum":2,"word":"لَهُۥ","meaning":"for him/to him (possessor of مُلْكُ)","transliteration":"lahu","root":"","lemmaId":3146},{"id":"85:9:3","ayahNum":9,"wordNum":3,"word":"مُلْكُ","meaning":"dominion/kingdom (subject of لَهُۥ - to him belongs)","transliteration":"mul'ku","root":"ملك","lemmaId":null},{"id":"85:9:4","ayahNum":9,"wordNum":4,"word":"ٱلسَّمٰوٰتِ","meaning":"the heavens (possessed by something)","transliteration":"l