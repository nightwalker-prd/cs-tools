":"ṭawīlan","root":"طول","lemmaId":null},{"id":"73:8:1","ayahNum":8,"wordNum":1,"word":"وَٱذْكُرِ","meaning":"and remember! (command to اسْمَ رَبِّكَ)","transliteration":"wa-udh'kuri","root":"ذكر","lemmaId":null},{"id":"73:8:2","ayahNum":8,"wordNum":2,"word":"ٱسْمَ","meaning":"name (object of اذْكُرِ)","transliteration":"is'ma","root":"سمو","lemmaId":null},{"id":"73:8:3","ayahNum":8,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (possessed by اسم/name)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"73:8:4","ayahNum":8,"wordNum":4,"word":"وَتَبَتَّلْ","meaning":"and devote yourself completely! (command)","transliteration":"watabattal","root":"بتل","lemmaId":null},{"id":"73:8:5","ayahNum":8,"wordNum":5,"word":"إِلَيْهِ","meaning":"to him","transliteration":"ilayhi","root":"","lemmaId":485},{"id":"73:8:6","ayahNum":8,"wordNum":6,"word":"تَبْتِيلًا","meaning":"with complete devotion (describes وَتَبَتَّلْ)","transliteration":"tabtīlan","root":"بتل","lemmaId":null},{"id":"73:9:1","ayahNum":9,"wordNum":1,"word":"رَّبُّ","meaning":"The Lord (owner of المشرق والمغرب - the East and West)","transliteration":"rabbu","root":"ربب","lemmaId":null},{"id":"73:9:2","ayahNum":9,"wordNum":2,"word":"ٱلْمَشْرِقِ","meaning":"of the east (possessed by رَّبُّ - Lord)","transliteration":"l-mashriqi","root":"شرق","lemmaId":null},{"id":"73:9:3","ayahNum":9,"wordNum":3,"word":"وَٱلْمَغْرِبِ","meaning":"and the west (possessed by رَّبُّ)","transliteration":"wal-maghribi","root":"غرب","lemmaId":null},{"id":"73:9:4","ayahNum":9,"wordNum":4,"word":"لَآ","meaning":"no/not (strong emphasis)","transliteration":"lā","root":"","lemmaId":3147},{"id":"73:9:5","ayahNum":9,"wordNum":5,"word":"إِلٰهَ","meaning":"god, deity (object of لَآ/no)","transliteration":"ilāha","root":"أله","lemmaId":null},{"id":"73:9:6","ayahNum":9,"wordNum":6,"word":"إِلَّا","meaning":"except (following لَآ)","transliteration":"illā","root":"","lemmaId":486},{"id":"73:9:7","ayahNum":9,"wordNum":7,"word":"هُوَ","meaning":"He (referring to Allah mentioned as رَبُّ/Lord)","transliteration":"huwa","root":"","lemmaId":4772},{"id":"73:9:8","ayahNum":9,"wordNum":8,"word":"فَٱتَّخِذْهُ","meaning":"so take him! (as وَكِيلًا)","transliteration":"fa-ittakhidh'hu","root":"أخذ","lemmaId":null},{"id":"73:9:9","ayahNum":9,"wordNum":9,"word":"وَكِيلًا","meaning":"as a guardian/trustee (object of فَٱتَّخِذْهُ - take him)","transliteration":"wakīlan","root":"وكل","lemmaId":4279},{"id":"73:10:1","ayahNum":10,"wordNum":1,"word":"وَٱصْبِرْ","meaning":"and be patient! (command to Prophet Muhammad ﷺ regarding what they say)","transliteration":"wa-iṣ'bir","root":"صبر","lemmaId":2245},{"id":"73:10:2","ayahNum":10,"wordNum":2,"word":"عَلَىٰ","meaning":"upon, on (connects to يَقُولُونَ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"73:10:3","ayahNum":10,"wordNum":3,"word":"مَا","meaning":"what (they say)","transliteration":"mā","root":"","lemmaId":3215},{"id":"73:10:4","ayahNum":10,"wordNum":4,"word":"يَقُولُونَ","meaning":"they say/are saying","transliteration":"yaqūlūna","root":"قول","lemmaId":2910},{"id":"73:10:5","ayahNum":10,"wordNum":5,"word":"وَٱهْجُرْهُمْ","meaning":"and abandon them! (command to Prophet ﷺ)","transliteration":"wa-uh'jur'hum","root":"هجر","lemmaId":4133},{"id":"73:10:6","ayahNum":10,"wordNum":6,"word":"هَجْرًا","meaning":"a graceful abandonment (describing how to abandon them in وَٱهْجُرْهُمْ)","transliteration":"hajran","root":"هجر","lemmaId":null},{"id":"73:10:7","ayahNum":10,"wordNum":7,"word":"جَمِيلًا","meaning":"beautifully (describes how هَجْرًا/departure should be done)","transliteration":"jamīlan","root":"جمل","lemmaId":null},{"id":"73:11:1","ayahNum":11,"wordNum":1,"word":"وَذَرْنِى","meaning":"and leave me! (command to one person)","transliteration":"wadharnī","root":"وذر","lemmaId":null},{"id":"73:11:2","ayahNum":11,"wordNum":2,"word":"وَالْمُكَذِّبِين","meaning":"and the ones who intensely deny/reject (connected to وَذَرْنِى)","transliteration":"wal-mukadhibīna","root":"كذب","lemmaId":null},{"id":"73:11:3","ayahNum":11,"wordNum":3,"word":"أُو۟لِى","meaning":"possessors of (connected to النَّعْمَةِ)","transliteration":"ulī","root":"","lemmaId":384},{"id":"73:11:4","ayahNum":11,"wordNum":4,"word":"ٱلنَّعْمَةِ","meaning":"the blessing (possessed by someone)","transliteration":"l-naʿmati","root":"نعم","lemmaId":4032},{"id":"73:11:5","ayahNum":11,"wordNum":5,"word":"وَمَهِّلْهُمْ","meaning":"and give them time! (command, connected to وَذَرْنِى - and leave me)","transliteration":"wamahhil'hum","root":"مهل","lemmaId":3490},{"id":"73:11:6","ayahNum":11,"wordNum":6,"word":"قَلِيلًا","meaning":"a little while (describes وَمَهِّلْهُمْ - give them respite)","transliteration":"qalīlan","root":"قلل","lemmaId":null},{"id":"73:12:1","ayahNum":12,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly (emphasizes لَدَيْنَآ أَنكَالًا وَجَحِيمًا - 'with Us are shackles and burning fire')","transliteration":"inna","root":"","lemmaId":502},{"id":"73:12:2","ayahNum":12,"wordNum":2,"word":"لَدَيْنَآ","meaning":"with us (connected to أَنكَالًا - shackles)","transliteration":"ladaynā","root":"","lemmaId":null},{"id":"73:12:3","ayahNum":12,"wordNum":3,"word":"أَنكَالًا","meaning":"restraints/fetters (object of لَدَيْنَآ - we have)","transliteration":"ankālan","root":"نكل","lemmaId":null},{"id":"73:12:4","ayahNum":12,"wordNum":4,"word":"وَجَحِيمًا","meaning":"and hellfire (object of إِنَّ لَدَيْنَآ - indeed, with Us)","transliteration":"wajaḥīman","root":"جحم","lemmaId":null},{"id":"73:13:1","ayahNum":13,"wordNum":1,"word":"وَطَعَامًا","meaning":"and food (coordinated with previous items in verse 73:12)","transliteration":"waṭaʿāman","root":"طعم","lemmaId":null},{"id":"73:13:2","ayahNum":13,"wordNum":2,"word":"ذَا","meaning":"possessing (describes طَعَامًا - food)","transliteration":"dhā","root":"","lemmaId":1677},{"id":"73:13:3","ayahNum":13,"wordNum":3,"word":"غُصَّةٍ","meaning":"a choking thing (describing طَعَامًا/food)","transliteration":"ghuṣṣatin","root":"غصص","lemmaId":null},{"id":"73:13:4","ayahNum":13,"wordNum":4,"word":"وَعَذَابًا","meaning":"and a punishment","transliteration":"waʿadhāban","root":"عذب","lemmaId":null},{"id":"73:13:5","ayahNum":13,"wordNum":5,"word":"أَلِيمًا","meaning":"severely painful (describes عَذَابًا/punishment)","transliteration":"alīman","root":"ألم","lemmaId":null},{"id":"73:14:1","ayahNum":14,"wordNum":1,"word":"يَوْمَ","meaning":"a day (accusative)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"73:14:2","ayahNum":14,"wordNum":2,"word":"تَرْجُفُ","meaning":"it (feminine) shakes violently","transliteration":"tarjufu","root":"رجف","lemmaId":null},{"id":"73:14:3","ayahNum":14,"wordNum":3,"word":"ٱلْأَرْضُ","meaning":"the earth (subject of تَرْجُفُ - shakes/quakes)","transliteration":"l-arḍu","root":"أرض","lemmaId":null},{"id":"73:14:4","ayahNum":14,"wordNum":4,"word":"وَٱلْجِبَالُ","meaning":"and the mountains (subject of تَرْجُفُ - shake/quake)","transliteration":"wal-jibālu","root":"جبل","lemmaId":null},{"id":"73:14:5","ayahNum":14,"wordNum":5,"word":"وَكَانَتِ","meaning":"and it was (connecting to what happened before)","transliteration":"wakānati","root":"كون","lemmaId":null},{"id":"73:14:6","ayahNum":14,"wordNum":6,"word":"ٱلْجِبَالُ","meaning":"the mountains (subject of تَرْجُفُ - shakes/trembles)","transliteration":"l-jibālu","root":"جبل","lemmaId":null},{"id":"73:14:7","ayahNum":14,"wordNum":7,"word":"كَثِيبًا","meaning":"a heap/mound (object of كانت)","transliteration":"kathīban","root":"كثب","lemmaId":null},{"id":"73:14:8","ayahNum":14,"wordNum":8,"word":"مَّهِيلًا","meaning":"completely poured out (describing الْجِبَالُ/the mountains)","transliteration":"mahīlan","root":"هيل","lemmaId":null},{"id":"73:15:1","ayahNum":15,"wordNum":1,"word":"إِنَّآ","meaning":"indeed we (subject of أَرْسَلْنَآ)","transliteration":"innā","root":"","lemmaId":502},{"id":"73:15:2","ayahNum":15,"wordNum":2,"word":"أَرْسَلْنَآ","meaning":"we sent forth (connected t