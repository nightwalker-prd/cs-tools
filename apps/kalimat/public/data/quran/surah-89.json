":"for/to one who possesses","transliteration":"lidhī","root":"","lemmaId":null},{"id":"89:5:6","ayahNum":5,"wordNum":6,"word":"حِجْرٍ","meaning":"intelligence (describing someone with قَسَمٌ/oath)","transliteration":"ḥij'rin","root":"حجر","lemmaId":null},{"id":"89:6:1","ayahNum":6,"wordNum":1,"word":"أَلَمْ","meaning":"did not (expecting 'yes' as answer)","transliteration":"alam","root":"","lemmaId":3177},{"id":"89:6:2","ayahNum":6,"wordNum":2,"word":"تَرَ","meaning":"you see (after أَلَمْ)","transliteration":"tara","root":"رأي","lemmaId":null},{"id":"89:6:3","ayahNum":6,"wordNum":3,"word":"كَيْفَ","meaning":"how","transliteration":"kayfa","root":"كيف","lemmaId":null},{"id":"89:6:4","ayahNum":6,"wordNum":4,"word":"فَعَلَ","meaning":"he did (referring to what رَبُّكَ/your Lord did)","transliteration":"faʿala","root":"فعل","lemmaId":null},{"id":"89:6:5","ayahNum":6,"wordNum":5,"word":"رَبُّكَ","meaning":"your Lord (who did فَعَلَ)","transliteration":"rabbuka","root":"ربب","lemmaId":null},{"id":"89:6:6","ayahNum":6,"wordNum":6,"word":"بِعَادٍ","meaning":"with/by Aad (the tribe being punished by اللَّهِ)","transliteration":"biʿādin","root":"عود","lemmaId":null},{"id":"89:7:1","ayahNum":7,"wordNum":1,"word":"إِرَمَ","meaning":"Iram (as the object being referred to)","transliteration":"irama","root":"","lemmaId":463},{"id":"89:7:2","ayahNum":7,"wordNum":2,"word":"ذَاتِ","meaning":"possessor of (feminine, describing العِمَادِ)","transliteration":"dhāti","root":"","lemmaId":null},{"id":"89:7:3","ayahNum":7,"wordNum":3,"word":"ٱلْعِمَادِ","meaning":"the pillars (possessed by إِرَمَ)","transliteration":"l-ʿimādi","root":"عمد","lemmaId":null},{"id":"89:8:1","ayahNum":8,"wordNum":1,"word":"ٱلَّتِى","meaning":"who/which (for feminine things)","transliteration":"allatī","root":"","lemmaId":null},{"id":"89:8:2","ayahNum":8,"wordNum":2,"word":"لَمْ","meaning":"not (negates يُخْلَقْ - was not created)","transliteration":"lam","root":"","lemmaId":3177},{"id":"89:8:3","ayahNum":8,"wo