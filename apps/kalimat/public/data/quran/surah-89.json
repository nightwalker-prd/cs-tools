9,"word":"فَيَقُولُ","meaning":"and so he says (after being blessed by رَبُّهُۥ)","transliteration":"fayaqūlu","root":"قول","lemmaId":null},{"id":"89:15:10","ayahNum":15,"wordNum":10,"word":"رَبِّىٓ","meaning":"my Lord (subject of يَقُولُ)","transliteration":"rabbī","root":"ربب","lemmaId":1742},{"id":"89:15:11","ayahNum":15,"wordNum":11,"word":"أَكْرَمَنِ","meaning":"he honored me","transliteration":"akramani","root":"كرم","lemmaId":3076},{"id":"89:16:1","ayahNum":16,"wordNum":1,"word":"وَأَمَّآ","meaning":"and as for (introduces a condition in إِذَا that follows)","transliteration":"wa-ammā","root":"","lemmaId":4637},{"id":"89:16:2","ayahNum":16,"wordNum":2,"word":"إِذَا","meaning":"whenever (introducing the first part of the test mentioned in ٱبْتَلَىٰهُ)","transliteration":"idhā","root":"","lemmaId":461},{"id":"89:16:3","ayahNum":16,"wordNum":3,"word":"مَا","meaning":"when (connected to إِذَا)","transliteration":"mā","root":"","lemmaId":3215},{"id":"89:16:4","ayahNum":16,"wordNum":4,"word":"ٱبْتَلَىٰهُ","meaning":"he tested him","transliteration":"ib'talāhu","root":"بلو","lemmaId":null},{"id":"89:16:5","ayahNum":16,"wordNum":5,"word":"فَقَدَرَ","meaning":"and so he restricted (the provision)","transliteration":"faqadara","root":"قدر","lemmaId":null},{"id":"89:16:6","ayahNum":16,"wordNum":6,"word":"عَلَيْهِ","meaning":"upon him (referring to the person whose provision was restricted)","transliteration":"ʿalayhi","root":"","lemmaId":2582},{"id":"89:16:7","ayahNum":16,"wordNum":7,"word":"رِزْقَهُۥ","meaning":"his provision (what Allah restricted)","transliteration":"riz'qahu","root":"رزق","lemmaId":null},{"id":"89:16:8","ayahNum":16,"wordNum":8,"word":"فَيَقُولُ","meaning":"and so he says (responding to what happened before)","transliteration":"fayaqūlu","root":"قول","lemmaId":2986},{"id":"89:16:9","ayahNum":16,"wordNum":9,"word":"رَبِّىٓ","meaning":"my Lord (subject of يَقُولُ)","transliteration":"rabbī","root":"ربب","lemmaId":null},{"id":"89:16:10","ayahNum":16,"w