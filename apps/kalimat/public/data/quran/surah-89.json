":"ʿadhābahu","root":"عذب","lemmaId":null},{"id":"89:25:5","ayahNum":25,"wordNum":5,"word":"أَحَدٌ","meaning":"anyone (who will be punished like His punishment)","transliteration":"aḥadun","root":"أحد","lemmaId":null},{"id":"89:26:1","ayahNum":26,"wordNum":1,"word":"وَلَا","meaning":"and not (negates يُوثِقُ - binds/chains)","transliteration":"walā","root":"","lemmaId":3147},{"id":"89:26:2","ayahNum":26,"wordNum":2,"word":"يُوثِقُ","meaning":"he binds/ties up (subject of أَحَدٌ)","transliteration":"yūthiqu","root":"وثق","lemmaId":null},{"id":"89:26:3","ayahNum":26,"wordNum":3,"word":"وَثَاقَهُۥٓ","meaning":"his binding/chain (being acted upon by يُوثِقُ - binds/ties up)","transliteration":"wathāqahu","root":"وثق","lemmaId":null},{"id":"89:26:4","ayahNum":26,"wordNum":4,"word":"أَحَدٌ","meaning":"anyone (who trusts)","transliteration":"aḥadun","root":"أحد","lemmaId":82},{"id":"89:27:1","ayahNum":27,"wordNum":1,"word":"يٰٓأَيَّتُهَا","meaning":"O you (feminine, with emphasis)","transliteration":"yāayyatuhā","root":"أيي","lemmaId":null},{"id":"89:27:2","ayahNum":27,"wordNum":2,"word":"ٱلنَّفْسُ","meaning":"the soul/self (in subject form)","transliteration":"l-nafsu","root":"نفس","lemmaId":null},{"id":"89:27:3","ayahNum":27,"wordNum":3,"word":"ٱلْمُطْمَئِنَّةُ","meaning":"O soul that feels complete peace (being addressed in يٰٓأَيَّتُهَا ٱلنَّفْسُ)","transliteration":"l-muṭ'ma-inatu","root":"طمأن","lemmaId":null},{"id":"89:28:1","ayahNum":28,"wordNum":1,"word":"اِرْجِعِيٓ","meaning":"return! (command to one female)","transliteration":"ir'jiʿī","root":"رجع","lemmaId":1746},{"id":"89:28:2","ayahNum":28,"wordNum":2,"word":"إِلَىٰ","meaning":"to/toward (connecting ٱرْجِعِىٓ with رَبِّكِ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"89:28:3","ayahNum":28,"wordNum":3,"word":"رَبِّكِ","meaning":"your Lord (addressing a female, after إلى/to)","transliteration":"rabbiki","root":"ربب","lemmaId":1742},{"id":"89:28:4","ayahNum":28,"wordNum":4,"word":"رَاضِيَةً","meaning":"being content/pleased (describing state while returning)","transliteration":"rāḍiyatan","root":"رضو","lemmaId":null},{"id":"89:28:5","ayahNum":28,"wordNum":5,"word":"مَّرْضِيَّةً","meaning":"pleased/content (feminine, indefinite)","transliteration":"marḍiyyatan","root":"رضو","lemmaId":null},{"id":"89:29:1","ayahNum":29,"wordNum":1,"word":"فَٱدْخُلِى","meaning":"so enter! (feminine) (connected to فِى عِبٰدِى)","transliteration":"fa-ud'khulī","root":"دخل","lemmaId":null},{"id":"89:29:2","ayahNum":29,"wordNum":2,"word":"فِى","meaning":"in/within/inside (connects عِبٰدِى to فَٱدْخُلِى)","transliteration":"fī","root":"","lemmaId":2887},{"id":"89:29:3","ayahNum":29,"wordNum":3,"word":"عِبٰدِى","meaning":"my servants","transliteration":"ʿibādī","root":"عبد","lemmaId":null},{"id":"89:30:1","ayahNum":30,"wordNum":1,"word":"وَٱدْخُلِى","meaning":"and enter! (feminine) (connected to جَنَّتِى)","transliteration":"wa-ud'khulī","root":"دخل","lemmaId":null},{"id":"89:30:2","ayahNum":30,"wordNum":2,"word":"جَنَّتِى","meaning":"my garden (mentioned after وَٱدْخُلِى - and enter)","transliteration":"jannatī","root":"جنن","lemmaId":1241}]