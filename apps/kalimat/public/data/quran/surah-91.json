[{"id":"91:1:1","ayahNum":1,"wordNum":1,"word":"وَٱلشَّمْسِ","meaning":"and the sun","transliteration":"wal-shamsi","root":"شمس","lemmaId":2176},{"id":"91:1:2","ayahNum":1,"wordNum":2,"word":"وَضُحَىٰهَا","meaning":"and its morning brightness","transliteration":"waḍuḥāhā","root":"ضحو","lemmaId":null},{"id":"91:2:1","ayahNum":2,"wordNum":1,"word":"وَٱلْقَمَرِ","meaning":"and the moon (object of oath, followed by إِذَا تَلَىٰهَا - when it follows it)","transliteration":"wal-qamari","root":"قمر","lemmaId":null},{"id":"91:2:2","ayahNum":2,"wordNum":2,"word":"إِذَا","meaning":"when (followed by تَلَىٰهَا)","transliteration":"idhā","root":"","lemmaId":461},{"id":"91:2:3","ayahNum":2,"wordNum":3,"word":"تَلَىٰهَا","meaning":"he followed it (the moon)","transliteration":"talāhā","root":"تلو","lemmaId":null},{"id":"91:3:1","ayahNum":3,"wordNum":1,"word":"وَٱلنَّهَارِ","meaning":"and the daytime (sworn by in an oath)","transliteration":"wal-nahāri","root":"نهر","lemmaId":null},{"id":"91:3:2","ayahNum":3,"wordNum":2,"word":"إِذَا","meaning":"when (introduces what happens in النَّهَارِ - the day)","transliteration":"idhā","root":"","lemmaId":4646},{"id":"91:3:3","ayahNum":3,"wordNum":3,"word":"جَلَّىٰهَا","meaning":"he made it (feminine) very clear","transliteration":"jallāhā","root":"جلو","lemmaId":null},{"id":"91:4:1","ayahNum":4,"wordNum":1,"word":"وَٱلَّيْلِ","meaning":"and the night (followed by إِذَا يَغْشَىٰهَا - when it covers it)","transliteration":"wa-al-layli","root":"ليل","lemmaId":3194},{"id":"91:4:2","ayahNum":4,"wordNum":2,"word":"إِذَا","meaning":"when (referring to يَغْشَىٰهَا - it covers it)","transliteration":"idhā","root":"","lemmaId":461},{"id":"91:4:3","ayahNum":4,"wordNum":3,"word":"يَغْشَىٰهَا","meaning":"he covers/is covering it (referring to the night covering the earth)","transliteration":"yaghshāhā","root":"غشو","lemmaId":null},{"id":"91:5:1","ayahNum":5,"wordNum":1,"word":"وَٱلسَّمَآءِ","meaning":"and by the sky (as an oath)","transliteration":"wal-samāi","root":"سمو","lemmaId":null},{"id":"91:5:2","ayahNum":5,"wordNum":2,"word":"وَمَا","meaning":"and what","transliteration":"wamā","root":"","lemmaId":3215},{"id":"91:5:3","ayahNum":5,"wordNum":3,"word":"بَنَىٰهَا","meaning":"he built it (fem)","transliteration":"banāhā","root":"بني","lemmaId":null},{"id":"91:6:1","ayahNum":6,"wordNum":1,"word":"وَٱلْأَرْضِ","meaning":"and the earth","transliteration":"wal-arḍi","root":"أرض","lemmaId":149},{"id":"91:6:2","ayahNum":6,"wordNum":2,"word":"وَمَا","meaning":"and what (connects to طَحَىٰهَا)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"91:6:3","ayahNum":6,"wordNum":3,"word":"طَحَىٰهَا","meaning":"He spread it (the earth) out flat","transliteration":"ṭaḥāhā","root":"طحو","lemmaId":null},{"id":"91:7:1","ayahNum":7,"wordNum":1,"word":"وَنَفْسٍ","meaning":"and by the soul (being sworn by)","transliteration":"wanafsin","root":"نفس","lemmaId":null},{"id":"91:7:2","ayahNum":7,"wordNum":2,"word":"وَمَا","meaning":"and what (object of سَوَّىٰهَا)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"91:7:3","ayahNum":7,"wordNum":3,"word":"سَوَّىٰهَا","meaning":"he perfected/fashioned it completely","transliteration":"sawwāhā","root":"سوي","lemmaId":null},{"id":"91:8:1","ayahNum":8,"wordNum":1,"word":"فَأَلْهَمَهَا","meaning":"and then He inspired her (فُجُورَهَا وَتَقْوَىٰهَا)","transliteration":"fa-alhamahā","root":"لهم","lemmaId":null},{"id":"91:8:2","ayahNum":8,"wordNum":2,"word":"فُجُورَهَا","meaning":"her wickedness (object of أَلْهَمَ - inspired)","transliteration":"fujūrahā","root":"فجر","lemmaId":null},{"id":"91:8:3","ayahNum":8,"wordNum":3,"word":"وَتَقْوَىٰهَا","meaning":"and her protection (object of أَلْهَمَ)","transliteration":"wataqwāhā","root":"وقي","lemmaId":4252},{"id":"91:9:1","ayahNum":9,"wordNum":1,"word":"قَدْ","meaning":"certainly/indeed (emphasizes أَفْلَحَ)","transliteration":"qad","root":"","lemmaId":2994},{"id":"91:9:2","ayahNum":9,"wordNum":2,"word":"أَفْلَحَ","meaning":"he caused to succeed/prosper","transliteration":"aflaḥa","root":"فلح","lemmaId":null},{"id":"91:9:3","ayahNum":9,"wordNum":3,"word":"مَن","meaning":"whoever (subject of زَكَّىٰهَا)","transliteration":"man","root":"","lemmaId":3464},{"id":"91:9:4","ayahNum":9,"wordNum":4,"word":"زَكَّىٰهَا","meaning":"he purified it/her (object of أَفْلَحَ - succeeded)","transliteration":"zakkāhā","root":"زكو","lemmaId":null},{"id":"91:10:1","ayahNum":10,"wordNum":1,"word":"وَقَدْ","meaning":"and definitely/certainly (in the past)","transliteration":"waqad","root":"","lemmaId":2994},{"id":"91:10:2","ayahNum":10,"wordNum":2,"word":"خَابَ","meaning":"he failed/was disappointed","transliteration":"khāba","root":"خيب","lemmaId":null},{"id":"91:10:3","ayahNum":10,"wordNum":3,"word":"مَن","meaning":"whoever (subject of دَسَّىٰهَا)","transliteration":"man","root":"","lemmaId":3464},{"id":"91:10:4","ayahNum":10,"wordNum":4,"word":"دَسَّىٰهَا","meaning":"he thoroughly buried it/her","transliteration":"dassāhā","root":"دسو","lemmaId":null},{"id":"91:11:1","ayahNum":11,"wordNum":1,"word":"كَذَّبَتْ","meaning":"she denied/rejected intensively (referring to ثَمُودُ)","transliteration":"kadhabat","root":"كذب","lemmaId":null},{"id":"91:11:2","ayahNum":11,"wordNum":2,"word":"ثَمُودُ","meaning":"Thamud (subject of كَذَّبَتْ - she denied/rejected)","transliteration":"thamūdu","root":"","lemmaId":1170},{"id":"91:11:3","ayahNum":11,"wordNum":3,"word":"بِطَغْوَىٰهَآ","meaning":"by/because of its transgression","transliteration":"biṭaghwāhā","root":"طغي","lemmaId":2403},{"id":"91:12:1","ayahNum":12,"wordNum":1,"word":"إِذِ","meaning":"when (connecting to انۢبَعَثَ - arose/went forth)","transliteration":"idhi","root":"","lemmaId":461},{"id":"91:12:2","ayahNum":12,"wordNum":2,"word":"ٱنۢبَعَثَ","meaning":"rose up by itself (after إِذِ)","transliteration":"inbaʿatha","root":"بعث","lemmaId":null},{"id":"91:12:3","ayahNum":12,"wordNum":3,"word":"أَشْقَىٰهَا","meaning":"their most wretched one (doer of انبعث)","transliteration":"ashqāhā","root":"شقو","lemmaId":null},{"id":"91:13:1","ayahNum":13,"wordNum":1,"word":"فَقَالَ","meaning":"then he said (to لَهُمْ/them)","transliteration":"faqāla","root":"قول","lemmaId":null},{"id":"91:13:2","ayahNum":13,"wordNum":2,"word":"لَهُمْ","meaning":"to/for them (referring to the disbelievers mentioned earlier)","transliteration":"lahum","root":"","lemmaId":3146},{"id":"91:13:3","ayahNum":13,"wordNum":3,"word":"رَسُولُ","meaning":"messenger (subject of فَقَالَ)","transliteration":"rasūlu","root":"رسل","lemmaId":null},{"id":"91:13:4","ayahNum":13,"wordNum":4,"word":"ٱللَّهِ","meaning":"of Allah (possessed by نَاقَةَ - she-camel)","transliteration":"l-lahi","root":"أله","lemmaId":650},{"id":"91:13:5","ayahNum":13,"wordNum":5,"word":"نَاقَةَ","meaning":"female camel (in accusative case)","transliteration":"nāqata","root":"نوق","lemmaId":null},{"id":"91:13:6","ayahNum":13,"wordNum":6,"word":"ٱللَّهِ","meaning":"Allah (the one true God)","transliteration":"l-lahi","root":"أله","lemmaId":490},{"id":"91:13:7","ayahNum":13,"wordNum":7,"word":"وَسُقْيٰهَا","meaning":"and her drinking (connected to the previous phrase about the she-camel)","transliteration":"wasuq'yāhā","root":"سقي","lemmaId":null},{"id":"91:14:1","ayahNum":14,"wordNum":1,"word":"فَكَذَّبُوهُ","meaning":"and so they strongly rejected him as false","transliteration":"fakadhabūhu","root":"كذب","lemmaId":null},{"id":"91:14:2","ayahNum":14,"wordNum":2,"word":"فَعَقَرُوهَا","meaning":"so they cut/severed her (referring to the she-camel) (after فَكَذَّبُوهُ - they denied him)","transliteration":"faʿaqarūhā","root":"عقر","lemmaId":2573},{"id":"91:14:3","ayahNum":14,"wordNum":3,"word":"فَدَمْدَمَ","meaning":"so he crushed/destroyed repeatedly (after فَكَذَّبُوهُ)","transliteration":"fadamdama","root":"دمدم","lemmaId":null},{"id":"91:14:4","ayahNum":14,"wordNum":4,"word":"عَلَيْهِمْ","meaning":"upon them (who denied the messenger)","transliteration":"ʿalayhim","root":"","lemmaId":2582},{"id":"91:14:5","ayahNum":14,"wordNum":5,"word":"رَبُّهُم","meaning":"their Lord (the one who cares for and helps them grow)","transliteration":"rabbuhum","root":"ربب","lemmaId":null},{"id":"91:14:6","ayahNum":14,"wordNum":6,"word":"بِذَنۢبِهِمْ","meaning":"because of their wrong (which led to punishment from رَبُّهُم)","transliteration":"bidhanbihim","root":"ذنب","lemmaId":null},{"id":"91:14:7","ayahNum":14,"wordNum":7,"word":"فَسَوَّىٰهَا","meaning":"and so he leveled it (after they killed the camel)","transliteration":"fasawwāhā","root":"سوي","lemmaId":null},{"id":"91:15:1","ayahNum":15,"wordNum":1,"word":"وَلَا","meaning":"and not (negates يَخَافُ - fears)","transliteration":"walā","root":"","lemmaId":3147},{"id":"91:15:2","ayahNum":15,"wordNum":2,"word":"يَخَافُ","meaning":"he fears (happening now)","transliteration":"yakhāfu","root":"خوف","lemmaId":null},{"id":"91:15:3","ayahNum":15,"wordNum":3,"word":"عُقْبٰهَا","meaning":"its final outcome (referring to the punishment mentioned earlier)","transliteration":"ʿuq'bāhā","root":"عقب","lemmaId":null}]