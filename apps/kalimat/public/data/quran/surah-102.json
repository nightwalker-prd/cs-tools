[{"id":"102:1:1","ayahNum":1,"wordNum":1,"word":"أَلْهَىٰكُمُ","meaning":"distracted you all (subject of التَّكَاثُرُ)","transliteration":"alhākumu","root":"لهو","lemmaId":null},{"id":"102:1:2","ayahNum":1,"wordNum":2,"word":"ٱلتَّكَاثُرُ","meaning":"the competing with each other in increasing","transliteration":"l-takāthuru","root":"كثر","lemmaId":null},{"id":"102:2:1","ayahNum":2,"wordNum":1,"word":"حَتَّىٰ","meaning":"until, up to (shows the end point of زُرْتُمُ - your visiting)","transliteration":"ḥattā","root":"","lemmaId":null},{"id":"102:2:2","ayahNum":2,"wordNum":2,"word":"زُرْتُمُ","meaning":"you all visited","transliteration":"zur'tumu","root":"زور","lemmaId":null},{"id":"102:2:3","ayahNum":2,"wordNum":3,"word":"ٱلْمَقَابِرَ","meaning":"the burial places/graveyards (object of زُرْتُمُ/you visited)","transliteration":"l-maqābira","root":"قبر","lemmaId":null},{"id":"102:3:1","ayahNum":3,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! (used for strong denial or rejection)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"102:3:2","ayahNum":3,"wordNum":2,"word":"سَوْفَ","meaning":"will/shall (in the more distant future)","transliteration":"sawfa","root":"","lemmaId":4697},{"id":"102:3:3","ayahNum":3,"wordNum":3,"word":"تَعْلَمُونَ","meaning":"you all know (after سَوْفَ meaning 'soon')","transliteration":"taʿlamūna","root":"علم","lemmaId":null},{"id":"102:4:1","ayahNum":4,"wordNum":1,"word":"ثُمَّ","meaning":"then, next, afterwards (shows sequence of events in relation to سَوْفَ تَعْلَمُونَ - you will know)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"102:4:2","ayahNum":4,"wordNum":2,"word":"كَلَّا","meaning":"no indeed, absolutely not (strong denial of what came before ثُمَّ)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"102:4:3","ayahNum":4,"wordNum":3,"word":"سَوْفَ","meaning":"will/shall (indicates distant future, modifies تَعْلَمُونَ)","transliteration":"sawfa","root":"","lemmaId":4697},{"id":"102:4:4","ayahNum":4