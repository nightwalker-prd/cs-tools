:439},{"id":"69:5:2","ayahNum":5,"wordNum":2,"word":"ثَمُودُ","meaning":"Thamud (subject of فَأُهْلِكُوا - so they were destroyed)","transliteration":"thamūdu","root":"","lemmaId":1170},{"id":"69:5:3","ayahNum":5,"wordNum":3,"word":"فَأُهْلِكُوا۟","meaning":"so they were destroyed (as a consequence of their actions)","transliteration":"fa-uh'likū","root":"هلك","lemmaId":4145},{"id":"69:5:4","ayahNum":5,"wordNum":4,"word":"بِٱلطَّاغِيَةِ","meaning":"with the female transgressor","transliteration":"bil-ṭāghiyati","root":"طغي","lemmaId":null},{"id":"69:6:1","ayahNum":6,"wordNum":1,"word":"وَأَمَّا","meaning":"and as for (connects to previous ayah and introduces عَادٌ)","transliteration":"wa-ammā","root":"","lemmaId":4637},{"id":"69:6:2","ayahNum":6,"wordNum":2,"word":"عَادٌ","meaning":"Ad (the ancient tribe that was destroyed)","transliteration":"ʿādun","root":"عود","lemmaId":null},{"id":"69:6:3","ayahNum":6,"wordNum":3,"word":"فَأُهْلِكُوا۟","meaning":"So they were destroyed","transliteration":"fa-uh'likū","root":"هلك","lemmaId":4145},{"id":"69:6:4","ayahNum":6,"wordNum":4,"word":"بِرِيحٍ","meaning":"by a wind (used with عَادٌ فَأُهْلِكُوا - Ad were destroyed)","transliteration":"birīḥin","root":"روح","lemmaId":null},{"id":"69:6:5","ayahNum":6,"wordNum":5,"word":"صَرْصَرٍ","meaning":"an intensely cold and howling (describing رِيحٍ - wind)","transliteration":"ṣarṣarin","root":"صرصر","lemmaId":null},{"id":"69:6:6","ayahNum":6,"wordNum":6,"word":"عَاتِيَةٍ","meaning":"furiously strong (describing رِيحٍ/wind, owned by something)","transliteration":"ʿātiyatin","root":"عتو","lemmaId":null},{"id":"69:7:1","ayahNum":7,"wordNum":1,"word":"سَخَّرَهَا","meaning":"he forcefully controlled it (referring to the wind mentioned earlier)","transliteration":"sakharahā","root":"سخر","lemmaId":null},{"id":"69:7:2","ayahNum":7,"wordNum":2,"word":"عَلَيْهِمْ","meaning":"upon them","transliteration":"ʿalayhim","root":"","lemmaId":2582},{"id":"69:7:3","ayahNum":7,"wordNum":3,"word":"سَبْعَ",