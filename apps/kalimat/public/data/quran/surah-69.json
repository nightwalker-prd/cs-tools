y, hollow (feminine, indefinite)","transliteration":"khāwiyatin","root":"خوي","lemmaId":null},{"id":"69:8:1","ayahNum":8,"wordNum":1,"word":"فَهَلْ","meaning":"So/then do you? (connects to تَرَىٰ)","transliteration":"fahal","root":"","lemmaId":4144},{"id":"69:8:2","ayahNum":8,"wordNum":2,"word":"تَرَىٰ","meaning":"you see (in response to فَهَلْ - 'then do?')","transliteration":"tarā","root":"رأي","lemmaId":1735},{"id":"69:8:3","ayahNum":8,"wordNum":3,"word":"لَهُم","meaning":"for/to them (masculine plural)","transliteration":"lahum","root":"","lemmaId":3146},{"id":"69:8:4","ayahNum":8,"wordNum":4,"word":"مِّنۢ","meaning":"from/of (emphasized)","transliteration":"min","root":"","lemmaId":3464},{"id":"69:8:5","ayahNum":8,"wordNum":5,"word":"بَاقِيَةٍ","meaning":"any remaining/lasting thing (feminine, object of مِنْ)","transliteration":"bāqiyatin","root":"بقي","lemmaId":786},{"id":"69:9:1","ayahNum":9,"wordNum":1,"word":"وَجَآءَ","meaning":"and he came (subject of فِرْعَوْنُ)","transliteration":"wajāa","root":"جيأ","lemmaId":null},{"id":"69:9:2","ayahNum":9,"wordNum":2,"word":"فِرْعَوْنُ","meaning":"Pharaoh (as the subject of جَآءَ/came)","transliteration":"fir'ʿawnu","root":"","lemmaId":2879},{"id":"69:9:3","ayahNum":9,"wordNum":3,"word":"وَمَن","meaning":"and whoever (subject of came before فِرْعَوْنُ)","transliteration":"waman","root":"","lemmaId":3464},{"id":"69:9:4","ayahNum":9,"wordNum":4,"word":"قَبْلَهُۥ","meaning":"before him (referring to the people who came before Pharaoh)","transliteration":"qablahu","root":"قبل","lemmaId":null},{"id":"69:9:5","ayahNum":9,"wordNum":5,"word":"وَٱلْمُؤْتَفِكٰتُ","meaning":"and the overturned cities (subject with فِرْعَوْنُ)","transliteration":"wal-mu'tafikātu","root":"أفك","lemmaId":null},{"id":"69:9:6","ayahNum":9,"wordNum":6,"word":"بِٱلْخَاطِئَةِ","meaning":"with/by the sinful deed (object of جَآءَ)","transliteration":"bil-khāṭi-ati","root":"خطأ","lemmaId":null},{"id":"69:10:1","ayahNum":10,"wordNum":1,"word":"فَعَصَوْا۟",