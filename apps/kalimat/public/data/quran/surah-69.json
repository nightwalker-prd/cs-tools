:null},{"id":"69:32:6","ayahNum":32,"wordNum":6,"word":"ذِرَاعًا","meaning":"a cubit (unit being counted by سَبْعُونَ/seventy)","transliteration":"dhirāʿan","root":"ذرع","lemmaId":null},{"id":"69:32:7","ayahNum":32,"wordNum":7,"word":"فَٱسْلُكُوهُ","meaning":"so insert him! (command to many people)","transliteration":"fa-us'lukūhu","root":"سلك","lemmaId":null},{"id":"69:33:1","ayahNum":33,"wordNum":1,"word":"إِنَّهُۥ","meaning":"indeed he (subject of كَانَ - was)","transliteration":"innahu","root":"","lemmaId":502},{"id":"69:33:2","ayahNum":33,"wordNum":2,"word":"كَانَ","meaning":"he was/existed (describing the subject of يُؤْمِنُ)","transliteration":"kāna","root":"كون","lemmaId":null},{"id":"69:33:3","ayahNum":33,"wordNum":3,"word":"لَا","meaning":"not (negates يُؤْمِنُ/believes)","transliteration":"lā","root":"","lemmaId":3147},{"id":"69:33:4","ayahNum":33,"wordNum":4,"word":"يُؤْمِنُ","meaning":"he believes/has faith (in اللَّهِ)","transliteration":"yu'minu","root":"أمن","lemmaId":null},{"id":"69:33:5","ayahNum":33,"wordNum":5,"word":"بِٱللَّهِ","meaning":"in/by Allah (object of يُؤْمِنُ)","transliteration":"bil-lahi","root":"","lemmaId":650},{"id":"69:33:6","ayahNum":33,"wordNum":6,"word":"ٱلْعَظِيمِ","meaning":"the Great One (describing اللَّهِ - Allah)","transliteration":"l-ʿaẓīmi","root":"عظم","lemmaId":2567},{"id":"69:34:1","ayahNum":34,"wordNum":1,"word":"وَلَا","meaning":"and not (negates يَحُضُّ - urges/encourages)","transliteration":"walā","root":"","lemmaId":3147},{"id":"69:34:2","ayahNum":34,"wordNum":2,"word":"يَحُضُّ","meaning":"he urges strongly (subject of لَا)","transliteration":"yaḥuḍḍu","root":"حضض","lemmaId":null},{"id":"69:34:3","ayahNum":34,"wordNum":3,"word":"عَلَىٰ","meaning":"upon/on (connects to طَعَامِ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"69:34:4","ayahNum":34,"wordNum":4,"word":"طَعَامِ","meaning":"food (of الْمِسْكِينِ - the needy)","transliteration":"ṭaʿāmi","root":"طعم","lemmaId":2401},{"id":"69:34:5","ayahNum"