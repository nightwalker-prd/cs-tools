in","root":"رضو","lemmaId":1773},{"id":"69:22:1","ayahNum":22,"wordNum":1,"word":"فِى","meaning":"in (location in جَنَّةٍ - garden)","transliteration":"fī","root":"","lemmaId":2887},{"id":"69:22:2","ayahNum":22,"wordNum":2,"word":"جَنَّةٍ","meaning":"a garden (in عَالِيَةٍ high)","transliteration":"jannatin","root":"جنن","lemmaId":null},{"id":"69:22:3","ayahNum":22,"wordNum":3,"word":"عَالِيَةٍ","meaning":"high, elevated (feminine, describing the garden)","transliteration":"ʿāliyatin","root":"علو","lemmaId":null},{"id":"69:23:1","ayahNum":23,"wordNum":1,"word":"قُطُوفُهَا","meaning":"its fruits (referring to the garden's fruits that are close/near)","transliteration":"quṭūfuhā","root":"قطف","lemmaId":null},{"id":"69:23:2","ayahNum":23,"wordNum":2,"word":"دَانِيَةٌ","meaning":"near/close (feminine, indefinite)","transliteration":"dāniyatun","root":"دنو","lemmaId":null},{"id":"69:24:1","ayahNum":24,"wordNum":1,"word":"كُلُوا۟","meaning":"eat! (all of you) (connected to وَٱشْرَبُوا۟ - and drink)","transliteration":"kulū","root":"أكل","lemmaId":3101},{"id":"69:24:2","ayahNum":24,"wordNum":2,"word":"وَٱشْرَبُوا۟","meaning":"and drink! (command to group) (connected to كُلُوا۟ - eat!)","transliteration":"wa-ish'rabū","root":"شرب","lemmaId":null},{"id":"69:24:3","ayahNum":24,"wordNum":3,"word":"هَنِيٓـًٔۢا","meaning":"pleasantly/enjoyably (describing how to eat and drink)","transliteration":"hanīan","root":"هنأ","lemmaId":null},{"id":"69:24:4","ayahNum":24,"wordNum":4,"word":"بِمَآ","meaning":"because of what (you sent ahead in الْأَيَّامِ ٱلْخَالِيَةِ - the days gone by)","transliteration":"bimā","root":"","lemmaId":null},{"id":"69:24:5","ayahNum":24,"wordNum":5,"word":"أَسْلَفْتُمْ","meaning":"you all sent ahead","transliteration":"aslaftum","root":"سلف","lemmaId":null},{"id":"69:24:6","ayahNum":24,"wordNum":6,"word":"فِى","meaning":"in (connects كُلُوا۟ وَٱشْرَبُوا۟ with ٱلْأَيَّامِ)","transliteration":"fī","root":"","lemmaId":2761},{"id":"69:24:7","ayahNum":24,"wordNum"