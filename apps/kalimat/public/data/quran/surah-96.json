[{"id":"96:1:1","ayahNum":1,"wordNum":1,"word":"ٱقْرَأْ","meaning":"Read!/Recite! (command to one person)","transliteration":"iq'ra","root":"قرأ","lemmaId":2942},{"id":"96:1:2","ayahNum":1,"wordNum":2,"word":"بِٱسْمِ","meaning":"by/in the name (of رَبِّكَ)","transliteration":"bi-is'mi","root":"سمو","lemmaId":null},{"id":"96:1:3","ayahNum":1,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (possessed by اسم/name)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"96:1:4","ayahNum":1,"wordNum":4,"word":"ٱلَّذِى","meaning":"who/which/that (connects رَبِّكَ to خَلَقَ)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"96:1:5","ayahNum":1,"wordNum":5,"word":"خَلَقَ","meaning":"he created (connected to رَبِّكَ - your Lord)","transliteration":"khalaqa","root":"خلق","lemmaId":null},{"id":"96:2:1","ayahNum":2,"wordNum":1,"word":"خَلَقَ","meaning":"he created (subject of a sentence about الْإِنسٰنَ - mankind)","transliteration":"khalaqa","root":"خلق","lemmaId":null},{"id":"96:2:2","ayahNum":2,"wordNum":2,"word":"ٱلْإِنسٰنَ","meaning":"the human being (object of خَلَقَ)","transliteration":"l-insāna","root":"أنس","lemmaId":null},{"id":"96:2:3","ayahNum":2,"wordNum":3,"word":"مِنْ","meaning":"from (shows that عَلَقٍ is the source/origin)","transliteration":"min","root":"","lemmaId":3464},{"id":"96:2:4","ayahNum":2,"wordNum":4,"word":"عَلَقٍ","meaning":"a blood clot (object of مِنْ)","transliteration":"ʿalaqin","root":"علق","lemmaId":null},{"id":"96:3:1","ayahNum":3,"wordNum":1,"word":"ٱقْرَأْ","meaning":"Read! (command to Prophet Muhammad ﷺ)","transliteration":"iq'ra","root":"قرأ","lemmaId":null},{"id":"96:3:2","ayahNum":3,"wordNum":2,"word":"وَرَبُّكَ","meaning":"and your Lord (as subject of الْأَكْرَمُ)","transliteration":"warabbuka","root":"ربب","lemmaId":1742},{"id":"96:3:3","ayahNum":3,"wordNum":3,"word":"ٱلْأَكْرَمُ","meaning":"the Most Noble/Generous (describing رَبُّكَ - your Lord)","transliteration":"l-akramu","root":"كرم","lemmaId":null},{"id":"96:4:1","ayahNum":4,"wordNum":1,"word":"ٱلَّذِى","meaning":"The one who (points to Allah in this ayah, who is teaching)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"96:4:2","ayahNum":4,"wordNum":2,"word":"عَلَّمَ","meaning":"he taught (made someone learn)","transliteration":"ʿallama","root":"علم","lemmaId":2583},{"id":"96:4:3","ayahNum":4,"wordNum":3,"word":"بِٱلْقَلَمِ","meaning":"by/with the pen (tool used by عَلَّمَ - taught)","transliteration":"bil-qalami","root":"قلم","lemmaId":null},{"id":"96:5:1","ayahNum":5,"wordNum":1,"word":"عَلَّمَ","meaning":"he taught (caused someone to know)","transliteration":"ʿallama","root":"علم","lemmaId":null},{"id":"96:5:2","ayahNum":5,"wordNum":2,"word":"ٱلْإِنسٰنَ","meaning":"the human being (object of عَلَّمَ/taught)","transliteration":"l-insāna","root":"أنس","lemmaId":null},{"id":"96:5:3","ayahNum":5,"wordNum":3,"word":"مَا","meaning":"what (object of عَلَّمَ - taught)","transliteration":"mā","root":"","lemmaId":3215},{"id":"96:5:4","ayahNum":5,"wordNum":4,"word":"لَمْ","meaning":"not (in the past)","transliteration":"lam","root":"","lemmaId":3146},{"id":"96:5:5","ayahNum":5,"wordNum":5,"word":"يَعْلَمْ","meaning":"he knows/learns (in the phrase 'what he did not know')","transliteration":"yaʿlam","root":"علم","lemmaId":2583},{"id":"96:6:1","ayahNum":6,"wordNum":1,"word":"كَلَّآ","meaning":"No indeed! (strongly rejecting what came before)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"96:6:2","ayahNum":6,"wordNum":2,"word":"إِنَّ","meaning":"indeed/truly (emphasizing ٱلْإِنسٰنَ)","transliteration":"inna","root":"","lemmaId":502},{"id":"96:6:3","ayahNum":6,"wordNum":3,"word":"ٱلْإِنسٰنَ","meaning":"the human being (acted upon)","transliteration":"l-insāna","root":"أنس","lemmaId":null},{"id":"96:6:4","ayahNum":6,"wordNum":4,"word":"لَيَطْغَىٰٓ","meaning":"surely he crosses limits","transliteration":"layaṭghā","root":"طغي","lemmaId":null},{"id":"96:7:1","ayahNum":7,"wordNum":1,"word":"أَن","meaning":"that (connects to رَّءَاهُ ٱسْتَغْنَىٰٓ - he saw himself self-sufficient)","transliteration":"an","root":"","lemmaId":368},{"id":"96:7:2","ayahNum":7,"wordNum":2,"word":"رَّءَاهُ","meaning":"he saw him (connected to أَن before it)","transliteration":"raāhu","root":"رأي","lemmaId":null},{"id":"96:7:3","ayahNum":7,"wordNum":3,"word":"ٱسْتَغْنَىٰٓ","meaning":"he considered himself free from need (because رَّءَاهُ - he saw himself)","transliteration":"is'taghnā","root":"غني","lemmaId":null},{"id":"96:8:1","ayahNum":8,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly (emphasizes رَبِّكَ)","transliteration":"inna","root":"","lemmaId":502},{"id":"96:8:2","ayahNum":8,"wordNum":2,"word":"إِلَىٰ","meaning":"to/towards (connecting رَبِّكَ)","transliteration":"ilā","root":"","lemmaId":486},{"id":"96:8:3","ayahNum":8,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (owned, after إِلَىٰ)","transliteration":"rabbika","root":"ربب","lemmaId":1742},{"id":"96:8:4","ayahNum":8,"wordNum":4,"word":"ٱلرُّجْعَىٰٓ","meaning":"the return (definite)","transliteration":"l-ruj'ʿā","root":"رجع","lemmaId":1746},{"id":"96:9:1","ayahNum":9,"wordNum":1,"word":"أَرَءَيْتَ","meaning":"have you seen/considered? (asking about ٱلَّذِى يَنْهَىٰ - the one who forbids)","transliteration":"ara-ayta","root":"رأي","lemmaId":null},{"id":"96:9:2","ayahNum":9,"wordNum":2,"word":"ٱلَّذِى","meaning":"the one who/which (subject of يَنْهَىٰ)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"96:9:3","ayahNum":9,"wordNum":3,"word":"يَنْهَىٰ","meaning":"he stops/prevents","transliteration":"yanhā","root":"نهي","lemmaId":null},{"id":"96:10:1","ayahNum":10,"wordNum":1,"word":"عَبْدًا","meaning":"a servant (who is praying)","transliteration":"ʿabdan","root":"عبد","lemmaId":null},{"id":"96:10:2","ayahNum":10,"wordNum":2,"word":"إِذَا","meaning":"whenever (referring to صَلَّىٰٓ - prays)","transliteration":"idhā","root":"","lemmaId":461},{"id":"96:10:3","ayahNum":10,"wordNum":3,"word":"صَلَّىٰٓ","meaning":"he prayed intensely","transliteration":"ṣallā","root":"صلو","lemmaId":null},{"id":"96:11:1","ayahNum":11,"wordNum":1,"word":"أَرَأَيْتَ","meaning":"have you seen/considered?","transliteration":"ara-ayta","root":"رأي","lemmaId":null},{"id":"96:11:2","ayahNum":11,"wordNum":2,"word":"إِن","meaning":"if (introduces condition for كَانَ)","transliteration":"in","root":"","lemmaId":502},{"id":"96:11:3","ayahNum":11,"wordNum":3,"word":"كَانَ","meaning":"he was (describing what came before)","transliteration":"kāna","root":"كون","lemmaId":null},{"id":"96:11:4","ayahNum":11,"wordNum":4,"word":"عَلَى","meaning":"on/upon (connected to ٱلْهُدَىٰٓ)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"96:11:5","ayahNum":11,"wordNum":5,"word":"الهدى","meaning":"the guidance","transliteration":"l-hudā","root":"هدي","lemmaId":4134},{"id":"96:12:1","ayahNum":12,"wordNum":1,"word":"أَوْ","meaning":"or (connecting two choices in أَمَرَ - he commanded)","transliteration":"aw","root":"","lemmaId":4642},{"id":"96:12:2","ayahNum":12,"wordNum":2,"word":"أَمَرَ","meaning":"he commanded (followed by بِٱلتَّقْوَىٰٓ)","transliteration":"amara","root":"أمر","lemmaId":null},{"id":"96:12:3","ayahNum":12,"wordNum":3,"word":"بِٱلتَّقْوَىٰٓ","meaning":"with/by the righteousness","transliteration":"bil-taqwā","root":"وقي","lemmaId":null},{"id":"96:13:1","ayahNum":13,"wordNum":1,"word":"أَرَأَيْتَ","meaning":"did you see?","transliteration":"ara-ayta","root":"رأي","lemmaId":null},{"id":"96:13:2","ayahNum":13,"wordNum":2,"word":"إِن","meaning":"if (introduces condition about كَذَّبَ)","transliteration":"in","root":"","lemmaId":502},{"id":"96:13:3","ayahNum":13,"wordNum":3,"word":"كَذَّبَ","meaning":"he denied forcefully (subject of أَرَءَيْتَ)","transliteration":"kadhaba","root":"كذب","lemmaId":3069},{"id":"96:13:4","ayahNum":13,"wordNum":4,"word":"وَتَوَلَّىٰٓ","meaning":"and he turned himself away","transliteration":"watawallā","root":"ولي","lemmaId":null},{"id":"96:14:1","ayahNum":14,"wordNum":1,"word":"أَلَمْ","meaning":"did not? (expecting 'yes' as answer)","transliteration":"alam","root":"","lemmaId":311},{"id":"96:14:2","ayahNum":14,"wordNum":2,"word":"يَعْلَم","meaning":"he knows (subject of يَرَىٰ - he sees)","transliteration":"yaʿlam","root":"علم","lemmaId":null},{"id":"96:14:3","ayahNum":14,"wordNum":3,"word":"بِأَنَّ","meaning":"because (connects to يَعْلَم - he knows)","transliteration":"bi-anna","root":"","lemmaId":368},{"id":"96:14:4","ayahNum":14,"wordNum":4,"word":"ٱللَّهَ","meaning":"Allah (as the object of يَعْلَم - knows)","transliteration":"l-laha","root":"أله","lemmaId":650},{"id":"96:14:5","ayahNum":14,"wordNum":5,"word":"يَرَىٰ","meaning":"he sees","transliteration":"yarā","root":"رأي","lemmaId":null},{"id":"96:15:1","ayahNum":15,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! (strongly rejecting what comes after in لَئِن لَّمْ يَنتَهِ)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"96:15:2","ayahNum":15,"wordNum":2,"word":"لَئِن","meaning":"if indeed (introducing a strong conditional statement)","transliteration":"la-in","root":"","lemmaId":3146},{"id":"96:15:3","ayahNum":15,"wordNum":3,"word":"لَّمْ","meaning":"not (in the past, with emphasis)","transliteration":"lam","root":"","lemmaId":3177},{"id":"96:15:4","ayahNum":15,"wordNum":4,"word":"يَنتَهِ","meaning":"he stops himself (in a conditional phrase)","transliteration":"yantahi","root":"نهي","lemmaId":null},{"id":"96:15:5","ayahNum":15,"wordNum":5,"word":"لَنَسْفَعًۢا","meaning":"surely we two will grab forcefully","transliteration":"lanasfaʿan","root":"سفع","lemmaId":null},{"id":"96:15:6","ayahNum":15,"wordNum":6,"word":"بِٱلنَّاصِيَةِ","meaning":"by the forelock (genitive)","transliteration":"bil-nāṣiyati","root":"نصي","lemmaId":null},{"id":"96:16:1","ayahNum":16,"wordNum":1,"word":"نَاصِيَةٍ","meaning":"a forelock (which is lying and sinful)","transliteration":"nāṣiyatin","root":"نصي","lemmaId":null},{"id":"96:16:2","ayahNum":16,"wordNum":2,"word":"كٰذِبَةٍ","meaning":"lying, false (describing نَاصِيَةٍ - forelock)","transliteration":"kādhibatin","root":"كذب","lemmaId":null},{"id":"96:16:3","ayahNum":16,"wordNum":3,"word":"خَاطِئَةٍ","meaning":"sinful (feminine, describing نَاصِيَةٍ)","transliteration":"khāṭi-atin","root":"خطأ","lemmaId":null},{"id":"96:17:1","ayahNum":17,"wordNum":1,"word":"فَلْيَدْعُ","meaning":"so let him call/summon","transliteration":"falyadʿu","root":"دعو","lemmaId":null},{"id":"96:17:2","ayahNum":17,"wordNum":2,"word":"نَادِيَهُۥ","meaning":"his gathering place (object of فَلْيَدْعُ)","transliteration":"nādiyahu","root":"ندي","lemmaId":3936},{"id":"96:18:1","ayahNum":18,"wordNum":1,"word":"سَنَدْعُ","meaning":"we will call out (to الزَّبَانِيَةَ)","transliteration":"sanadʿu","root":"دعو","lemmaId":null},{"id":"96:18:2","ayahNum":18,"wordNum":2,"word":"ٱلزَّبَانِيَةَ","meaning":"the angels who push away forcefully (object of سَنَدْعُ)","transliteration":"l-zabāniyata","root":"زبن","lemmaId":null},{"id":"96:19:1","ayahNum":19,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! (used for strong denial or rejection)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"96:19:2","ayahNum":19,"wordNum":2,"word":"لَا","meaning":"do not! (commanding تُطِعْهُ/obey him)","transliteration":"lā","root":"","lemmaId":3147},{"id":"96:19:3","ayahNum":19,"wordNum":3,"word":"تُطِعْهُ","meaning":"you obey him (لَا negates this command: 'do not obey him')","transliteration":"tuṭiʿ'hu","root":"طوع","lemmaId":null},{"id":"96:19:4","ayahNum":19,"wordNum":4,"word":"وَٱسْجُدْ","meaning":"and prostrate! (command)","transliteration":"wa-us'jud","root":"سجد","lemmaId":null},{"id":"96:19:5","ayahNum":19,"wordNum":5,"word":"وَٱقْتَرِب","meaning":"and draw yourself near!","transliteration":"wa-iq'tarib","root":"قرب","lemmaId":2945}]