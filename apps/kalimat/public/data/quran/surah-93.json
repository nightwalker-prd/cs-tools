har","root":"نهر","lemmaId":null},{"id":"93:11:1","ayahNum":11,"wordNum":1,"word":"وَأَمَّا","meaning":"And as for... (introduces the topic that will be discussed in فَحَدِّثْ)","transliteration":"wa-ammā","root":"","lemmaId":4637},{"id":"93:11:2","ayahNum":11,"wordNum":2,"word":"بِنِعْمَةِ","meaning":"by the blessing (of رَبِّكَ - your Lord)","transliteration":"biniʿ'mati","root":"نعم","lemmaId":null},{"id":"93:11:3","ayahNum":11,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (possessed by نِعْمَة)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"93:11:4","ayahNum":11,"wordNum":4,"word":"فَحَدِّثْ","meaning":"so tell! (emphatic command)","transliteration":"faḥaddith","root":"حدث","lemmaId":null}]