,"root":"نبأ","lemmaId":3960},{"id":"66:3:25","ayahNum":3,"wordNum":25,"word":"هٰذَا","meaning":"this (referring to what was mentioned about telling the news)","transliteration":"hādhā","root":"","lemmaId":null},{"id":"66:3:26","ayahNum":3,"wordNum":26,"word":"قَالَ","meaning":"he said","transliteration":"qāla","root":"قول","lemmaId":null},{"id":"66:3:27","ayahNum":3,"wordNum":27,"word":"نَبَّأَنِىَ","meaning":"he informed me","transliteration":"nabba-aniya","root":"نبأ","lemmaId":null},{"id":"66:3:28","ayahNum":3,"wordNum":28,"word":"ٱلْعَلِيمُ","meaning":"The All-Knowing (attribute of Allah mentioned with الخَبِيرُ)","transliteration":"l-ʿalīmu","root":"علم","lemmaId":null},{"id":"66:3:29","ayahNum":3,"wordNum":29,"word":"ٱلْخَبِيرُ","meaning":"The All-Aware (one of Allah's names showing His complete knowledge of everything through direct awareness)","transliteration":"l-khabīru","root":"خبر","lemmaId":1511},{"id":"66:4:1","ayahNum":4,"wordNum":1,"word":"إِن","meaning":"if (introduces condition in تَتُوبَآ)","transliteration":"in","root":"","lemmaId":502},{"id":"66:4:2","ayahNum":4,"wordNum":2,"word":"تَتُوبَآ","meaning":"you two return (to what is right)","transliteration":"tatūbā","root":"توب","lemmaId":null},{"id":"66:4:3","ayahNum":4,"wordNum":3,"word":"إِلَى","meaning":"to/towards (connects تَتُوبَا with ٱللَّهِ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"66:4:4","ayahNum":4,"wordNum":4,"word":"ٱللَّهِ","meaning":"of Allah","transliteration":"l-lahi","root":"أله","lemmaId":650},{"id":"66:4:5","ayahNum":4,"wordNum":5,"word":"فَقَدْ","meaning":"then certainly (connects to تَتُوبَآ - if you both repent)","transliteration":"faqad","root":"","lemmaId":2994},{"id":"66:4:6","ayahNum":4,"wordNum":6,"word":"صَغَتْ","meaning":"she inclined","transliteration":"ṣaghat","root":"صغو","lemmaId":null},{"id":"66:4:7","ayahNum":4,"wordNum":7,"word":"قُلُوبُكُمَا","meaning":"hearts of you two (referring to two wives)","transliteration":"qulūbukumā","root":"قلب","