":13,"wordNum":14,"word":"رَهَقًا","meaning":"burden/oppression (object of يَخَافُ - fears)","transliteration":"rahaqan","root":"رهق","lemmaId":1799},{"id":"72:14:1","ayahNum":14,"wordNum":1,"word":"وَأَنَّا","meaning":"and indeed we/and that we (connected to مِنَّا)","transliteration":"wa-annā","root":"","lemmaId":368},{"id":"72:14:2","ayahNum":14,"wordNum":2,"word":"مِنَّا","meaning":"from us (connected to ٱلْمُسْلِمُونَ - the submitters)","transliteration":"minnā","root":"","lemmaId":3464},{"id":"72:14:3","ayahNum":14,"wordNum":3,"word":"ٱلْمُسْلِمُونَ","meaning":"The Muslims (those who submit peacefully)","transliteration":"l-mus'limūna","root":"سلم","lemmaId":null},{"id":"72:14:4","ayahNum":14,"wordNum":4,"word":"وَمِنَّا","meaning":"and from us","transliteration":"waminnā","root":"","lemmaId":3464},{"id":"72:14:5","ayahNum":14,"wordNum":5,"word":"ٱلْقٰسِطُونَ","meaning":"the deviators from justice (subject of مِنَّا)","transliteration":"l-qāsiṭūna","root":"قسط","lemmaId":null},{"id":"72:14:6","ayahNum":14,"wordNum":6,"word":"فَمَنْ","meaning":"so whoever (subject of أَسْلَمَ)","transliteration":"faman","root":"","lemmaId":3464},{"id":"72:14:7","ayahNum":14,"wordNum":7,"word":"أَسْلَمَ","meaning":"he submitted (to Allah's will)","transliteration":"aslama","root":"سلم","lemmaId":2029},{"id":"72:14:8","ayahNum":14,"wordNum":8,"word":"فَأُو۟لٰٓئِكَ","meaning":"so those (who submitted to Allah)","transliteration":"fa-ulāika","root":"","lemmaId":null},{"id":"72:14:9","ayahNum":14,"wordNum":9,"word":"تَحَرَّوْا۟","meaning":"they sought thoroughly (referring to الْقٰسِطُونَ - those who deviate)","transliteration":"taḥarraw","root":"حري","lemmaId":null},{"id":"72:14:10","ayahNum":14,"wordNum":10,"word":"رَشَدًا","meaning":"right guidance (object of تَحَرَّوْا/they sought)","transliteration":"rashadan","root":"رشد","lemmaId":null},{"id":"72:15:1","ayahNum":15,"wordNum":1,"word":"وَأَمَّا","meaning":"And as for (introduces ٱلْقٰسِطُونَ)","transliteration":"wa-ammā","root":"","lemmaId":4637},{"id":"72:15:2","ayahNum":15,"wordNum":2,"word":"ٱلْقٰسِطُونَ","meaning":"the unjust ones (subject of كَانُوا)","transliteration":"l-qāsiṭūna","root":"قسط","lemmaId":null},{"id":"72:15:3","ayahNum":15,"wordNum":3,"word":"فَكَانُوا۟","meaning":"and so they were (result of being ٱلْقٰسِطُونَ/deviators)","transliteration":"fakānū","root":"كون","lemmaId":3051},{"id":"72:15:4","ayahNum":15,"wordNum":4,"word":"لِجَهَنَّمَ","meaning":"for/as fuel for Hell (object of كَانُوا)","transliteration":"lijahannama","root":"","lemmaId":1246},{"id":"72:15:5","ayahNum":15,"wordNum":5,"word":"حَطَبًا","meaning":"firewood (object of كَانُوا)","transliteration":"ḥaṭaban","root":"حطب","lemmaId":null},{"id":"72:16:1","ayahNum":16,"wordNum":1,"word":"وَأَلَّوِ","meaning":"and even if (connected to ٱسْتَقٰمُوا۟)","transliteration":"wa-allawi","root":"","lemmaId":3187},{"id":"72:16:2","ayahNum":16,"wordNum":2,"word":"ٱسْتَقٰمُوا۟","meaning":"they became straight/upright (on الطَّرِيقَةِ - the way)","transliteration":"is'taqāmū","root":"قوم","lemmaId":null},{"id":"72:16:3","ayahNum":16,"wordNum":3,"word":"عَلَى","meaning":"upon, on (something being higher than ٱلطَّرِيقَةِ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"72:16:4","ayahNum":16,"wordNum":4,"word":"ٱلطَّرِيقَةِ","meaning":"the way/method (after عَلَى)","transliteration":"l-ṭarīqati","root":"طرق","lemmaId":null},{"id":"72:16:5","ayahNum":16,"wordNum":5,"word":"لَأَسْقَيْنٰهُم","meaning":"we would surely give them drink","transliteration":"la-asqaynāhum","root":"سقي","lemmaId":null},{"id":"72:16:6","ayahNum":16,"wordNum":6,"word":"مَّآءً","meaning":"abundant water (as direct object of لَأَسْقَيْنٰهُم - we would surely give them to drink)","transliteration":"māan","root":"موه","lemmaId":null},{"id":"72:16:7","ayahNum":16,"wordNum":7,"word":"غَدَقًا","meaning":"abundantly flowing (describing مَّآءً/water)","transliteration":"ghadaqan","root":"غدق","lemmaId":2693},{"id":"72:17:1","ayahNum":17,"wordNum"