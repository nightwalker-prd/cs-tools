[{"id":"80:1:1","ayahNum":1,"wordNum":1,"word":"عَبَسَ","meaning":"he frowned (followed by وَتَوَلَّىٰٓ - and turned away)","transliteration":"ʿabasa","root":"عبس","lemmaId":null},{"id":"80:1:2","ayahNum":1,"wordNum":2,"word":"وَتَوَلَّىٰٓ","meaning":"and he turned himself away","transliteration":"watawallā","root":"ولي","lemmaId":null},{"id":"80:2:1","ayahNum":2,"wordNum":1,"word":"أَن","meaning":"that (introduces what follows: جَآءَهُ ٱلْأَعْمَىٰ - the blind man came to him)","transliteration":"an","root":"","lemmaId":368},{"id":"80:2:2","ayahNum":2,"wordNum":2,"word":"جَآءَهُ","meaning":"he came to him (referring to the blind man in ٱلْأَعْمَىٰ)","transliteration":"jāahu","root":"جيأ","lemmaId":null},{"id":"80:2:3","ayahNum":2,"wordNum":3,"word":"ٱلْأَعْمَىٰ","meaning":"the blind one (who came to the Prophet ﷺ)","transliteration":"l-aʿmā","root":"عمي","lemmaId":null},{"id":"80:3:1","ayahNum":3,"wordNum":1,"word":"وَمَا","meaning":"and what (asking about يُدْرِيكَ - what could make you know)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"80:3:2","ayahNum":3,"wordNum":2,"word":"يُدْرِيكَ","meaning":"what would make you know (addressing Prophet Muhammad ﷺ)","transliteration":"yud'rīka","root":"دري","lemmaId":null},{"id":"80:3:3","ayahNum":3,"wordNum":3,"word":"لَعَلَّهُۥ","meaning":"perhaps he (expressing hope about يَزَّكَّىٰٓ)","transliteration":"laʿallahu","root":"","lemmaId":4735},{"id":"80:3:4","ayahNum":3,"wordNum":4,"word":"يَزَّكَّىٰٓ","meaning":"he purifies himself intensely","transliteration":"yazzakkā","root":"زكو","lemmaId":null},{"id":"80:4:1","ayahNum":4,"wordNum":1,"word":"أَوْ","meaning":"or (connecting يَذَّكَّرُ with what comes before)","transliteration":"aw","root":"","lemmaId":4642},{"id":"80:4:2","ayahNum":4,"wordNum":2,"word":"يَذَّكَّرُ","meaning":"he remembers/receives reminders (subject of فَتَنفَعَهُ)","transliteration":"yadhakkaru","root":"ذكر","lemmaId":null},{"id":"80:4:3","ayahNum":4,"wordNum":3,"word":"فَتَنفَعَهُ","meaning":"and then it gives him benefit (referring to the person in يَذَّكَّرُ)","transliteration":"fatanfaʿahu","root":"نفع","lemmaId":null},{"id":"80:4:4","ayahNum":4,"wordNum":4,"word":"ٱلذِّكْرَىٰٓ","meaning":"the reminder (that will benefit him)","transliteration":"l-dhik'rā","root":"ذكر","lemmaId":1689},{"id":"80:5:1","ayahNum":5,"wordNum":1,"word":"أَمَّا","meaning":"As for... (introduces a topic before مَنِ ٱسْتَغْنَىٰ)","transliteration":"ammā","root":"","lemmaId":439},{"id":"80:5:2","ayahNum":5,"wordNum":2,"word":"مَنِ","meaning":"who/whoever (subject of ٱسْتَغْنَىٰ)","transliteration":"mani","root":"","lemmaId":3464},{"id":"80:5:3","ayahNum":5,"wordNum":3,"word":"ٱسْتَغْنَىٰ","meaning":"he considered himself self-sufficient","transliteration":"is'taghnā","root":"غني","lemmaId":2728},{"id":"80:6:1","ayahNum":6,"wordNum":1,"word":"فَأَنتَ","meaning":"and so you/then you (addressing the Prophet ﷺ about the rich man)","transliteration":"fa-anta","root":"","lemmaId":4639},{"id":"80:6:2","ayahNum":6,"wordNum":2,"word":"لَهُۥ","meaning":"for him/to him (connected to تَصَدَّىٰ)","transliteration":"lahu","root":"","lemmaId":3146},{"id":"80:6:3","ayahNum":6,"wordNum":3,"word":"تَصَدَّىٰ","meaning":"he turns himself intensely (towards لَهُۥ)","transliteration":"taṣaddā","root":"صدي","lemmaId":null},{"id":"80:7:1","ayahNum":7,"wordNum":1,"word":"وَمَا","meaning":"and not (negates يَزَّكَّىٰ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"80:7:2","ayahNum":7,"wordNum":2,"word":"عَلَيْكَ","meaning":"upon you (addressing one male)","transliteration":"ʿalayka","root":"","lemmaId":2582},{"id":"80:7:3","ayahNum":7,"wordNum":3,"word":"أَلَّا","meaning":"that not (connects to يَزَّكَّىٰ)","transliteration":"allā","root":"","lemmaId":3147},{"id":"80:7:4","ayahNum":7,"wordNum":4,"word":"يَزَّكَّىٰ","meaning":"he purifies himself intensely","transliteration":"yazzakkā","root":"زكو","lemmaId":null},{"id":"80:8:1","ayahNum":8,"wordNum":1,"word":"وَأَمَّا","meaning":"and as for (introduces contrast with previous statement)","transliteration":"wa-ammā","root":"","lemmaId":439},{"id":"80:8:2","ayahNum":8,"wordNum":2,"word":"مَن","meaning":"whoever (subject of يَسْعَىٰ)","transliteration":"man","root":"","lemmaId":3464},{"id":"80:8:3","ayahNum":8,"wordNum":3,"word":"جَآءَكَ","meaning":"he came to you","transliteration":"jāaka","root":"جيأ","lemmaId":null},{"id":"80:8:4","ayahNum":8,"wordNum":4,"word":"يَسْعَىٰ","meaning":"he moves quickly/strives (in this ayah, describing someone coming eagerly)","transliteration":"yasʿā","root":"سعي","lemmaId":null},{"id":"80:9:1","ayahNum":9,"wordNum":1,"word":"وَهُوَ","meaning":"and he (subject of يَخْشَىٰ)","transliteration":"wahuwa","root":"","lemmaId":4772},{"id":"80:9:2","ayahNum":9,"wordNum":2,"word":"يَخْشَىٰ","meaning":"he is afraid (of what comes next in the ayah)","transliteration":"yakhshā","root":"خشي","lemmaId":null},{"id":"80:10:1","ayahNum":10,"wordNum":1,"word":"فَأَنتَ","meaning":"and so you (subject of تَلَهَّىٰ)","transliteration":"fa-anta","root":"","lemmaId":4639},{"id":"80:10:2","ayahNum":10,"wordNum":2,"word":"عَنْهُ","meaning":"away from him/about him (referring to the one who came seeking guidance)","transliteration":"ʿanhu","root":"","lemmaId":4713},{"id":"80:10:3","ayahNum":10,"wordNum":3,"word":"تَلَهَّىٰ","meaning":"he deliberately busied himself (with عَنْهُ - away from it)","transliteration":"talahhā","root":"لهو","lemmaId":null},{"id":"80:11:1","ayahNum":11,"wordNum":1,"word":"كَلَّآ","meaning":"No indeed! (strongly rejecting what came before)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"80:11:2","ayahNum":11,"wordNum":2,"word":"إِنَّهَا","meaning":"indeed it (referring to تَذْكِرَةٌ)","transliteration":"innahā","root":"","lemmaId":502},{"id":"80:11:3","ayahNum":11,"wordNum":3,"word":"تَذْكِرَةٌ","meaning":"a reminder (general/any reminder)","transliteration":"tadhkiratun","root":"ذكر","lemmaId":null},{"id":"80:12:1","ayahNum":12,"wordNum":1,"word":"فَمَن","meaning":"so whoever (connected to شَآءَ 'wills/wants')","transliteration":"faman","root":"","lemmaId":3464},{"id":"80:12:2","ayahNum":12,"wordNum":2,"word":"شَآءَ","meaning":"he wanted","transliteration":"shāa","root":"شيأ","lemmaId":null},{"id":"80:12:3","ayahNum":12,"wordNum":3,"word":"ذَكَرَهُۥ","meaning":"he remembered/mentioned him (acted on by شَآءَ)","transliteration":"dhakarahu","root":"ذكر","lemmaId":1689},{"id":"80:13:1","ayahNum":13,"wordNum":1,"word":"فِى","meaning":"in (the noble pages/scrolls)","transliteration":"fī","root":"","lemmaId":2887},{"id":"80:13:2","ayahNum":13,"wordNum":2,"word":"صُحُفٍ","meaning":"of written pages/scrolls (possessed by مُّكَرَّمَةٍ - honored/noble)","transliteration":"ṣuḥufin","root":"صحف","lemmaId":null},{"id":"80:13:3","ayahNum":13,"wordNum":3,"word":"مُّكَرَّمَةٍ","meaning":"greatly honored (feminine, describing صُحُفٍ)","transliteration":"mukarramatin","root":"كرم","lemmaId":null},{"id":"80:14:1","ayahNum":14,"wordNum":1,"word":"مَّرْفُوعَةٍ","meaning":"lifted/raised (describing a feminine thing that belongs to something)","transliteration":"marfūʿatin","root":"رفع","lemmaId":null},{"id":"80:14:2","ayahNum":14,"wordNum":2,"word":"مُّطَهَّرَةٍۭ","meaning":"thoroughly purified (feminine, possessed)","transliteration":"muṭahharatin","root":"طهر","lemmaId":null},{"id":"80:15:1","ayahNum":15,"wordNum":1,"word":"بِأَيْدِى","meaning":"by/with hands (of سَفَرَةٍ)","transliteration":"bi-aydī","root":"يدي","lemmaId":null},{"id":"80:15:2","ayahNum":15,"wordNum":2,"word":"سَفَرَةٍ","meaning":"of noble scribes (in بِأَيْدِى سَفَرَةٍ - by the hands of noble scribes)","transliteration":"safaratin","root":"سفر","lemmaId":null},{"id":"80:16:1","ayahNum":16,"wordNum":1,"word":"كِرَامٍۭ","meaning":"noble ones (describing بَرَرَةٍ - righteous ones)","transliteration":"kirāmin","root":"كرم","lemmaId":null},{"id":"80:16:2","ayahNum":16,"wordNum":2,"word":"بَرَرَةٍ","meaning":"righteous ones (matching the grammar of كِرَامٍۭ - noble ones)","transliteration":"bararatin","root":"برر","lemmaId":null},{"id":"80:17:1","ayahNum":17,"wordNum":1,"word":"قُتِلَ","meaning":"may he be destroyed! (referring to الْإِنسٰنُ - mankind)","transliteration":"qutila","root":"قتل","lemmaId":2927},{"id":"80:17:2","ayahNum":17,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of قُتِلَ - was destroyed/cursed)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"80:17:3","ayahNum":17,"wordNum":3,"word":"مَآ","meaning":"how (used to express amazement at أَكْفَرَهُۥ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"80:17:4","ayahNum":17,"wordNum":4,"word":"أَكْفَرَهُۥ","meaning":"made him reject/disbelieve","transliteration":"akfarahu","root":"كفر","lemmaId":null},{"id":"80:18:1","ayahNum":18,"wordNum":1,"word":"مِنْ","meaning":"from (connects to خَلَقَهُۥ - He created him)","transliteration":"min","root":"","lemmaId":3464},{"id":"80:18:2","ayahNum":18,"wordNum":2,"word":"أَىِّ","meaning":"from what kind (of شَىْءٍ did He create it)","transliteration":"ayyi","root":"أيي","lemmaId":null},{"id":"80:18:3","ayahNum":18,"wordNum":3,"word":"شَىْءٍ","meaning":"any thing (possessed by أَيِّ)","transliteration":"shayin","root":"شيأ","lemmaId":null},{"id":"80:18:4","ayahNum":18,"wordNum":4,"word":"خَلَقَهُۥ","meaning":"he created him (referring to man in أَىِّ شَىْءٍ)","transliteration":"khalaqahu","root":"خلق","lemmaId":1555},{"id":"80:19:1","ayahNum":19,"wordNum":1,"word":"مِن","meaning":"from (connects to نُّطْفَةٍ)","transliteration":"min","root":"","lemmaId":3464},{"id":"80:19:2","ayahNum":19,"wordNum":2,"word":"نُّطْفَةٍ","meaning":"from a tiny drop (of special fluid that creates babies)","transliteration":"nuṭ'fatin","root":"نطف","lemmaId":null},{"id":"80:19:3","ayahNum":19,"wordNum":3,"word":"خَلَقَهُۥ","meaning":"he created him (object of فَقَدَّرَهُۥ)","transliteration":"khalaqahu","root":"خلق","lemmaId":1555},{"id":"80:19:4","ayahNum":19,"wordNum":4,"word":"فَقَدَّرَهُۥ","meaning":"and then He measured/determined it","transliteration":"faqaddarahu","root":"قدر","lemmaId":null},{"id":"80:20:1","ayahNum":20,"wordNum":1,"word":"ثُمَّ","meaning":"then, next, afterwards (connects to السَّبِيلَ يَسَّرَهُۥ)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"80:20:2","ayahNum":20,"wordNum":2,"word":"ٱلسَّبِيلَ","meaning":"the path/way (object of يَسَّرَهُۥ)","transliteration":"l-sabīla","root":"سبل","lemmaId":null},{"id":"80:20:3","ayahNum":20,"wordNum":3,"word":"يَسَّرَهُۥ","meaning":"he made it easy (referring to السَّبِيلَ/the path)","transliteration":"yassarahu","root":"يسر","lemmaId":null},{"id":"80:21:1","ayahNum":21,"wordNum":1,"word":"ثُمَّ","meaning":"then (connects to أَمَاتَهُۥ - He caused him to die)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"80:21:2","ayahNum":21,"wordNum":2,"word":"أَمَاتَهُۥ","meaning":"he caused him to die (followed by فَأَقْبَرَهُۥ - then he buried him)","transliteration":"amātahu","root":"موت","lemmaId":null},{"id":"80:21:3","ayahNum":21,"wordNum":3,"word":"فَأَقْبَرَهُۥ","meaning":"and then He caused him to be buried","transliteration":"fa-aqbarahu","root":"قبر","lemmaId":2921},{"id":"80:22:1","ayahNum":22,"wordNum":1,"word":"ثُمَّ","meaning":"then, next, afterwards (connects to إِذَا شَآءَ - when He wills)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"80:22:2","ayahNum":22,"wordNum":2,"word":"إِذَا","meaning":"when (introduces a condition before شَآءَ)","transliteration":"idhā","root":"","lemmaId":461},{"id":"80:22:3","ayahNum":22,"wordNum":3,"word":"شَآءَ","meaning":"he willed/wanted","transliteration":"shāa","root":"شيأ","lemmaId":null},{"id":"80:22:4","ayahNum":22,"wordNum":4,"word":"أَنشَرَهُۥ","meaning":"he made him/it come back to life (after شَآءَ - he willed)","transliteration":"ansharahu","root":"نشر","lemmaId":4012},{"id":"80:23:1","ayahNum":23,"wordNum":1,"word":"كَلَّا","meaning":"No! By no means! (used for strong denial or rejection)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"80:23:2","ayahNum":23,"wordNum":2,"word":"لَمَّا","meaning":"not yet (indicates something hasn't happened up to now)","transliteration":"lammā","root":"","lemmaId":3146},{"id":"80:23:3","ayahNum":23,"wordNum":3,"word":"يَقْضِ","meaning":"he decides/completes (after لَمَّا which requires dropping the final ي)","transliteration":"yaqḍi","root":"قضي","lemmaId":null},{"id":"80:23:4","ayahNum":23,"wordNum":4,"word":"مَآ","meaning":"not (negating أَمَرَهُۥ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"80:23:5","ayahNum":23,"wordNum":5,"word":"أَمَرَهُۥ","meaning":"he commanded him (object of يَقْضِ - he fulfills)","transliteration":"amarahu","root":"أمر","lemmaId":330},{"id":"80:24:1","ayahNum":24,"wordNum":1,"word":"فَلْيَنظُرِ","meaning":"then let him look","transliteration":"falyanẓuri","root":"نظر","lemmaId":null},{"id":"80:24:2","ayahNum":24,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of فَلْيَنظُرِ - let him look)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"80:24:3","ayahNum":24,"wordNum":3,"word":"إِلَىٰ","meaning":"to/towards (connecting طَعَامِ with يَنظُرِ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"80:24:4","ayahNum":24,"wordNum":4,"word":"طَعَامِهِۦٓ","meaning":"his food (after إِلَىٰ)","transliteration":"ṭaʿāmihi","root":"طعم","lemmaId":null},{"id":"80:25:1","ayahNum":25,"wordNum":1,"word":"أَنَّا","meaning":"that we/us (subject of صَبَبْنَا - we poured)","transliteration":"annā","root":"","lemmaId":368},{"id":"80:25:2","ayahNum":25,"wordNum":2,"word":"صَبَبْنَا","meaning":"we poured","transliteration":"ṣababnā","root":"صبب","lemmaId":null},{"id":"80:25:3","ayahNum":25,"wordNum":3,"word":"ٱلْمَآءَ","meaning":"the water (object of صَبَبْنَا - we poured)","transliteration":"l-māa","root":"موه","lemmaId":null},{"id":"80:25:4","ayahNum":25,"wordNum":4,"word":"صَبًّا","meaning":"an intense pouring (object of صَبَبْنَا)","transliteration":"ṣabban","root":"صبب","lemmaId":null},{"id":"80:26:1","ayahNum":26,"wordNum":1,"word":"ثُمَّ","meaning":"then (with emphasis, connecting to شَقَقْنَا - we split)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"80:26:2","ayahNum":26,"wordNum":2,"word":"شَقَقْنَا","meaning":"we split","transliteration":"shaqaqnā","root":"شقق","lemmaId":2167},{"id":"80:26:3","ayahNum":26,"wordNum":3,"word":"ٱلْأَرْضَ","meaning":"the earth (object of شَقَقْنَا/we split)","transliteration":"l-arḍa","root":"أرض","lemmaId":149},{"id":"80:26:4","ayahNum":26,"wordNum":4,"word":"شَقًّا","meaning":"a split/crack (object of شَقَقْنَا - we split)","transliteration":"shaqqan","root":"شقق","lemmaId":null},{"id":"80:27:1","ayahNum":27,"wordNum":1,"word":"فَأَنۢبَتْنَا","meaning":"and then We made (something) grow (referring to what follows in فِيهَا حَبًّا - in it grain)","transliteration":"fa-anbatnā","root":"نبت","lemmaId":null},{"id":"80:27:2","ayahNum":27,"wordNum":2,"word":"فِيهَا","meaning":"in it (referring to the earth mentioned earlier)","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"80:27:3","ayahNum":27,"wordNum":3,"word":"حَبًّا","meaning":"a grain/seed (object of أَنۢبَتْنَا - we caused to grow)","transliteration":"ḥabban","root":"حبب","lemmaId":null},{"id":"80:28:1","ayahNum":28,"wordNum":1,"word":"وَعِنَبًا","meaning":"and grapes (acted on)","transliteration":"waʿinaban","root":"عنب","lemmaId":null},{"id":"80:28:2","ayahNum":28,"wordNum":2,"word":"وَقَضْبًا","meaning":"and vegetables (acted on)","transliteration":"waqaḍban","root":"قضب","lemmaId":null},{"id":"80:29:1","ayahNum":29,"wordNum":1,"word":"وَزَيْتُونًا","meaning":"and an olive (as object of implied verb, connected to وَنَخْلًا)","transliteration":"wazaytūnan","root":"زيت","lemmaId":null},{"id":"80:29:2","ayahNum":29,"wordNum":2,"word":"وَنَخْلًا","meaning":"and a palm tree (object of verb)","transliteration":"wanakhlan","root":"نخل","lemmaId":3983},{"id":"80:30:1","ayahNum":30,"wordNum":1,"word":"وَحَدَآئِقَ","meaning":"and gardens (connected to what came before)","transliteration":"waḥadāiqa","root":"حدق","lemmaId":null},{"id":"80:30:2","ayahNum":30,"wordNum":2,"word":"غُلْبًا","meaning":"thick/dense ones (describing the gardens)","transliteration":"ghul'ban","root":"غلب","lemmaId":null},{"id":"80:31:1","ayahNum":31,"wordNum":1,"word":"وَفٰكِهَةً","meaning":"and fruit (as a direct object)","transliteration":"wafākihatan","root":"فكه","lemmaId":null},{"id":"80:31:2","ayahNum":31,"wordNum":2,"word":"وَأَبًّا","meaning":"and pasture/fodder (as object)","transliteration":"wa-abban","root":"أبب","lemmaId":null},{"id":"80:32:1","ayahNum":32,"wordNum":1,"word":"مَّتٰعًا","meaning":"as a provision/benefit (emphasized)","transliteration":"matāʿan","root":"متع","lemmaId":null},{"id":"80:32:2","ayahNum":32,"wordNum":2,"word":"لَّكُمْ","meaning":"surely for you all (connected to مَّتٰعًا - enjoyment)","transliteration":"lakum","root":"","lemmaId":3146},{"id":"80:32:3","ayahNum":32,"wordNum":3,"word":"وَلِأَنْعٰمِكُمْ","meaning":"and for your livestock","transliteration":"wali-anʿāmikum","root":"نعم","lemmaId":null},{"id":"80:33:1","ayahNum":33,"wordNum":1,"word":"فَإِذَا","meaning":"and/then when (followed by جَآءَتِ - it comes)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"80:33:2","ayahNum":33,"wordNum":2,"word":"جَآءَتِ","meaning":"she arrived/came suddenly (subject of الصَّآخَّةُ)","transliteration":"jāati","root":"جيأ","lemmaId":null},{"id":"80:33:3","ayahNum":33,"wordNum":3,"word":"ٱلصَّآخَّةُ","meaning":"The Deafening Blast (a name for the Day of Judgment)","transliteration":"l-ṣākhatu","root":"صخخ","lemmaId":null},{"id":"80:34:1","ayahNum":34,"wordNum":1,"word":"يَوْمَ","meaning":"a day (in accusative case)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"80:34:2","ayahNum":34,"wordNum":2,"word":"يَفِرُّ","meaning":"he flees/is fleeing (from أَخِيهِ - his brother)","transliteration":"yafirru","root":"فرر","lemmaId":null},{"id":"80:34:3","ayahNum":34,"wordNum":3,"word":"ٱلْمَرْءُ","meaning":"the person (doer)","transliteration":"l-maru","root":"مرأ","lemmaId":null},{"id":"80:34:4","ayahNum":34,"wordNum":4,"word":"مِنْ","meaning":"from (shows separation from أَخِيهِ/his brother)","transliteration":"min","root":"","lemmaId":3464},{"id":"80:34:5","ayahNum":34,"wordNum":5,"word":"أَخِيهِ","meaning":"his brother (possessed by the person being fled from)","transliteration":"akhīhi","root":"أخو","lemmaId":null},{"id":"80:35:1","ayahNum":35,"wordNum":1,"word":"وَأُمِّهِۦ","meaning":"and his mother (owned)","transliteration":"wa-ummihi","root":"أمم","lemmaId":null},{"id":"80:35:2","ayahNum":35,"wordNum":2,"word":"وَأَبِيهِ","meaning":"and his father","transliteration":"wa-abīhi","root":"أبو","lemmaId":null},{"id":"80:36:1","ayahNum":36,"wordNum":1,"word":"وَصٰحِبَتِهِۦ","meaning":"and his female companion (owned)","transliteration":"waṣāḥibatihi","root":"صحب","lemmaId":null},{"id":"80:36:2","ayahNum":36,"wordNum":2,"word":"وَبَنِيهِ","meaning":"and his sons","transliteration":"wabanīhi","root":"بني","lemmaId":null},{"id":"80:37:1","ayahNum":37,"wordNum":1,"word":"لِكُلِّ","meaning":"for every/each (subject of يُغْنِيهِ)","transliteration":"likulli","root":"كلل","lemmaId":null},{"id":"80:37:2","ayahNum":37,"wordNum":2,"word":"ٱمْرِئٍ","meaning":"any person (subject of يُغْنِيهِ)","transliteration":"im'ri-in","root":"مرأ","lemmaId":null},{"id":"80:37:3","ayahNum":37,"wordNum":3,"word":"مِّنْهُمْ","meaning":"from them (referring to each person mentioned in لِكُلِّ ٱمْرِئٍ)","transliteration":"min'hum","root":"","lemmaId":3464},{"id":"80:37:4","ayahNum":37,"wordNum":4,"word":"يَوْمَئِذٍ","meaning":"that day (when each person will be preoccupied with their own state)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"80:37:5","ayahNum":37,"wordNum":5,"word":"شَأْنٌ","meaning":"a matter, affair (subject of يُغْنِيهِ)","transliteration":"shanun","root":"شأن","lemmaId":null},{"id":"80:37:6","ayahNum":37,"wordNum":6,"word":"يُغْنِيهِ","meaning":"preoccupies him (describes شَأْنٌ/matter)","transliteration":"yugh'nīhi","root":"غني","lemmaId":2728},{"id":"80:38:1","ayahNum":38,"wordNum":1,"word":"وُجُوهٌ","meaning":"faces (as the subject of مُّسْفِرَةٌ - bright/beaming)","transliteration":"wujūhun","root":"وجه","lemmaId":null},{"id":"80:38:2","ayahNum":38,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (faces on that day are bright)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"80:38:3","ayahNum":38,"wordNum":3,"word":"مُّسْفِرَةٌ","meaning":"brightly shining (feminine, indefinite)","transliteration":"mus'firatun","root":"سفر","lemmaId":2006},{"id":"80:39:1","ayahNum":39,"wordNum":1,"word":"ضَاحِكَةٌ","meaning":"a female who laughs happily (describes مُّسْتَبْشِرَةٌ)","transliteration":"ḍāḥikatun","root":"ضحك","lemmaId":null},{"id":"80:39:2","ayahNum":39,"wordNum":2,"word":"مُّسْتَبْشِرَةٌ","meaning":"a female who is joyfully receiving good news (paired with ضَاحِكَةٌ - laughing)","transliteration":"mus'tabshiratun","root":"بشر","lemmaId":null},{"id":"80:40:1","ayahNum":40,"wordNum":1,"word":"وَوُجُوهٌ","meaning":"and faces (that will have dust on them)","transliteration":"wawujūhun","root":"وجه","lemmaId":null},{"id":"80:40:2","ayahNum":40,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (when faces will be covered with dust)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"80:40:3","ayahNum":40,"wordNum":3,"word":"عَلَيْهَا","meaning":"upon her/it (referring to faces/وُجُوهٌ)","transliteration":"ʿalayhā","root":"","lemmaId":2582},{"id":"80:40:4","ayahNum":40,"wordNum":4,"word":"غَبَرَةٌ","meaning":"dust (indefinite)","transliteration":"ghabaratun","root":"غبر","lemmaId":null},{"id":"80:41:1","ayahNum":41,"wordNum":1,"word":"تَرْهَقُهَا","meaning":"she covers/overwhelms them (referring to the faces mentioned earlier)","transliteration":"tarhaquhā","root":"رهق","lemmaId":null},{"id":"80:41:2","ayahNum":41,"wordNum":2,"word":"قَتَر