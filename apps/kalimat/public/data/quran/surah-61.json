ural) (subject of ءَامَنُوا۟)","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"61:2:3","ayahNum":2,"wordNum":3,"word":"ءَامَنُوا۟","meaning":"they believed (referring to ٱلَّذِينَ - those who)","transliteration":"āmanū","root":"أمن","lemmaId":null},{"id":"61:2:4","ayahNum":2,"wordNum":4,"word":"لِمَ","meaning":"why (asking about تَقُولُونَ - you say)","transliteration":"lima","root":"","lemmaId":4736},{"id":"61:2:5","ayahNum":2,"wordNum":5,"word":"تَقُولُونَ","meaning":"you all say/speak","transliteration":"taqūlūna","root":"قول","lemmaId":2910},{"id":"61:2:6","ayahNum":2,"wordNum":6,"word":"مَا","meaning":"what (questioning تَقُولُونَ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"61:2:7","ayahNum":2,"wordNum":7,"word":"لَا","meaning":"not (negates تَفْعَلُونَ)","transliteration":"lā","root":"","lemmaId":3147},{"id":"61:2:8","ayahNum":2,"wordNum":8,"word":"تَفْعَلُونَ","meaning":"you (all) do (addressing multiple people)","transliteration":"tafʿalūna","root":"فعل","lemmaId":2836},{"id":"61:3:1","ayahNum":3,"wordNum":1,"word":"كَبُرَ","meaning":"to become great/big","transliteration":"kabura","root":"كبر","lemmaId":null},{"id":"61:3:2","ayahNum":3,"wordNum":2,"word":"مَقْتًا","meaning":"hatred (as something greatly disliked by Allah)","transliteration":"maqtan","root":"مقت","lemmaId":null},{"id":"61:3:3","ayahNum":3,"wordNum":3,"word":"عِندَ","meaning":"with/at/near (connects اللَّهِ)","transliteration":"ʿinda","root":"عند","lemmaId":null},{"id":"61:3:4","ayahNum":3,"wordNum":4,"word":"ٱللَّهِ","meaning":"of Allah (object of عِندَ)","transliteration":"l-lahi","root":"أله","lemmaId":650},{"id":"61:3:5","ayahNum":3,"wordNum":5,"word":"أَن","meaning":"that (introduces what is said in تَقُولُوا)","transliteration":"an","root":"","lemmaId":368},{"id":"61:3:6","ayahNum":3,"wordNum":6,"word":"تَقُولُوا۟","meaning":"you (all) say","transliteration":"taqūlū","root":"قول","lemmaId":null},{"id":"61:3:7","ayahNum":3,"wordNum":7,"word":"مَا","meaning":"