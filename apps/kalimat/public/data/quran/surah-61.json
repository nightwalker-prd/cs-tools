nd (رَسُولَهُۥ)","transliteration":"arsala","root":"رسل","lemmaId":null},{"id":"61:9:4","ayahNum":9,"wordNum":4,"word":"رَسُولَهُۥ","meaning":"His messenger (being sent by أَرْسَلَ)","transliteration":"rasūlahu","root":"رسل","lemmaId":null},{"id":"61:9:5","ayahNum":9,"wordNum":5,"word":"بِٱلْهُدَىٰ","meaning":"with the guidance","transliteration":"bil-hudā","root":"هدي","lemmaId":null},{"id":"61:9:6","ayahNum":9,"wordNum":6,"word":"وَدِينِ","meaning":"and religion (connected to الْحَقِّ)","transliteration":"wadīni","root":"دين","lemmaId":null},{"id":"61:9:7","ayahNum":9,"wordNum":7,"word":"الْحَقِّ","meaning":"the truth (possessed by دِينِ - religion)","transliteration":"l-ḥaqi","root":"حقق","lemmaId":null},{"id":"61:9:8","ayahNum":9,"wordNum":8,"word":"لِيُظْهِرَهُۥ","meaning":"so that He makes it prevail (over دِينِ)","transliteration":"liyuẓ'hirahu","root":"ظهر","lemmaId":null},{"id":"61:9:9","ayahNum":9,"wordNum":9,"word":"عَلَى","meaning":"upon/over (the دِينِ)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"61:9:10","ayahNum":9,"wordNum":10,"word":"ٱلدِّينِ","meaning":"the religion","transliteration":"l-dīni","root":"دين","lemmaId":1657},{"id":"61:9:11","ayahNum":9,"wordNum":11,"word":"كُلِّهِۦ","meaning":"all of it (possessed by الدِّينِ)","transliteration":"kullihi","root":"كلل","lemmaId":null},{"id":"61:9:12","ayahNum":9,"wordNum":12,"word":"وَلَوْ","meaning":"and even if/though","transliteration":"walaw","root":"","lemmaId":3187},{"id":"61:9:13","ayahNum":9,"wordNum":13,"word":"كَرِهَ","meaning":"he disliked/hated","transliteration":"kariha","root":"كره","lemmaId":null},{"id":"61:9:14","ayahNum":9,"wordNum":14,"word":"ٱلْمُشْرِكُونَ","meaning":"the polytheists (those who worship others alongside Allah)","transliteration":"l-mush'rikūna","root":"شرك","lemmaId":null},{"id":"61:10:1","ayahNum":10,"wordNum":1,"word":"يٰٓأَيُّهَا","meaning":"O you (addressing a group)","transliteration":"yāayyuhā","root":"أيي","lemmaId":null},{"id":"61:10:2","ayahNum":10,"wordNum":2,"word":"الذين","meaning":"those who","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"61:10:3","ayahNum":10,"wordNum":3,"word":"ءَامَنُوا۟","meaning":"they believed (subject of يٰٓأَيُّهَا ٱلَّذِينَ)","transliteration":"āmanū","root":"أمن","lemmaId":null},{"id":"61:10:4","ayahNum":10,"wordNum":4,"word":"هَلْ","meaning":"do? does? (introduces a yes/no question)","transliteration":"hal","root":"","lemmaId":4144},{"id":"61:10:5","ayahNum":10,"wordNum":5,"word":"أَدُلُّكُمْ","meaning":"I guide you all (addressing the believers)","transliteration":"adullukum","root":"دلل","lemmaId":null},{"id":"61:10:6","ayahNum":10,"wordNum":6,"word":"عَلَىٰ","meaning":"on/upon (connects تِجٰرَةٍ to أَدُلُّكُمْ)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"61:10:7","ayahNum":10,"wordNum":7,"word":"تِجٰرَةٍ","meaning":"a trade/business (that will save you from عَذَابٍ أَلِيمٍ)","transliteration":"tijāratin","root":"تجر","lemmaId":null},{"id":"61:10:8","ayahNum":10,"wordNum":8,"word":"تُنجِيكُم","meaning":"it saves/rescues you all (from عَذَابٍ - punishment)","transliteration":"tunjīkum","root":"نجو","lemmaId":null},{"id":"61:10:9","ayahNum":10,"wordNum":9,"word":"مِّنْ","meaning":"from (connects to عَذَابٍ)","transliteration":"min","root":"","lemmaId":3464},{"id":"61:10:10","ayahNum":10,"wordNum":10,"word":"عَذَابٍ","meaning":"a punishment (after مِنْ/from)","transliteration":"ʿadhābin","root":"عذب","lemmaId":null},{"id":"61:10:11","ayahNum":10,"wordNum":11,"word":"أَلِيمٍ","meaning":"intensely painful (describing عَذَابٍ/punishment)","transliteration":"alīmin","root":"ألم","lemmaId":null},{"id":"61:11:1","ayahNum":11,"wordNum":1,"word":"تُؤْمِنُونَ","meaning":"you (all) believe (in اللَّهِ وَرَسُولِهِۦ)","transliteration":"tu'minūna","root":"أمن","lemmaId":null},{"id":"61:11:2","ayahNum":11,"wordNum":2,"word":"بِٱللَّهِ","meaning":"in/by/with Allah (object of تُؤْمِنُونَ - you believe)","transliteration":"bil-lahi","root":"","lemmaId":null},{