9,"wordNum":1,"word":"كِتٰبٌ","meaning":"a book (subject of مَّرْقُومٌ)","transliteration":"kitābun","root":"كتب","lemmaId":null},{"id":"83:9:2","ayahNum":9,"wordNum":2,"word":"مَّرْقُومٌ","meaning":"a definitely marked/numbered (record) (describes كِتٰبٌ)","transliteration":"marqūmun","root":"رقم","lemmaId":null},{"id":"83:10:1","ayahNum":10,"wordNum":1,"word":"وَيْلٌ","meaning":"woe/destruction! (threatening those who deny in يَوْمَئِذٍ لِّلْمُكَذِّبِينَ)","transliteration":"waylun","root":"","lemmaId":4272},{"id":"83:10:2","ayahNum":10,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (followed by لِّلْمُكَذِّبِينَ - for the deniers)","transliteration":"yawma-idhin","root":"يوم","lemmaId":4512},{"id":"83:10:3","ayahNum":10,"wordNum":3,"word":"لِّلْمُكَذِّبِينَ","meaning":"for/to the ones who repeatedly deny","transliteration":"lil'mukadhibīna","root":"كذب","lemmaId":null},{"id":"83:11:1","ayahNum":11,"wordNum":1,"word":"ٱلَّذِينَ","meaning":"those who","transliteration":"alladhīna","root":"","lemmaId":null},{"id":"83:11:2","ayahNum":11,"wordNum":2,"word":"يُكَذِّبُونَ","meaning":"they strongly deny/reject (referring to those who deny the Day of Judgment)","transliteration":"yukadhibūna","root":"كذب","lemmaId":3069},{"id":"83:11:3","ayahNum":11,"wordNum":3,"word":"بِيَوْمِ","meaning":"by/in the day (possessed by الدِّينِ)","transliteration":"biyawmi","root":"يوم","lemmaId":4512},{"id":"83:11:4","ayahNum":11,"wordNum":4,"word":"ٱلدِّينِ","meaning":"the judgment/religion (object of بِيَوْمِ - Day of)","transliteration":"l-dīni","root":"دين","lemmaId":1657},{"id":"83:12:1","ayahNum":12,"wordNum":1,"word":"وَمَا","meaning":"and what/that which (subject of يُكَذِّبُ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"83:12:2","ayahNum":12,"wordNum":2,"word":"يُكَذِّبُ","meaning":"he denies/rejects (something) (subject of مَا)","transliteration":"yukadhibu","root":"كذب","lemmaId":null},{"id":"83:12:3","ayahNum":12,"wordNum":3,"word":"بِهِۦٓ","meaning":"with it/by it (acted on by يُكَذِّبُ)","transliteration":"bihi","root":"","lemmaId":692},{"id":"83:12:4","ayahNum":12,"wordNum":4,"word":"إِلَّا","meaning":"except (connecting to كُلُّ مُعْتَدٍ أَثِيمٍ)","transliteration":"illā","root":"","lemmaId":486},{"id":"83:12:5","ayahNum":12,"wordNum":5,"word":"كُلُّ","meaning":"every (transgressor/أَثِيمٍ)","transliteration":"kullu","root":"كلل","lemmaId":null},{"id":"83:12:6","ayahNum":12,"wordNum":6,"word":"مُعْتَدٍ","meaning":"transgressor (describes someone in كُلُّ/every)","transliteration":"muʿ'tadin","root":"عدو","lemmaId":null},{"id":"83:12:7","ayahNum":12,"wordNum":7,"word":"أَثِيمٍ","meaning":"a sinful one (describing مُعْتَدٍ - transgressor)","transliteration":"athīmin","root":"أثم","lemmaId":null},{"id":"83:13:1","ayahNum":13,"wordNum":1,"word":"إِذَا","meaning":"when (referring to something that will happen in the future, followed by تُتْلَىٰ/are recited)","transliteration":"idhā","root":"","lemmaId":4646},{"id":"83:13:2","ayahNum":13,"wordNum":2,"word":"تُتْلَىٰ","meaning":"it is being recited (to عَلَيْهِ - to him)","transliteration":"tut'lā","root":"تلو","lemmaId":null},{"id":"83:13:3","ayahNum":13,"wordNum":3,"word":"عَلَيْهِ","meaning":"upon him (object of تُتْلَىٰ/are recited)","transliteration":"ʿalayhi","root":"","lemmaId":2582},{"id":"83:13:4","ayahNum":13,"wordNum":4,"word":"ءَايٰتُنَا","meaning":"our signs, our verses (that are being recited)","transliteration":"āyātunā","root":"أيي","lemmaId":null},{"id":"83:13:5","ayahNum":13,"wordNum":5,"word":"قَالَ","meaning":"he said (subject of أَسٰطِيرُ)","transliteration":"qāla","root":"قول","lemmaId":null},{"id":"83:13:6","ayahNum":13,"wordNum":6,"word":"أَسٰطِيرُ","meaning":"tales/legends (subject of قَالَ)","transliteration":"asāṭīru","root":"سطر","lemmaId":null},{"id":"83:13:7","ayahNum":13,"wordNum":7,"word":"ٱلْأَوَّلِينَ","meaning":"the ancient ones (possessed by أَسٰطِيرُ)","transliteration":"l-awalīna","root":"أول","lemmaId":null},{"id":"83:14:1","ayahNu