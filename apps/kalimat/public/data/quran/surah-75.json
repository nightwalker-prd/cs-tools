jamʿahu","root":"جمع","lemmaId":null},{"id":"75:17:4","ayahNum":17,"wordNum":4,"word":"وَقُرْءَانَهُۥ","meaning":"and its recitation","transliteration":"waqur'ānahu","root":"قرأ","lemmaId":null},{"id":"75:18:1","ayahNum":18,"wordNum":1,"word":"فَإِذَا","meaning":"so when/then when (followed by قَرَأْنٰهُ - We recite it)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"75:18:2","ayahNum":18,"wordNum":2,"word":"قَرَأْنٰهُ","meaning":"we read/recited it aloud (referring to the Quran)","transliteration":"qaranāhu","root":"قرأ","lemmaId":null},{"id":"75:18:3","ayahNum":18,"wordNum":3,"word":"فَٱتَّبِعْ","meaning":"then follow closely! (after قَرَأْنٰهُ - We have recited it)","transliteration":"fa-ittabiʿ","root":"تبع","lemmaId":875},{"id":"75:18:4","ayahNum":18,"wordNum":4,"word":"قُرْءَانَهُۥ","meaning":"its recitation (object of فَٱتَّبِعْ/follow)","transliteration":"qur'ānahu","root":"قرأ","lemmaId":null},{"id":"75:19:1","ayahNum":19,"wordNum":1,"word":"ثُمَّ","meaning":"then (followed by إِنَّ)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"75:19:2","ayahNum":19,"wordNum":2,"word":"إِنَّ","meaning":"indeed/truly/certainly (emphasizes what follows)","transliteration":"inna","root":"","lemmaId":502},{"id":"75:19:3","ayahNum":19,"wordNum":3,"word":"عَلَيْنَا","meaning":"upon us (connected to إِنَّ)","transliteration":"ʿalaynā","root":"","lemmaId":2585},{"id":"75:19:4","ayahNum":19,"wordNum":4,"word":"بَيَانَهُۥ","meaning":"its explanation (object of علينا/upon us)","transliteration":"bayānahu","root":"بين","lemmaId":810},{"id":"75:20:1","ayahNum":20,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! (used for strong denial or rejection)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"75:20:2","ayahNum":20,"wordNum":2,"word":"بَلْ","meaning":"No! Rather (correcting كَلَّا)","transliteration":"bal","root":"","lemmaId":4661},{"id":"75:20:3","ayahNum":20,"wordNum":3,"word":"تُحِبُّونَ","meaning":"you (all) intensely love (the عَاجِلَة - worldly life)","transliteration":"tuḥibbūna","root":"حبب","lemmaId":1324},{"id":"75:20:4","ayahNum":20,"wordNum":4,"word":"ٱلْعَاجِلَةَ","meaning":"the immediate/worldly life (object of تُحِبُّونَ)","transliteration":"l-ʿājilata","root":"عجل","lemmaId":null},{"id":"75:21:1","ayahNum":21,"wordNum":1,"word":"وَتَذَرُونَ","meaning":"and you all leave/abandon (the ٱلْءَاخِرَةَ - Hereafter)","transliteration":"watadharūna","root":"وذر","lemmaId":null},{"id":"75:21:2","ayahNum":21,"wordNum":2,"word":"ٱلْءَاخِرَةَ","meaning":"the Hereafter (object of تَذَرُونَ - you leave)","transliteration":"l-ākhirata","root":"أخر","lemmaId":null},{"id":"75:22:1","ayahNum":22,"wordNum":1,"word":"وُجُوهٌ","meaning":"faces (plural)","transliteration":"wujūhun","root":"وجه","lemmaId":4205},{"id":"75:22:2","ayahNum":22,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (when faces will be نَّاضِرَةٌ - radiant)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:22:3","ayahNum":22,"wordNum":3,"word":"نَّاضِرَةٌ","meaning":"intensely radiant (feminine, nominative case, describes وُجُوهٌ/faces)","transliteration":"nāḍiratun","root":"نضر","lemmaId":null},{"id":"75:23:1","ayahNum":23,"wordNum":1,"word":"إِلَىٰ","meaning":"towards (pointing to رَبِّهَا - her Lord)","transliteration":"ilā","root":"","lemmaId":486},{"id":"75:23:2","ayahNum":23,"wordNum":2,"word":"رَبِّهَا","meaning":"her master who cares for her (after إِلَىٰ)","transliteration":"rabbihā","root":"ربب","lemmaId":null},{"id":"75:23:3","ayahNum":23,"wordNum":3,"word":"نَاظِرَةٌ","meaning":"gazing (feminine, indefinite)","transliteration":"nāẓiratun","root":"نظر","lemmaId":null},{"id":"75:24:1","ayahNum":24,"wordNum":1,"word":"وَوُجُوهٌ","meaning":"and faces (that will do something)","transliteration":"wawujūhun","root":"وجه","lemmaId":null},{"id":"75:24:2","ayahNum":24,"wordNum":2,"word":"يَوْمَئِذٍۭ","meaning":"that day (when faces will be gloomy)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:24:3","ayahNum":24,"wordNum":3,"word":"بَاسِرَةٌ","meaning":"frowning (feminine, nominative)","transliteration":"bāsiratun","root":"بسر","lemmaId":null},{"id":"75:25:1","ayahNum":25,"wordNum":1,"word":"تَظُنُّ","meaning":"she thinks/believes (about what will happen to her)","transliteration":"taẓunnu","root":"ظنن","lemmaId":null},{"id":"75:25:2","ayahNum":25,"wordNum":2,"word":"أَن","meaning":"that (connects تَظُنُّ with يُفْعَلَ)","transliteration":"an","root":"","lemmaId":368},{"id":"75:25:3","ayahNum":25,"wordNum":3,"word":"يُفْعَلَ","meaning":"to be done/made (that something will happen to it)","transliteration":"yuf'ʿala","root":"فعل","lemmaId":null},{"id":"75:25:4","ayahNum":25,"wordNum":4,"word":"بِهَا","meaning":"with/by her/it (referring to فَاقِرَةٌ - a catastrophe)","transliteration":"bihā","root":"","lemmaId":692},{"id":"75:25:5","ayahNum":25,"wordNum":5,"word":"فَاقِرَةٌ","meaning":"a crushing calamity (that will devastate them)","transliteration":"fāqiratun","root":"فقر","lemmaId":null},{"id":"75:26:1","ayahNum":26,"wordNum":1,"word":"كَلَّآ","meaning":"No indeed! - used to strongly reject or deny something (introduces إِذَا بَلَغَتِ ٱلتَّرَاقِىَ)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"75:26:2","ayahNum":26,"wordNum":2,"word":"إِذَا","meaning":"when (referring to بَلَغَتِ - it reached)","transliteration":"idhā","root":"","lemmaId":461},{"id":"75:26:3","ayahNum":26,"wordNum":3,"word":"بَلَغَتِ","meaning":"she reached (referring to الروح - the soul)","transliteration":"balaghati","root":"بلغ","lemmaId":794},{"id":"75:26:4","ayahNum":26,"wordNum":4,"word":"ٱلتَّرَاقِىَ","meaning":"the collarbones (object of بَلَغَتِ)","transliteration":"l-tarāqiya","root":"ترق","lemmaId":null},{"id":"75:27:1","ayahNum":27,"wordNum":1,"word":"وَقِيلَ","meaning":"and it was said (connected to مَنْ رَاقٍ)","transliteration":"waqīla","root":"قول","lemmaId":null},{"id":"75:27:2","ayahNum":27,"wordNum":2,"word":"مَنْ","meaning":"who (asking about the person who will be رَاقٍ)","transliteration":"man","root":"","lemmaId":3464},{"id":"75:27:3","ayahNum":27,"wordNum":3,"word":"رَاقٍ","meaning":"one who ascends/heals","transliteration":"rāqin","root":"رقي","lemmaId":null},{"id":"75:28:1","ayahNum":28,"wordNum":1,"word":"وَظَنَّ","meaning":"and he thought/believed (connected to أَنَّهُ ٱلْفِرَاقُ - that it was the parting)","transliteration":"waẓanna","root":"ظنن","lemmaId":null},{"id":"75:28:2","ayahNum":28,"wordNum":2,"word":"أَنَّهُ","meaning":"that it (referring to الْفِرَاقُ - the parting)","transliteration":"annahu","root":"","lemmaId":368},{"id":"75:28:3","ayahNum":28,"wordNum":3,"word":"ٱلْفِرَاقُ","meaning":"the separation (predicate of أَنَّهُ)","transliteration":"l-firāqu","root":"فرق","lemmaId":null},{"id":"75:29:1","ayahNum":29,"wordNum":1,"word":"وَٱلْتَفَّتِ","meaning":"and she turned herself around (subject of ٱلسَّاقُ)","transliteration":"wal-tafati","root":"لفف","lemmaId":null},{"id":"75:29:2","ayahNum":29,"wordNum":2,"word":"ٱلسَّاقُ","meaning":"the leg (that's being wrapped around the other leg)","transliteration":"l-sāqu","root":"سوق","lemmaId":null},{"id":"75:29:3","ayahNum":29,"wordNum":3,"word":"بِٱلسَّاقِ","meaning":"with the leg","transliteration":"bil-sāqi","root":"سوق","lemmaId":null},{"id":"75:30:1","ayahNum":30,"wordNum":1,"word":"إِلَىٰ","meaning":"to (connects to رَبِّكَ - your Lord)","transliteration":"ilā","root":"","lemmaId":485},{"id":"75:30:2","ayahNum":30,"wordNum":2,"word":"رَبِّكَ","meaning":"your Lord (object of إِلَىٰ/to)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"75:30:3","ayahNum":30,"wordNum":3,"word":"يَوْمَئِذٍ","meaning":"on that day (connected to ٱلْمَسَاقُ)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:30:4","ayahNum":30,"wordNum":4,"word":"ٱلْمَسَاقُ","meaning":"the final destination (where all will be driven to on the Day of Judgment)","transliteration":"l-masāqu","root":"سوق","lemmaId":null},{"id":"75:31:1","ayahNum":31,"wordNum":1,"word":"فَلَا","meaning":"and then not (connects to صَدَّقَ - 'he believed')","transliteration":"falā","root":"","lemmaId":3147},{"id":"75:31:2","ayahNum":31,"wordNum":2,"word":"صَدَّقَ","meaning":"he affirmed strongly (connected to فَلَا - 'but no/not')","transliteration":"ṣaddaqa","root":"صدق","lemmaId":2256},{"id":"75:31:3","ayahNum":31,"wordNum":3,"word":"وَلَا","meaning":"and not (connects to فَلَا صَدَّقَ and negates صَلَّىٰ)","transliteration":"walā","root":"","lemmaId":3147},{"id":"75:31:4","ayahNum":31,"wordNum":4,"word":"صَلَّىٰ","meaning":"he prayed earnestly","transliteration":"ṣallā","root":"صلو","lemmaId":null},{"id":"75:32:1","ayahNum":32,"wordNum":1,"word":"وَلٰكِن","meaning":"and yet/but still (connecting to كَذَّبَ وَتَوَلَّىٰ - he denied and turned away)","transliteration":"walākin","root":"","lemmaId":4741},{"id":"75:32:2","ayahNum":32,"wordNum":2,"word":"كَذَّبَ","meaning":"he strongly denied/rejected (وَلٰكِن but)","transliteration":"kadhaba","root":"كذب","lemmaId":null},{"id":"75:32:3","ayahNum":32,"wordNum":3,"word":"وَتَوَلَّىٰ","meaning":"and he turned away","transliteration":"watawallā","root":"ولي","lemmaId":null},{"id":"75:33:1","ayahNum":33,"wordNum":1,"word":"ثُمَّ","meaning":"then (connecting to ذَهَبَ - he went)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"75:33:2","ayahNum":33,"wordNum":2,"word":"ذَهَبَ","meaning":"he went (followed by إِلَىٰ - to)","transliteration":"dhahaba","root":"ذهب","lemmaId":null},{"id":"75:33:3","ayahNum":33,"wordNum":3,"word":"إِلَىٰٓ","meaning":"to, towards (connected to أَهْلِهِۦ - his family)","transliteration":"ilā","root":"","lemmaId":485},{"id":"75:33:4","ayahNum":33,"wordNum":4,"word":"أَهْلِهِۦ","meaning":"his family (owned by إِلَىٰٓ)","transliteration":"ahlihi","root":"أهل","lemmaId":378},{"id":"75:33:5","ayahNum":33,"wordNum":5,"word":"يَتَمَطَّىٰٓ","meaning":"he is stretching himself (proudly)","transliteration":"yatamaṭṭā","root":"مطو","lemmaId":null},{"id":"7