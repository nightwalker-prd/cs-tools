"lemmaId":2068},{"id":"75:37:1","ayahNum":37,"wordNum":1,"word":"أَلَمْ","meaning":"Did not...? (asking about something in the past that connects to يَكُ)","transliteration":"alam","root":"","lemmaId":31},{"id":"75:37:2","ayahNum":37,"wordNum":2,"word":"يَكُنُ","meaning":"he is/exists (jussive mood)","transliteration":"yaku","root":"كون","lemmaId":null},{"id":"75:37:3","ayahNum":37,"wordNum":3,"word":"نُطْفَةً","meaning":"a drop (object of يَكُ)","transliteration":"nuṭ'fatan","root":"نطف","lemmaId":null},{"id":"75:37:4","ayahNum":37,"wordNum":4,"word":"مِّن","meaning":"from/of (describing نُطْفَةً)","transliteration":"min","root":"","lemmaId":3464},{"id":"75:37:5","ayahNum":37,"wordNum":5,"word":"مَّنِىٍّ","meaning":"semen/seminal fluid (being emitted)","transliteration":"maniyyin","root":"مني","lemmaId":null},{"id":"75:37:6","ayahNum":37,"wordNum":6,"word":"يُمْنَىٰ","meaning":"it is emitted (describing مَّنِىٍّ - seminal fluid)","transliteration":"yum'nā","root":"مني","lemmaId":null},{"id":"75:38:1","ayahNum":38,"wordNum":1,"word":"ثُمَّ","meaning":"then (connects كَانَ عَلَقَةً 'was a clinging substance' to what came before)","transliteration":"thumma","root":"","lemmaId":1171},{"id":"75:38:2","ayahNum":38,"wordNum":2,"word":"كَانَ","meaning":"he was (followed by عَلَقَةً - a clinging substance)","transliteration":"kāna","root":"كون","lemmaId":null},{"id":"75:38:3","ayahNum":38,"wordNum":3,"word":"عَلَقَةً","meaning":"a blood clot (object being transformed in كَانَ)","transliteration":"ʿalaqatan","root":"علق","lemmaId":2580},{"id":"75:38:4","ayahNum":38,"wordNum":4,"word":"فَخَلَقَ","meaning":"and then He created (after making it عَلَقَةً/a clinging substance)","transliteration":"fakhalaqa","root":"خلق","lemmaId":1555},{"id":"75:38:5","ayahNum":38,"wordNum":5,"word":"فَسَوَّىٰ","meaning":"and then He fashioned (it) perfectly (after خَلَقَ)","transliteration":"fasawwā","root":"سوي","lemmaId":null},{"id":"75:39:1","ayahNum":39,"wordNum":1,"word":"فَجَعَلَ","meaning":"and then He made (referring to Allah creating from a drop two pairs)","transliteration":"fajaʿala","root":"جعل","lemmaId":null},{"id":"75:39:2","ayahNum":39,"wordNum":2,"word":"مِنْهُ","meaning":"from him/it (object of جَعَلَ - he made)","transliteration":"min'hu","root":"","lemmaId":3464},{"id":"75:39:3","ayahNum":39,"wordNum":3,"word":"ٱلزَّوْجَيْنِ","meaning":"the two pairs","transliteration":"l-zawjayni","root":"زوج","lemmaId":null},{"id":"75:39:4","ayahNum":39,"wordNum":4,"word":"ٱلذَّكَرَ","meaning":"the male (object of جَعَلَ/made)","transliteration":"l-dhakara","root":"ذكر","lemmaId":null},{"id":"75:39:5","ayahNum":39,"wordNum":5,"word":"وَٱلْأُنثَىٰٓ","meaning":"and the female","transliteration":"wal-unthā","root":"أنث","lemmaId":null},{"id":"75:40:1","ayahNum":40,"wordNum":1,"word":"أَلَيْسَ","meaning":"is (it) not? (questioning ذٰلِكَ)","transliteration":"alaysa","root":"ليس","lemmaId":null},{"id":"75:40:2","ayahNum":40,"wordNum":2,"word":"ذٰلِكَ","meaning":"that (pointing to something far) (subject of أَلَيْسَ)","transliteration":"dhālika","root":"","lemmaId":1677},{"id":"75:40:3","ayahNum":40,"wordNum":3,"word":"بِقٰدِرٍ","meaning":"by/with a powerful one (connected to أَلَيْسَ - is not)","transliteration":"biqādirin","root":"قدر","lemmaId":null},{"id":"75:40:4","ayahNum":40,"wordNum":4,"word":"عَلَىٰٓ","meaning":"upon (connected to يُحْۦِىَ)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"75:40:5","ayahNum":40,"wordNum":5,"word":"أَن","meaning":"that (connects to يُحْۦِىَ/to bring to life)","transliteration":"an","root":"","lemmaId":368},{"id":"75:40:6","ayahNum":40,"wordNum":6,"word":"يُحْۦِىَ","meaning":"he gives life to (object of قٰدِرٍ - able to)","transliteration":"yuḥ'yiya","root":"حيي","lemmaId":null},{"id":"75:40:7","ayahNum":40,"wordNum":7,"word":"ٱلْمَوْتَىٰ","meaning":"the dead ones (object of يُحْۦِىَ - gives life to)","transliteration":"l-mawtā","root":"موت","lemmaId":3505}]