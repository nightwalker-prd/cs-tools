[{"id":"75:1:1","ayahNum":1,"wordNum":1,"word":"لَآ","meaning":"not (negates أُقْسِمُ/I swear)","transliteration":"lā","root":"","lemmaId":3147},{"id":"75:1:2","ayahNum":1,"wordNum":2,"word":"أُقْسِمُ","meaning":"I swear/take oath (present) (negated by لَآ)","transliteration":"uq'simu","root":"قسم","lemmaId":null},{"id":"75:1:3","ayahNum":1,"wordNum":3,"word":"بِيَوْمِ","meaning":"by the day (of ٱلْقِيٰمَةِ)","transliteration":"biyawmi","root":"يوم","lemmaId":null},{"id":"75:1:4","ayahNum":1,"wordNum":4,"word":"ٱلْقِيٰمَةِ","meaning":"the resurrection (in relation to يَوْمِ - day of)","transliteration":"l-qiyāmati","root":"قوم","lemmaId":null},{"id":"75:2:1","ayahNum":2,"wordNum":1,"word":"وَلَآ","meaning":"and no/and not (negates أُقْسِمُ)","transliteration":"walā","root":"","lemmaId":3147},{"id":"75:2:2","ayahNum":2,"wordNum":2,"word":"أُقْسِمُ","meaning":"I swear","transliteration":"uq'simu","root":"قسم","lemmaId":2951},{"id":"75:2:3","ayahNum":2,"wordNum":3,"word":"بِٱلنَّفْسِ","meaning":"by the soul/self (object of أُقْسِمُ - I swear)","transliteration":"bil-nafsi","root":"نفس","lemmaId":null},{"id":"75:2:4","ayahNum":2,"wordNum":4,"word":"ٱللَّوَّامَةِ","meaning":"the (female) who blames a lot (describing ٱلنَّفْسِ - the soul)","transliteration":"l-lawāmati","root":"لوم","lemmaId":null},{"id":"75:3:1","ayahNum":3,"wordNum":1,"word":"أَيَحْسَبُ","meaning":"does he think/suppose? (questioning ٱلْإِنسٰنُ/man)","transliteration":"ayaḥsabu","root":"حسب","lemmaId":1360},{"id":"75:3:2","ayahNum":3,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of يَحْسَبُ/does he think)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"75:3:3","ayahNum":3,"wordNum":3,"word":"أَلَّن","meaning":"that not (negates نَّجْمَعَ - we will gather)","transliteration":"allan","root":"","lemmaId":368},{"id":"75:3:4","ayahNum":3,"wordNum":4,"word":"نَّجْمَعَ","meaning":"we gather (bones)","transliteration":"najmaʿa","root":"جمع","lemmaId":1229},{"id":"75:3:5","ayahNum":3,"wordNum":5,"word":"عِظَامَهُۥ","meaning":"his bones (object of نَّجْمَعَ/we collect)","transliteration":"ʿiẓāmahu","root":"عظم","lemmaId":null},{"id":"75:4:1","ayahNum":4,"wordNum":1,"word":"بَلَىٰ","meaning":"yes indeed! (responding to doubt about Allah's power)","transliteration":"balā","root":"","lemmaId":4661},{"id":"75:4:2","ayahNum":4,"wordNum":2,"word":"قٰدِرِينَ","meaning":"those who are capable (of doing something)","transliteration":"qādirīna","root":"قدر","lemmaId":2931},{"id":"75:4:3","ayahNum":4,"wordNum":3,"word":"عَلَىٰٓ","meaning":"upon (connecting to نُّسَوِّىَ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"75:4:4","ayahNum":4,"wordNum":4,"word":"أَن","meaning":"that (connects to نُّسَوِّىَ - we will arrange)","transliteration":"an","root":"","lemmaId":368},{"id":"75:4:5","ayahNum":4,"wordNum":5,"word":"نُّسَوِّىَ","meaning":"we make equal or arrange (object of أَن)","transliteration":"nusawwiya","root":"سوي","lemmaId":null},{"id":"75:4:6","ayahNum":4,"wordNum":6,"word":"بَنَانَهُۥ","meaning":"his fingertips (being acted upon by نُّسَوِّىَ)","transliteration":"banānahu","root":"بنن","lemmaId":null},{"id":"75:5:1","ayahNum":5,"wordNum":1,"word":"بَلْ","meaning":"No! Rather... (introduces what follows in يُرِيدُ)","transliteration":"bal","root":"","lemmaId":4661},{"id":"75:5:2","ayahNum":5,"wordNum":2,"word":"يُرِيدُ","meaning":"he wants/seeks (subject of لِيَفْجُرَ)","transliteration":"yurīdu","root":"رود","lemmaId":null},{"id":"75:5:3","ayahNum":5,"wordNum":3,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of يُرِيدُ - wants)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"75:5:4","ayahNum":5,"wordNum":4,"word":"لِيَفْجُرَ","meaning":"so that he may break through boundaries (connected to يُرِيدُ - he wants)","transliteration":"liyafjura","root":"فجر","lemmaId":2798},{"id":"75:5:5","ayahNum":5,"wordNum":5,"word":"أَمَامَهُۥ","meaning":"in front of him","transliteration":"amāmahu","root":"أمم","lemmaId":null},{"id":"75:6:1","ayahNum":6,"wordNum":1,"word":"يَسْأَلُ","meaning":"he asks (about يَوْمُ ٱلْقِيٰمَةِ)","transliteration":"yasalu","root":"سأل","lemmaId":null},{"id":"75:6:2","ayahNum":6,"wordNum":2,"word":"أَيَّانَ","meaning":"when (asking about the Day of Judgment)","transliteration":"ayyāna","root":"","lemmaId":405},{"id":"75:6:3","ayahNum":6,"wordNum":3,"word":"يَوْمُ","meaning":"the Day (possessed by القيامة)","transliteration":"yawmu","root":"يوم","lemmaId":null},{"id":"75:6:4","ayahNum":6,"wordNum":4,"word":"ٱلْقِيٰمَةِ","meaning":"of the resurrection (modifies يَوْمُ - the Day)","transliteration":"l-qiyāmati","root":"قوم","lemmaId":null},{"id":"75:7:1","ayahNum":7,"wordNum":1,"word":"فَإِذَا","meaning":"and/so when (followed by بَرِقَ ٱلْبَصَرُ)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"75:7:2","ayahNum":7,"wordNum":2,"word":"بَرِقَ","meaning":"it became dazzled/stunned (describes ٱلْبَصَرُ - the vision)","transliteration":"bariqa","root":"برق","lemmaId":null},{"id":"75:7:3","ayahNum":7,"wordNum":3,"word":"ٱلْبَصَرُ","meaning":"the sight (subject of بَرِقَ - became dazzled)","transliteration":"l-baṣaru","root":"بصر","lemmaId":758},{"id":"75:8:1","ayahNum":8,"wordNum":1,"word":"وَخَسَفَ","meaning":"and it sank/disappeared (subject is ٱلْقَمَرُ)","transliteration":"wakhasafa","root":"خسف","lemmaId":null},{"id":"75:8:2","ayahNum":8,"wordNum":2,"word":"ٱلْقَمَرُ","meaning":"the moon (subject of خَسَفَ/darkened)","transliteration":"l-qamaru","root":"قمر","lemmaId":null},{"id":"75:9:1","ayahNum":9,"wordNum":1,"word":"وَجُمِعَ","meaning":"and was gathered (subject: ٱلشَّمْسُ وَٱلْقَمَرُ)","transliteration":"wajumiʿa","root":"جمع","lemmaId":null},{"id":"75:9:2","ayahNum":9,"wordNum":2,"word":"ٱلشَّمْسُ","meaning":"the sun (subject of was gathered)","transliteration":"l-shamsu","root":"شمس","lemmaId":null},{"id":"75:9:3","ayahNum":9,"wordNum":3,"word":"وَٱلْقَمَرُ","meaning":"and the moon (subject of جُمِعَ - was gathered)","transliteration":"wal-qamaru","root":"قمر","lemmaId":null},{"id":"75:10:1","ayahNum":10,"wordNum":1,"word":"يَقُولُ","meaning":"he says/is saying (describing what الإنسان/man does)","transliteration":"yaqūlu","root":"قول","lemmaId":2986},{"id":"75:10:2","ayahNum":10,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of يَقُولُ - he says)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"75:10:3","ayahNum":10,"wordNum":3,"word":"يَوْمَئِذٍ","meaning":"on that day (when this is happening)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:10:4","ayahNum":10,"wordNum":4,"word":"أَيْنَ","meaning":"where? (asking about the escape mentioned in ٱلْمَفَرُّ)","transliteration":"ayna","root":"","lemmaId":411},{"id":"75:10:5","ayahNum":10,"wordNum":5,"word":"ٱلْمَفَرُّ","meaning":"the escape (subject of أَيْنَ - where is)","transliteration":"l-mafaru","root":"فرر","lemmaId":3414},{"id":"75:11:1","ayahNum":11,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! By no means! (used for strong denial or rejection)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"75:11:2","ayahNum":11,"wordNum":2,"word":"لَا","meaning":"no (negating وَزَرَ - refuge)","transliteration":"lā","root":"","lemmaId":3147},{"id":"75:11:3","ayahNum":11,"wordNum":3,"word":"وَزَرَ","meaning":"he sought refuge (in response to كَلَّا لَا - 'No!')","transliteration":"wazara","root":"وزر","lemmaId":4223},{"id":"75:12:1","ayahNum":12,"wordNum":1,"word":"إِلَىٰ","meaning":"to (connects to رَبِّكَ - your Lord)","transliteration":"ilā","root":"","lemmaId":485},{"id":"75:12:2","ayahNum":12,"wordNum":2,"word":"رَبِّكَ","meaning":"your Lord (connected to إِلَىٰ/to)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"75:12:3","ayahNum":12,"wordNum":3,"word":"يَوْمَئِذٍ","meaning":"on that day (referring to the Day of Judgment)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:12:4","ayahNum":12,"wordNum":4,"word":"ٱلْمُسْتَقَرُّ","meaning":"the final destination (on that Day)","transliteration":"l-mus'taqaru","root":"قرر","lemmaId":null},{"id":"75:13:1","ayahNum":13,"wordNum":1,"word":"يُنَبَّؤُا۟","meaning":"they will be thoroughly informed (refers to الإنسان)","transliteration":"yunabba-u","root":"نبأ","lemmaId":null},{"id":"75:13:2","ayahNum":13,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (subject of يُنَبَّؤُا۟ - will be informed)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"75:13:3","ayahNum":13,"wordNum":3,"word":"يَوْمَئِذٍۭ","meaning":"on that day (when the human is informed of their deeds)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"75:13:4","ayahNum":13,"wordNum":4,"word":"بِمَا","meaning":"with/by what (relates to يُنَبَّؤُا - he will be informed)","transliteration":"bimā","root":"","lemmaId":3215},{"id":"75:13:5","ayahNum":13,"wordNum":5,"word":"قَدَّمَ","meaning":"he sent forward (what deeds he did)","transliteration":"qaddama","root":"قدم","lemmaId":null},{"id":"75:13:6","ayahNum":13,"wordNum":6,"word":"وَأَخَّرَ","meaning":"and he delayed (intensively) (connected to قَدَّمَ - what he sent ahead)","transliteration":"wa-akhara","root":"أخر","lemmaId":106},{"id":"75:14:1","ayahNum":14,"wordNum":1,"word":"بَلِ","meaning":"rather/but (connects to ٱلْإِنسٰنُ)","transliteration":"bali","root":"","lemmaId":4661},{"id":"75:14:2","ayahNum":14,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"the human being (as the subject)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"75:14:3","ayahNum":14,"wordNum":3,"word":"عَلَىٰ","meaning":"upon, on (preposition showing location relative to نَفْسِهِۦ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"75:14:4","ayahNum":14,"wordNum":4,"word":"نَفْسِهِۦ","meaning":"his self (after عَلَىٰ)","transliteration":"nafsihi","root":"نفس","lemmaId":null},{"id":"75:14:5","ayahNum":14,"wordNum":5,"word":"بَصِيرَةٌ","meaning":"a clear evidence (against نَفْسِهِۦ)","transliteration":"baṣī