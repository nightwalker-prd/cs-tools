بخل","lemmaId":null},{"id":"92:8:4","ayahNum":8,"wordNum":4,"word":"وَٱسْتَغْنَىٰ","meaning":"and he considered himself free from need","transliteration":"wa-is'taghnā","root":"غني","lemmaId":null},{"id":"92:9:1","ayahNum":9,"wordNum":1,"word":"وَكَذَّبَ","meaning":"and he strongly denied (بِٱلْحُسْنَىٰ - the good [reward])","transliteration":"wakadhaba","root":"كذب","lemmaId":3069},{"id":"92:9:2","ayahNum":9,"wordNum":2,"word":"بِٱلْحُسْنَىٰ","meaning":"with/by the best outcome (object of كَذَّبَ)","transliteration":"bil-ḥus'nā","root":"حسن","lemmaId":1357},{"id":"92:10:1","ayahNum":10,"wordNum":1,"word":"فَسَنُيَسِّرُهُۥ","meaning":"and so we will make it easy (acted on)","transliteration":"fasanuyassiruhu","root":"يسر","lemmaId":null},{"id":"92:10:2","ayahNum":10,"wordNum":2,"word":"لِلْعُسْرَىٰ","meaning":"for/towards the difficulty (object of فَسَنُيَسِّرُهُۥ)","transliteration":"lil'ʿus'rā","root":"عسر","lemmaId":2547},{"id":"92:11:1","ayahNum":11,"wordNum":1,"word":"وَمَا","meaning":"And what (negates يُغْنِى)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"92:11:2","ayahNum":11,"wordNum":2,"word":"يُغْنِى","meaning":"he makes (someone) rich/sufficient","transliteration":"yugh'nī","root":"غني","lemmaId":null},{"id":"92:11:3","ayahNum":11,"wordNum":3,"word":"عَنْهُ","meaning":"away from him","transliteration":"ʿanhu","root":"","lemmaId":4713},{"id":"92:11:4","ayahNum":11,"wordNum":4,"word":"مَالُهُۥٓ","meaning":"his wealth (will not avail him)","transliteration":"māluhu","root":"مول","lemmaId":null},{"id":"92:11:5","ayahNum":11,"wordNum":5,"word":"إِذَا","meaning":"when (something happens)","transliteration":"idhā","root":"","lemmaId":461},{"id":"92:11:6","ayahNum":11,"wordNum":6,"word":"تَرَدَّىٰٓ","meaning":"he fell into destruction","transliteration":"taraddā","root":"ردي","lemmaId":null},{"id":"92:12:1","ayahNum":12,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly/certainly","transliteration":"inna","root":"","lemmaId":502},{"id":"92:12:2","ayahNum":12,"wordNum":2,"word":"عَلَيْنَا","meaning":"upon us (connected to إِنَّ)","transliteration":"ʿalaynā","root":"","lemmaId":2582},{"id":"92:12:3","ayahNum":12,"wordNum":3,"word":"لَلْهُدَىٰ","meaning":"surely the guidance","transliteration":"lalhudā","root":"هدي","lemmaId":null},{"id":"92:13:1","ayahNum":13,"wordNum":1,"word":"وَإِنَّ","meaning":"and indeed","transliteration":"wa-inna","root":"","lemmaId":502},{"id":"92:13:2","ayahNum":13,"wordNum":2,"word":"لَنَا","meaning":"indeed for us (connected to وَإِنَّ)","transliteration":"lanā","root":"","lemmaId":null},{"id":"92:13:3","ayahNum":13,"wordNum":3,"word":"لَلْءَاخِرَةَ","meaning":"surely the hereafter (connected to لَنَا - for us)","transliteration":"lalākhirata","root":"أخر","lemmaId":null},{"id":"92:13:4","ayahNum":13,"wordNum":4,"word":"وَٱلْأُولَىٰ","meaning":"and the first (feminine) (contrasted with لَلْءَاخِرَةَ - the last)","transliteration":"wal-ūlā","root":"أول","lemmaId":401},{"id":"92:14:1","ayahNum":14,"wordNum":1,"word":"فَأَنذَرْتُكُمْ","meaning":"and so I made you all warned (about نَارًا - the fire)","transliteration":"fa-andhartukum","root":"نذر","lemmaId":3987},{"id":"92:14:2","ayahNum":14,"wordNum":2,"word":"نَارًا","meaning":"a fire (object of فَأَنذَرْتُكُمْ - I warned you of)","transliteration":"nāran","root":"نور","lemmaId":null},{"id":"92:14:3","ayahNum":14,"wordNum":3,"word":"تَلَظَّىٰ","meaning":"it becomes an intensely blazing fire (referring to نَارًا/the Fire)","transliteration":"talaẓẓā","root":"لظي","lemmaId":null},{"id":"92:15:1","ayahNum":15,"wordNum":1,"word":"لَا","meaning":"not (negates يَصْلَىٰهَآ - will burn in)","transliteration":"lā","root":"","lemmaId":3147},{"id":"92:15:2","ayahNum":15,"wordNum":2,"word":"يَصْلَىٰهَآ","meaning":"he will burn in it (referring to the Fire mentioned in context)","transliteration":"yaṣlāhā","root":"صلي","lemmaId":null},{"id":"92:15:3","ayahNum":15,"wordNum":3,"word":"إِلَّا","meaning":"except (emphasizing the exclusion)","transliteration":"illā","root":"","lemmaId":486},{"id":"92:15:4","ayahNum":15,"wordNum":4,"word":"ٱلْأَشْقَى","meaning":"the most wretched (subject of يَصْلَىٰهَآ)","transliteration":"l-ashqā","root":"شقو","lemmaId":2169},{"id":"92:16:1","ayahNum":16,"wordNum":1,"word":"ٱلَّذِى","meaning":"The one who (points to someone or something mentioned before)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"92:16:2","ayahNum":16,"wordNum":2,"word":"كَذَّبَ","meaning":"he strongly denied/rejected (subject of the sentence)","transliteration":"kadhaba","root":"كذب","lemmaId":3069},{"id":"92:16:3","ayahNum":16,"wordNum":3,"word":"وَتَوَلَّىٰ","meaning":"and he turned away","transliteration":"watawallā","root":"ولي","lemmaId":null},{"id":"92:17:1","ayahNum":17,"wordNum":1,"word":"وَسَيُجَنَّبُهَا","meaning":"and he will be made to stay away from it/her (referring to the Fire)","transliteration":"wasayujannabuhā","root":"جنب","lemmaId":null},{"id":"92:17:2","ayahNum":17,"wordNum":2,"word":"ٱلْأَتْقَى","meaning":"the most pious one (who will be kept away from it - وَسَيُجَنَّبُهَا)","transliteration":"l-atqā","root":"وقي","lemmaId":null},{"id":"92:18:1","ayahNum":18,"wordNum":1,"word":"ٱلَّذِى","meaning":"the one who (refers to the generous person mentioned in context)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"92:18:2","ayahNum":18,"wordNum":2,"word":"يُؤْتِي","meaning":"he gives (his wealth in مَالَهُۥ)","transliteration":"yu'tī","root":"أتي","lemmaId":null},{"id":"92:18:3","ayahNum":18,"wordNum":3,"word":"مَالَهُۥ","meaning":"his wealth (object being given by يُؤْتِى)","transliteration":"mālahu","root":"مول","lemmaId":null},{"id":"92:18:4","ayahNum":18,"wordNum":4,"word":"يَتَزَكَّىٰ","meaning":"he purifies himself (subject of يُؤْتِى - he gives)","transliteration":"yatazakkā","root":"زكو","lemmaId":null},{"id":"92:19:1","ayahNum":19,"wordNum":1,"word":"وَمَا","meaning":"and not (negating عِندَهُۥ مِن نِّعْمَةٍ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"92:19:2","ayahNum":19,"wordNum":2,"word":"لِأَحَدٍ","meaning":"for anyone (receiving نِّعْمَةٍ/favor)","transliteration":"li-aḥadin","root":"أحد","lemmaId":null},{"id":"92:19:3","ayahNum":19,"wordNum":3,"word":"عِندَهُۥ","meaning":"with him (referring to someone in 92:19)","transliteration":"ʿindahu","root":"عند","lemmaId":null},{"id":"92:19:4","ayahNum":19,"wordNum":4,"word":"مِن","meaning":"from/of (connects عِندَهُۥ with نِّعْمَةٍ)","transliteration":"min","root":"","lemmaId":3464},{"id":"92:19:5","ayahNum":19,"wordNum":5,"word":"نِّعْمَةٍ","meaning":"a blessing/favor (that is owned)","transliteration":"niʿ'matin","root":"نعم","lemmaId":null},{"id":"92:19:6","ayahNum":19,"wordNum":6,"word":"تُجْزَىٰٓ","meaning":"she/it is being rewarded","transliteration":"tuj'zā","root":"جزي","lemmaId":null},{"id":"92:20:1","ayahNum":20,"wordNum":1,"word":"إِلَّا","meaning":"except (what comes after ٱبْتِغَآءَ)","transliteration":"illā","root":"","lemmaId":486},{"id":"92:20:2","ayahNum":20,"wordNum":2,"word":"ٱبْتِغَآءَ","meaning":"seeking (as the object being acted upon)","transliteration":"ib'tighāa","root":"بغي","lemmaId":null},{"id":"92:20:3","ayahNum":20,"wordNum":3,"word":"وَجْهِ","meaning":"face of (owned by رَبِّهِ)","transliteration":"wajhi","root":"وجه","lemmaId":null},{"id":"92:20:4","ayahNum":20,"wordNum":4,"word":"رَبِّهِ","meaning":"his Lord (belonging to وَجْهِ - face)","transliteration":"rabbihi","root":"ربب","lemmaId":null},{"id":"92:20:5","ayahNum":20,"wordNum":5,"word":"ٱلْأَعْلَىٰ","meaning":"The Most High (a name/attribute of Allah)","transliteration":"l-aʿlā","root":"علو","lemmaId":null},{"id":"92:21:1","ayahNum":21,"wordNum":1,"word":"وَلَسَوْفَ","meaning":"and surely will (in the future) (connects to يَرْضَىٰ - he will be pleased)","transliteration":"walasawfa","root":"","lemmaId":4697},{"id":"92:21:2","ayahNum":21,"wordNum":2,"word":"يَرْضَىٰ","meaning":"he is/will be pleased (in وَلَسَوْفَ يَرْضَىٰ - and soon he will be pleased)","transliteration":"yarḍā","root":"رضو","lemmaId":1773}]