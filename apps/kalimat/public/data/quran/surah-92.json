[{"id":"92:1:1","ayahNum":1,"wordNum":1,"word":"وَٱلَّيْلِ","meaning":"and the night (when إِذَا يَغْشَىٰ)","transliteration":"wa-al-layli","root":"ليل","lemmaId":3194},{"id":"92:1:2","ayahNum":1,"wordNum":2,"word":"إِذَا","meaning":"when (connects to يَغْشَىٰ)","transliteration":"idhā","root":"","lemmaId":461},{"id":"92:1:3","ayahNum":1,"wordNum":3,"word":"يَغْشَىٰ","meaning":"he covers/is covering","transliteration":"yaghshā","root":"غشو","lemmaId":null},{"id":"92:2:1","ayahNum":2,"wordNum":1,"word":"والنهارِ","meaning":"by the daylight (object of oath)","transliteration":"wal-nahāri","root":"نهر","lemmaId":null},{"id":"92:2:2","ayahNum":2,"wordNum":2,"word":"إِذَا","meaning":"when (referring to تَجَلَّىٰ)","transliteration":"idhā","root":"","lemmaId":461},{"id":"92:2:3","ayahNum":2,"wordNum":3,"word":"تَجَلَّىٰ","meaning":"it made itself very clear (when the day)","transliteration":"tajallā","root":"جلو","lemmaId":null},{"id":"92:3:1","ayahNum":3,"wordNum":1,"word":"وَمَا","meaning":"and what (asking about something in خَلَقَ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"92:3:2","ayahNum":3,"wordNum":2,"word":"خَلَقَ","meaning":"he created (subject of وَمَا)","transliteration":"khalaqa","root":"خلق","lemmaId":null},{"id":"92:3:3","ayahNum":3,"wordNum":3,"word":"ٱلذَّكَرَ","meaning":"the male (object of خَلَقَ - created)","transliteration":"l-dhakara","root":"ذكر","lemmaId":1689},{"id":"92:3:4","ayahNum":3,"wordNum":4,"word":"وَٱلْأُنثَىٰٓ","meaning":"and the female (connected to ٱلذَّكَرَ)","transliteration":"wal-unthā","root":"أنث","lemmaId":null},{"id":"92:4:1","ayahNum":4,"wordNum":1,"word":"إِنَّ","meaning":"indeed (emphasizes سَعْيَكُمْ)","transliteration":"inna","root":"","lemmaId":502},{"id":"92:4:2","ayahNum":4,"wordNum":2,"word":"سَعْيَكُمْ","meaning":"your (plural) striving","transliteration":"saʿyakum","root":"سعي","lemmaId":null},{"id":"92:4:3","ayahNum":4,"wordNum":3,"word":"لَشَتَّىٰ","meaning":"truly various/different (describing سَعْ