[{"id":"82:1:1","ayahNum":1,"wordNum":1,"word":"إِذَا","meaning":"when (referring to a future event that will definitely happen)","transliteration":"idhā","root":"","lemmaId":461},{"id":"82:1:2","ayahNum":1,"wordNum":2,"word":"ٱلسَّمَآءُ","meaning":"the sky/heaven (subject of انفَطَرَتْ)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"82:1:3","ayahNum":1,"wordNum":3,"word":"ٱنفَطَرَتْ","meaning":"it (feminine) split/broke apart by itself (referring to السَّمَآءُ/the sky)","transliteration":"infaṭarat","root":"فطر","lemmaId":null},{"id":"82:2:1","ayahNum":2,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time of ٱنتَثَرَتْ - scattered)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"82:2:2","ayahNum":2,"wordNum":2,"word":"ٱلْكَوَاكِبُ","meaning":"the stars (subject of ٱنتَثَرَتْ)","transliteration":"l-kawākibu","root":"كوكب","lemmaId":null},{"id":"82:2:3","ayahNum":2,"wordNum":3,"word":"اِنْتَثَرَتْ","meaning":"it (feminine) scattered itself (said about الْكَوَاكِبُ - the stars)","transliteration":"intatharat","root":"نثر","lemmaId":null},{"id":"82:3:1","ayahNum":3,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces what will happen to البِحَارُ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"82:3:2","ayahNum":3,"wordNum":2,"word":"ٱلْبِحَارُ","meaning":"the seas (subject of فُجِّرَتْ - were burst open)","transliteration":"l-biḥāru","root":"بحر","lemmaId":null},{"id":"82:3:3","ayahNum":3,"wordNum":3,"word":"فُجِّرَتْ","meaning":"it (feminine) was made to burst forth (referring to البِحَارُ - the seas)","transliteration":"fujjirat","root":"فجر","lemmaId":2798},{"id":"82:4:1","ayahNum":4,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time of بُعْثِرَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"82:4:2","ayahNum":4,"wordNum":2,"word":"ٱلْقُبُورُ","meaning":"the graves (subject of بُعْثِرَتْ)","transliteration":"l-qubūru","root":"قبر","lemmaId":null},{"id":"82:4:3","ayahNum":4,"wordNum":3,"word":"بُعْثِرَتْ","meaning":"were completely scattered (referring to الْقُبُورُ/the graves)","transliteration":"buʿ'thirat","root":"بعثر","lemmaId":825},{"id":"82:5:1","ayahNum":5,"wordNum":1,"word":"عَلِمَتْ","meaning":"she knew (subject of نَفْسٌ)","transliteration":"ʿalimat","root":"علم","lemmaId":null},{"id":"82:5:2","ayahNum":5,"wordNum":2,"word":"نَفْسٌ","meaning":"a soul/self (subject of عَلِمَتْ)","transliteration":"nafsun","root":"نفس","lemmaId":null},{"id":"82:5:3","ayahNum":5,"wordNum":3,"word":"مَّا","meaning":"what (connects to عَلِمَتْ - knew)","transliteration":"mā","root":"","lemmaId":3215},{"id":"82:5:4","ayahNum":5,"wordNum":4,"word":"قَدَّمَتْ","meaning":"she sent forward (subject of نَفْسٌ)","transliteration":"qaddamat","root":"قدم","lemmaId":2933},{"id":"82:5:5","ayahNum":5,"wordNum":5,"word":"وَأَخَّرَتْ","meaning":"and she delayed intensively/repeatedly (subject of عَلِمَتْ)","transliteration":"wa-akharat","root":"أخر","lemmaId":106},{"id":"82:6:1","ayahNum":6,"wordNum":1,"word":"يٰٓأَيُّهَا","meaning":"O you (feminine)","transliteration":"yāayyuhā","root":"أيي","lemmaId":null},{"id":"82:6:2","ayahNum":6,"wordNum":2,"word":"ٱلْإِنسٰنُ","meaning":"O mankind! (being directly addressed)","transliteration":"l-insānu","root":"أنس","lemmaId":null},{"id":"82:6:3","ayahNum":6,"wordNum":3,"word":"مَا","meaning":"what (has deceived you about رَبِّكَ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"82:6:4","ayahNum":6,"wordNum":4,"word":"غَرَّكَ","meaning":"he thoroughly deceived/deluded you (referring to الْإِنسٰنُ - mankind)","transliteration":"gharraka","root":"غرر","lemmaId":2699},{"id":"82:6:5","ayahNum":6,"wordNum":5,"word":"بِرَبِّكَ","meaning":"by your Lord (used as an oath in this ayah)","transliteration":"birabbika","root":"ربب","lemmaId":null},{"id":"82:6:6","ayahNum":6,"wordNum":6,"word":"ٱلْكَرِيمِ","meaning":"the Most Generous (describing رَبِّكَ - your Lord)","transliteration":"l-karīmi","root":"كرم","lemmaId":3076},{"id":"82:7:1","ayahNum":7,"wordNum":1,"word":"ٱلَّذِى","meaning":"The One who (refers to Allah who خَلَقَكَ created you)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"82:7:2","ayahNum":7,"wordNum":2,"word":"خَلَقَكَ","meaning":"he created you (object of الَّذِى who)","transliteration":"khalaqaka","root":"خلق","lemmaId":1555},{"id":"82:7:3","ayahNum":7,"wordNum":3,"word":"فَسَوَّىٰكَ","meaning":"and so He made you perfectly (follows خَلَقَكَ - He created you)","transliteration":"fasawwāka","root":"سوي","lemmaId":null},{"id":"82:7:4","ayahNum":7,"wordNum":4,"word":"فَعَدَلَكَ","meaning":"and He made you balanced/proportionate (after خَلَقَكَ فَسَوَّىٰكَ)","transliteration":"faʿadalaka","root":"عدل","lemmaId":2516},{"id":"82:8:1","ayahNum":8,"wordNum":1,"word":"فِىٓ","meaning":"in (location within صُورَةٍ - form/shape)","transliteration":"fī","root":"","lemmaId":2887},{"id":"82:8:2","ayahNum":8,"wordNum":2,"word":"أَيِّ","meaning":"which, what kind (in genitive case)","transliteration":"ayyi","root":"أيي","lemmaId":null},{"id":"82:8:3","ayahNum":8,"wordNum":3,"word":"صُورَةٍ","meaning":"any form/shape (that Allah willed to assemble you in)","transliteration":"ṣūratin","root":"صور","lemmaId":2303},{"id":"82:8:4","ayahNum":8,"wordNum":4,"word":"مَّا","meaning":"whatever/whichever (form that شَآءَ wants)","transliteration":"mā","root":"","lemmaId":3215},{"id":"82:8:5","ayahNum":8,"wordNum":5,"word":"شَآءَ","meaning":"he willed/wished","transliteration":"shāa","root":"شيأ","lemmaId":null},{"id":"82:8:6","ayahNum":8,"wordNum":6,"word":"رَكَّبَكَ","meaning":"He formed you (referring to how Allah carefully assembled/fashioned humans)","transliteration":"rakkabaka","root":"ركب","lemmaId":null},{"id":"82:9:1","ayahNum":9,"wordNum":1,"word":"كَلَّا","meaning":"No indeed! (responding to those who deny the Day of Judgment)","transliteration":"kallā","root":"","lemmaId":3101},{"id":"82:9:2","ayahNum":9,"wordNum":2,"word":"بَلْ","meaning":"No! Rather... (correcting كَلَّا)","transliteration":"bal","root":"","lemmaId":4661},{"id":"82:9:3","ayahNum":9,"wordNum":3,"word":"تُكَذِّبُونَ","meaning":"you (all) strongly deny/reject (the religion/judgment)","transliteration":"tukadhibūna","root":"كذب","lemmaId":null},{"id":"82:9:4","ayahNum":9,"wordNum":4,"word":"بِٱلدِّينِ","meaning":"in/with the religion (object of تُكَذِّبُونَ - you deny)","transliteration":"bil-dīni","root":"دين","lemmaId":null},{"id":"82:10:1","ayahNum":10,"wordNum":1,"word":"وَإِنَّ","meaning":"and indeed (emphasizing عَلَيْكُمْ لَحٰفِظِينَ - 'over you are guardians')","transliteration":"wa-inna","root":"","lemmaId":502},{"id":"82:10:2","ayahNum":10,"wordNum":2,"word":"عَلَيْكُمْ","meaning":"upon you all (connected to لَحٰفِظِينَ - guardians)","transliteration":"ʿalaykum","root":"","lemmaId":2582},{"id":"82:10:3","ayahNum":10,"wordNum":3,"word":"لَحٰفِظِينَ","meaning":"surely protectors/guards","transliteration":"laḥāfiẓīna","root":"حفظ","lemmaId":null},{"id":"82:11:1","ayahNum":11,"wordNum":1,"word":"كِرَامًا","meaning":"noble ones (as the object of كٰتِبِينَ)","transliteration":"kirāman","root":"كرم","lemmaId":null},{"id":"82:11:2","ayahNum":11,"wordNum":2,"word":"كَاتِبِينَ","meaning":"writers (plural form)","transliteration":"kātibīna","root":"كتب","lemmaId":null},{"id":"82:12:1","ayahNum":12,"wordNum":1,"word":"يَعْلَمُونَ","meaning":"they know (what تَفْعَلُونَ you do)","transliteration":"yaʿlamūna","root":"علم","lemmaId":2583},{"id":"82:12:2","ayahNum":12,"wordNum":2,"word":"مَا","meaning":"what (connects يَعْلَمُونَ with تَفْعَلُونَ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"82:12:3","ayahNum":12,"wordNum":3,"word":"تَفْعَلُونَ","meaning":"you (all) do (subject of يَعْلَمُونَ)","transliteration":"tafʿalūna","root":"فعل","lemmaId":2836},{"id":"82:13:1","ayahNum":13,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly (emphasizes ٱلْأَبْرَارَ)","transliteration":"inna","root":"","lemmaId":502},{"id":"82:13:2","ayahNum":13,"wordNu