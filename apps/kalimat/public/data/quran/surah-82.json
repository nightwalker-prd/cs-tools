","meaning":"of the judgment/religion (connected to يَوْمُ)","transliteration":"l-dīni","root":"دين","lemmaId":null},{"id":"82:19:1","ayahNum":19,"wordNum":1,"word":"يَوْمَ","meaning":"day (in accusative case - used as object or time)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"82:19:2","ayahNum":19,"wordNum":2,"word":"لَا","meaning":"not (negates تَمْلِكُ)","transliteration":"lā","root":"","lemmaId":3147},{"id":"82:19:3","ayahNum":19,"wordNum":3,"word":"تَمْلِكُ","meaning":"she owns/controls","transliteration":"tamliku","root":"ملك","lemmaId":null},{"id":"82:19:4","ayahNum":19,"wordNum":4,"word":"نَفْسٌ","meaning":"a soul/self (doer of تَمْلِكُ)","transliteration":"nafsun","root":"نفس","lemmaId":null},{"id":"82:19:5","ayahNum":19,"wordNum":5,"word":"لِّنَفْسٍ","meaning":"for/to any soul/person","transliteration":"linafsin","root":"نفس","lemmaId":null},{"id":"82:19:6","ayahNum":19,"wordNum":6,"word":"شَيْـًٔا","meaning":"anything (that is owned/possessed by someone)","transliteration":"shayan","root":"شيأ","lemmaId":null},{"id":"82:19:7","ayahNum":19,"wordNum":7,"word":"وَٱلْأَمْرُ","meaning":"and the command/matter (subject)","transliteration":"wal-amru","root":"أمر","lemmaId":null},{"id":"82:19:8","ayahNum":19,"wordNum":8,"word":"يَوْمَئِذٍ","meaning":"on that day","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"82:19:9","ayahNum":19,"wordNum":9,"word":"لِّلَّهِ","meaning":"for/to God (belongs to يَوْمَئِذٍ - on that Day)","transliteration":"lillahi","root":"","lemmaId":null}]