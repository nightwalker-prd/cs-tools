":"وَلَا","meaning":"and not (connects to previous negative لَّا)","transliteration":"walā","root":"","lemmaId":3147},{"id":"88:7:4","ayahNum":7,"wordNum":4,"word":"يُغْنِى","meaning":"he makes (something/someone) sufficient (negated by لَا)","transliteration":"yugh'nī","root":"غني","lemmaId":null},{"id":"88:7:5","ayahNum":7,"wordNum":5,"word":"مِن","meaning":"from (connects جُوعٍ 'hunger' to show what doesn't nourish)","transliteration":"min","root":"","lemmaId":3464},{"id":"88:7:6","ayahNum":7,"wordNum":6,"word":"جُوعٍ","meaning":"from hunger (in مِن جُوعٍ - from hunger)","transliteration":"jūʿin","root":"جوع","lemmaId":null},{"id":"88:8:1","ayahNum":8,"wordNum":1,"word":"وُجُوهٌ","meaning":"faces (that will be)","transliteration":"wujūhun","root":"وجه","lemmaId":4205},{"id":"88:8:2","ayahNum":8,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (when faces will be نَّاعِمَةٌ [joyful])","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"88:8:3","ayahNum":8,"wordNum":3,"word":"نَّاعِمَةٌ","meaning":"intensely feeling pleasure (feminine) (describes وُجُوهٌ - faces)","transliteration":"nāʿimatun","root":"نعم","lemmaId":null},{"id":"88:9:1","ayahNum":9,"wordNum":1,"word":"لِّسَعْيِهَا","meaning":"for her effort (related to رَاضِيَةٌ)","transliteration":"lisaʿyihā","root":"سعي","lemmaId":null},{"id":"88:9:2","ayahNum":9,"wordNum":2,"word":"رَاضِيَةٌ","meaning":"being content/pleased (feminine, indefinite, describes وُجُوه/faces)","transliteration":"rāḍiyatun","root":"رضو","lemmaId":null},{"id":"88:10:1","ayahNum":10,"wordNum":1,"word":"فِى","meaning":"in (location in جَنَّةٍ - garden)","transliteration":"fī","root":"","lemmaId":2887},{"id":"88:10:2","ayahNum":10,"wordNum":2,"word":"جَنَّةٍ","meaning":"a garden (in فِى/in)","transliteration":"jannatin","root":"جنن","lemmaId":1241},{"id":"88:10:3","ayahNum":10,"wordNum":3,"word":"عَالِيَةٍ","meaning":"a high, rising (feminine form describing جَنَّةٍ/garden)","transliteration":"ʿāliyatin","root":"علو","lemmaId":null},{"id":"88:11:1","ayahNum":11,"wordNum":1,"word":"لَّا","meaning":"absolutely no/not at all (negates تَسْمَعُ 'you hear')","transliteration":"lā","root":"","lemmaId":3147},{"id":"88:11:2","ayahNum":11,"wordNum":2,"word":"تَسْمَعُ","meaning":"you hear (in لَّا تَسْمَعُ - you will not hear)","transliteration":"tasmaʿu","root":"سمع","lemmaId":2035},{"id":"88:11:3","ayahNum":11,"wordNum":3,"word":"فِيهَا","meaning":"in it (referring to جَنَّةٍ - garden)","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"88:11:4","ayahNum":11,"wordNum":4,"word":"لٰغِيَةً","meaning":"any empty talk (object of تَسْمَعُ)","transliteration":"lāghiyatan","root":"لغو","lemmaId":null},{"id":"88:12:1","ayahNum":12,"wordNum":1,"word":"فِيهَا","meaning":"in it (referring to جَنَّةٍ 'garden')","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"88:12:2","ayahNum":12,"wordNum":2,"word":"عَيْنٌ","meaning":"a spring (flowing in جَنَّةٍ عَالِيَةٍ - an elevated garden)","transliteration":"ʿaynun","root":"عين","lemmaId":null},{"id":"88:12:3","ayahNum":12,"wordNum":3,"word":"جَارِيَةٌ","meaning":"flowing/running (feminine, describing عَيْنٌ)","transliteration":"jāriyatun","root":"جري","lemmaId":1217},{"id":"88:13:1","ayahNum":13,"wordNum":1,"word":"فِيهَا","meaning":"in it/her (referring to the elevated couches mentioned after)","transliteration":"fīhā","root":"","lemmaId":2887},{"id":"88:13:2","ayahNum":13,"wordNum":2,"word":"سُرُرٌ","meaning":"thrones/couches (described by مَّرْفُوعَةٌ)","transliteration":"sururun","root":"سرر","lemmaId":null},{"id":"88:13:3","ayahNum":13,"wordNum":3,"word":"مَّرْفُوعَةٌ","meaning":"a raised/elevated (feminine)","transliteration":"marfūʿatun","root":"رفع","lemmaId":1781},{"id":"88:14:1","ayahNum":14,"wordNum":1,"word":"وَأَكْوَابٌ","meaning":"and cups (subject of مَّوْضُوعَةٌ)","transliteration":"wa-akwābun","root":"كوب","lemmaId":null},{"id":"88:14:2","ayahNum":14,"wordNum":2,"word":"مَّوْضُوعَةٌ","meaning":"well-placed/perfectly set (describing أَكْوَابٌ)","transliteration":"mawḍūʿatun","root":"وضع","lemmaId":null},{"id":"88:15:1","ayahNum":15,"wordNum":1,"word":"وَنَمَارِقُ","meaning":"and cushions (arranged in rows with مَصْفُوفَةٌ)","transliteration":"wanamāriqu","root":"نمرق","lemmaId":null},{"id":"88:15:2","ayahNum":15,"wordNum":2,"word":"مَصْفُوفَةٌ","meaning":"arranged in rows (feminine, describing the cushions as general items)","transliteration":"maṣfūfatun","root":"صفف","lemmaId":null},{"id":"88:16:1","ayahNum":16,"wordNum":1,"word":"وَزَرَابِيُّ","meaning":"and luxurious carpets (subject of مَبْثُوثَةٌ)","transliteration":"wazarābiyyu","root":"زرب","lemmaId":null},{"id":"88:16:2","ayahNum":16,"wordNum":2,"word":"مَبْثُوثَةٌ","meaning":"scattered, spread out (feminine indefinite)","transliteration":"mabthūthatun","root":"بثث","lemmaId":null},{"id":"88:17:1","ayahNum":17,"wordNum":1,"word":"أَفَلَا","meaning":"Then do they not...? (connecting to يَنظُرُونَ - they look)","transliteration":"afalā","root":"","lemmaId":31},{"id":"88:17:2","ayahNum":17,"wordNum":2,"word":"يَنظُرُونَ","meaning":"they look/are looking (at الْإِبِلِ)","transliteration":"yanẓurūna","root":"نظر","lemmaId":4028},{"id":"88:17:3","ayahNum":17,"wordNum":3,"word":"إِلَى","meaning":"to/towards (connects يَنظُرُونَ with ٱلْإِبِلِ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"88:17:4","ayahNum":17,"wordNum":4,"word":"ٱلْإِبِلِ","meaning":"to the camels (object of يَنظُرُونَ)","transliteration":"l-ibili","root":"أبل","lemmaId":null},{"id":"88:17:5","ayahNum":17,"wordNum":5,"word":"كَيْفَ","meaning":"how (question word)","transliteration":"kayfa","root":"كيف","lemmaId":null},{"id":"88:17:6","ayahNum":17,"wordNum":6,"word":"خُلِقَتْ","meaning":"it was created (referring to الإبل/the camel)","transliteration":"khuliqat","root":"خلق","lemmaId":null},{"id":"88:18:1","ayahNum":18,"wordNum":1,"word":"وَإِلَى","meaning":"and towards (points to السَّمَآءِ/the sky)","transliteration":"wa-ilā","root":"","lemmaId":485},{"id":