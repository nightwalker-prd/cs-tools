agic')","transliteration":"in","root":"","lemmaId":502},{"id":"74:24:3","ayahNum":24,"wordNum":3,"word":"هٰذَآ","meaning":"this (near) (subject of سِحْرٌ)","transliteration":"hādhā","root":"","lemmaId":null},{"id":"74:24:4","ayahNum":24,"wordNum":4,"word":"إِلَّا","meaning":"except/only (excluding سِحْرٌ from what came before)","transliteration":"illā","root":"","lemmaId":486},{"id":"74:24:5","ayahNum":24,"wordNum":5,"word":"سِحْرٌ","meaning":"magic (being used as a subject)","transliteration":"siḥ'run","root":"سحر","lemmaId":null},{"id":"74:24:6","ayahNum":24,"wordNum":6,"word":"يُؤْثَرُ","meaning":"it is being passed down (describing السِّحْرُ/magic)","transliteration":"yu'tharu","root":"أثر","lemmaId":63},{"id":"74:25:1","ayahNum":25,"wordNum":1,"word":"إِنْ","meaning":"if (introduces the condition 'this is nothing but human speech')","transliteration":"in","root":"","lemmaId":502},{"id":"74:25:2","ayahNum":25,"wordNum":2,"word":"هٰذَآ","meaning":"this (with extended pronunciation)","transliteration":"hādhā","root":"","lemmaId":null},{"id":"74:25:3","ayahNum":25,"wordNum":3,"word":"إِلَّا","meaning":"except (connecting to قَوْلُ ٱلْبَشَرِ - human speech)","transliteration":"illā","root":"","lemmaId":486},{"id":"74:25:4","ayahNum":25,"wordNum":4,"word":"قَوْلُ","meaning":"speech (subject of إِنْ هٰذَآ إِلَّا)","transliteration":"qawlu","root":"قول","lemmaId":null},{"id":"74:25:5","ayahNum":25,"wordNum":5,"word":"ٱلْبَشَرِ","meaning":"of the human beings","transliteration":"l-bashari","root":"بشر","lemmaId":null},{"id":"74:26:1","ayahNum":26,"wordNum":1,"word":"سَأُصْلِيهِ","meaning":"I will cause him to burn","transliteration":"sa-uṣ'līhi","root":"صلي","lemmaId":null},{"id":"74:26:2","ayahNum":26,"wordNum":2,"word":"سَقَرَ","meaning":"Saqar (object of سَأُصْلِيهِ - I will burn him in)","transliteration":"saqara","root":"","lemmaId":2012},{"id":"74:27:1","ayahNum":27,"wordNum":1,"word":"وَمَآ","meaning":"and what (with emphasis)","transliteration":"wamā","root":"",