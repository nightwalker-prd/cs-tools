ll},{"id":"74:6:3","ayahNum":6,"wordNum":3,"word":"تَسْتَكْثِرُ","meaning":"you seek to increase (connected to تَمْنُن - you bestow favor)","transliteration":"tastakthiru","root":"كثر","lemmaId":null},{"id":"74:7:1","ayahNum":7,"wordNum":1,"word":"وَلِرَبِّكَ","meaning":"and for your lord (connected to فَٱصْبِرْ - so be patient)","transliteration":"walirabbika","root":"ربب","lemmaId":null},{"id":"74:7:2","ayahNum":7,"wordNum":2,"word":"فَٱصْبِرْ","meaning":"so be patient!","transliteration":"fa-iṣ'bir","root":"صبر","lemmaId":null},{"id":"74:8:1","ayahNum":8,"wordNum":1,"word":"فَإِذَا","meaning":"and/then when (followed by نُقِرَ - is blown)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"74:8:2","ayahNum":8,"wordNum":2,"word":"نُقِرَ","meaning":"it was blown (referring to الناقور - the trumpet)","transliteration":"nuqira","root":"نقر","lemmaId":4101},{"id":"74:8:3","ayahNum":8,"wordNum":3,"word":"فِى","meaning":"in (location in ٱلنَّاقُورِ - the trumpet)","transliteration":"fī","root":"","lemmaId":2887},{"id":"74:8:4","ayahNum":8,"wordNum":4,"word":"ٱلنَّاقَرَ","meaning":"the one who struck repeatedly","transliteration":"l-nāqūri","root":"نقر","lemmaId":null},{"id":"74:9:1","ayahNum":9,"wordNum":1,"word":"فَذٰلِكَ","meaning":"so that (connecting to what came before)","transliteration":"fadhālika","root":"","lemmaId":1677},{"id":"74:9:2","ayahNum":9,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (describes عَسِيرٌ)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"74:9:3","ayahNum":9,"wordNum":3,"word":"يَوْمٌ","meaning":"a day","transliteration":"yawmun","root":"يوم","lemmaId":null},{"id":"74:9:4","ayahNum":9,"wordNum":4,"word":"عَسِيرٌ","meaning":"a difficult thing","transliteration":"ʿasīrun","root":"عسر","lemmaId":null},{"id":"74:10:1","ayahNum":10,"wordNum":1,"word":"عَلَى","meaning":"upon, against (describing the difficulty for الْكٰفِرِينَ)","transliteration":"ʿalā","root":"","lemmaId":null},{"id":"74:10:2","ayahNum":1