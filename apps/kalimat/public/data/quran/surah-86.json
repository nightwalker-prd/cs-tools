[{"id":"86:1:1","ayahNum":1,"wordNum":1,"word":"وَٱلسَّمَآءِ","meaning":"and the sky (being sworn by)","transliteration":"wal-samāi","root":"سمو","lemmaId":null},{"id":"86:1:2","ayahNum":1,"wordNum":2,"word":"وَٱلطَّارِقِ","meaning":"and the night visitor (owned by السماءِ)","transliteration":"wal-ṭāriqi","root":"طرق","lemmaId":null},{"id":"86:2:1","ayahNum":2,"wordNum":1,"word":"وَمَآ","meaning":"and what (asking about الطَّارِقُ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"86:2:2","ayahNum":2,"wordNum":2,"word":"أَدْرَىٰكَ","meaning":"made you know","transliteration":"adrāka","root":"دري","lemmaId":null},{"id":"86:2:3","ayahNum":2,"wordNum":3,"word":"مَا","meaning":"what (asking about الطَّارِقُ)","transliteration":"mā","root":"","lemmaId":3215},{"id":"86:2:4","ayahNum":2,"wordNum":4,"word":"ٱلطَّارِقُ","meaning":"the night visitor (referring to a bright star)","transliteration":"l-ṭāriqu","root":"طرق","lemmaId":null},{"id":"86:3:1","ayahNum":3,"wordNum":1,"word":"ٱلنَّجْمُ","meaning":"the star (as the subject)","transliteration":"al-najmu","root":"نجم","lemmaId":null},{"id":"86:3:2","ayahNum":3,"wordNum":2,"word":"ٱلثَّاقِبُ","meaning":"the piercing, penetrating one (describes النَّجْمُ/the star)","transliteration":"l-thāqibu","root":"ثقب","lemmaId":null},{"id":"86:4:1","ayahNum":4,"wordNum":1,"word":"إِن","meaning":"indeed/verily (emphasizes كُلُّ نَفْسٍ that follows)","transliteration":"in","root":"","lemmaId":502},{"id":"86:4:2","ayahNum":4,"wordNum":2,"word":"كُلُّ","meaning":"every (describes نَفْسٍ)","transliteration":"kullu","root":"كلل","lemmaId":null},{"id":"86:4:3","ayahNum":4,"wordNum":3,"word":"نَفْسٍ","meaning":"a soul/self (possessed by كُلُّ)","transliteration":"nafsin","root":"نفس","lemmaId":null},{"id":"86:4:4","ayahNum":4,"wordNum":4,"word":"لَّمَّا","meaning":"when (emphasizing the connection between كُلُّ نَفْسٍ and حَافِظٌ)","transliteration":"lammā","root":"","lemmaId":4736},{"id":"86:4:5","ayahNum":4,"wordNum":5,"word":"عَلَي