":"between (connecting to الصُّلْبِ)","transliteration":"bayni","root":"بين","lemmaId":null},{"id":"86:7:4","ayahNum":7,"wordNum":4,"word":"ٱلصُّلْبِ","meaning":"the backbone (after مِنۢ بَيْنِ)","transliteration":"l-ṣul'bi","root":"صلب","lemmaId":2291},{"id":"86:7:5","ayahNum":7,"wordNum":5,"word":"وَٱلتَّرَآئِبِ","meaning":"and the chest bones","transliteration":"wal-tarāibi","root":"ترب","lemmaId":null},{"id":"86:8:1","ayahNum":8,"wordNum":1,"word":"إِنَّهُۥ","meaning":"indeed he (subject of لَقَادِرٌ - capable)","transliteration":"innahu","root":"","lemmaId":502},{"id":"86:8:2","ayahNum":8,"wordNum":2,"word":"عَلَىٰ","meaning":"upon/on/over","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"86:8:3","ayahNum":8,"wordNum":3,"word":"رَجْعِهِۦ","meaning":"his returning (after عَلَىٰ)","transliteration":"rajʿihi","root":"رجع","lemmaId":null},{"id":"86:8:4","ayahNum":8,"wordNum":4,"word":"لَقَادِرٌ","meaning":"surely having complete power/truly able in an absolute sense (describes إِنَّهُ - indeed He)","transliteration":"laqādirun","root":"قدر","lemmaId":null},{"id":"86:9:1","ayahNum":9,"wordNum":1,"word":"يَوْمَ","meaning":"on the day (when تُبْلَى the secrets will be tested)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"86:9:2","ayahNum":9,"wordNum":2,"word":"تُبْلَى","meaning":"is being tested (on يَوْمَ - Day)","transliteration":"tub'lā","root":"بلو","lemmaId":null},{"id":"86:9:3","ayahNum":9,"wordNum":3,"word":"ٱلسَّرَآئِرُ","meaning":"the secrets (subject of تُبْلَى - will be exposed)","transliteration":"l-sarāiru","root":"سرر","lemmaId":null},{"id":"86:10:1","ayahNum":10,"wordNum":1,"word":"فَمَا","meaning":"then what/so what (connects to previous statement about having no strength)","transliteration":"famā","root":"","lemmaId":3215},{"id":"86:10:2","ayahNum":10,"wordNum":2,"word":"لَهُۥ","meaning":"for him/to him (connected to قُوَّةٍ)","transliteration":"lahu","root":"","lemmaId":3146},{"id":"86:10:3","ayahNum":10,"wordNum":3,"word":"