,{"id":"87:16:4","ayahNum":16,"wordNum":4,"word":"ٱلدُّنْيَا","meaning":"the worldly (life) (describes ٱلْحَيَوٰةَ)","transliteration":"l-dun'yā","root":"دنو","lemmaId":null},{"id":"87:17:1","ayahNum":17,"wordNum":1,"word":"ٱلْآخِرَةُ","meaning":"and the life to come (subject of خَيْرٌ)","transliteration":"wal-ākhiratu","root":"أخر","lemmaId":106},{"id":"87:17:2","ayahNum":17,"wordNum":2,"word":"خَيْرٌ","meaning":"better (describes الآخِرَةُ)","transliteration":"khayrun","root":"خير","lemmaId":null},{"id":"87:17:3","ayahNum":17,"wordNum":3,"word":"وَأَبْقَىٰٓ","meaning":"and more lasting","transliteration":"wa-abqā","root":"بقي","lemmaId":null},{"id":"87:18:1","ayahNum":18,"wordNum":1,"word":"إِنَّ","meaning":"indeed (emphasizes 'هٰذَا' - this)","transliteration":"inna","root":"","lemmaId":502},{"id":"87:18:2","ayahNum":18,"wordNum":2,"word":"هٰذَا","meaning":"this (points to something nearby) (subject of لَفِى)","transliteration":"hādhā","root":"","lemmaId":null},{"id":"87:18:3","ayahNum":18,"wordNum":3,"word":"لَفِى","meaning":"surely/indeed in (connects to ٱلصُّحُفِ)","transliteration":"lafī","root":"","lemmaId":null},{"id":"87:18:4","ayahNum":18,"wordNum":4,"word":"ٱلصُّحُفِ","meaning":"the written pages/scrolls","transliteration":"l-ṣuḥufi","root":"صحف","lemmaId":2312},{"id":"87:18:5","ayahNum":18,"wordNum":5,"word":"ٱلْأُولَىٰ","meaning":"the first (feminine)","transliteration":"l-ūlā","root":"أول","lemmaId":null},{"id":"87:19:1","ayahNum":19,"wordNum":1,"word":"صُحُفِ","meaning":"of the written pages/scrolls (belonging to إِبْرٰهِيمَ وَمُوسَىٰ)","transliteration":"ṣuḥufi","root":"صحف","lemmaId":null},{"id":"87:19:2","ayahNum":19,"wordNum":2,"word":"إِبْرٰهِيمَ","meaning":"Abraham (the proper name, in the scrolls of إِبْرٰهِيمَ)","transliteration":"ib'rāhīma","root":"","lemmaId":null},{"id":"87:19:3","ayahNum":19,"wordNum":3,"word":"وَمُوسَىٰ","meaning":"and Moses","transliteration":"wamūsā","root":"","lemmaId":3887}]