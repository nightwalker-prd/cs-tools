[{"id":"87:1:1","ayahNum":1,"wordNum":1,"word":"سَبِّحِ","meaning":"glorify! (command)","transliteration":"sabbiḥi","root":"سبح","lemmaId":null},{"id":"87:1:2","ayahNum":1,"wordNum":2,"word":"ٱسْمَ","meaning":"name (object of سَبِّحِ/glorify)","transliteration":"is'ma","root":"سمو","lemmaId":null},{"id":"87:1:3","ayahNum":1,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (possessed by اسم)","transliteration":"rabbika","root":"ربب","lemmaId":null},{"id":"87:1:4","ayahNum":1,"wordNum":4,"word":"ٱلْأَعْلَى","meaning":"The Most High (a name/attribute of رَبِّكَ - your Lord)","transliteration":"l-aʿlā","root":"علو","lemmaId":null},{"id":"87:2:1","ayahNum":2,"wordNum":1,"word":"ٱلَّذِى","meaning":"The one who (connects to خَلَقَ - created)","transliteration":"alladhī","root":"","lemmaId":null},{"id":"87:2:2","ayahNum":2,"wordNum":2,"word":"خَلَقَ","meaning":"he created (followed by فَسَوَّىٰ - and then perfected)","transliteration":"khalaqa","root":"خلق","lemmaId":null},{"id":"87:2:3","ayahNum":2,"wordNum":3,"word":"فَسَوَّىٰ","meaning":"so He made perfect/proportioned","transliteration":"fasawwā","root":"سوي","lemmaId":2048},{"id":"87:3:1","ayahNum":3,"wordNum":1,"word":"وَٱلَّذِى","meaning":"And the one who/that which (subject of قَدَّرَ)","transliteration":"wa-alladhī","root":"","lemmaId":null},{"id":"87:3:2","ayahNum":3,"wordNum":2,"word":"قَدَّرَ","meaning":"he determined precisely (subject of فَهَدَىٰ)","transliteration":"qaddara","root":"قدر","lemmaId":2931},{"id":"87:3:3","ayahNum":3,"wordNum":3,"word":"فَهَدَىٰ","meaning":"and thus he guided (after قَدَّرَ - he determined)","transliteration":"fahadā","root":"هدي","lemmaId":4134},{"id":"87:4:1","ayahNum":4,"wordNum":1,"word":"وَٱلَّذِىٓ","meaning":"and the one who/which (subject of أَخْرَجَ)","transliteration":"wa-alladhī","root":"","lemmaId":null},{"id":"87:4:2","ayahNum":4,"wordNum":2,"word":"أَخْرَجَ","meaning":"he brought forth (the pasture/المرعى)","transliteration":"akhraja","root":"خرج","lemmaId":1523},{"