[{"id":"81:1:1","ayahNum":1,"wordNum":1,"word":"إِذَا","meaning":"when (introducing something certain to happen in the future)","transliteration":"idhā","root":"","lemmaId":461},{"id":"81:1:2","ayahNum":1,"wordNum":2,"word":"ٱلشَّمْسُ","meaning":"the sun (definite)","transliteration":"l-shamsu","root":"شمس","lemmaId":null},{"id":"81:1:3","ayahNum":1,"wordNum":3,"word":"كُوِّرَتْ","meaning":"it (feminine) was intensively rolled up (referring to الشَّمْسُ/the sun)","transliteration":"kuwwirat","root":"كور","lemmaId":null},{"id":"81:2:1","ayahNum":2,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introducing the time of ٱنكَدَرَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:2:2","ayahNum":2,"wordNum":2,"word":"ٱلنُّجُومُ","meaning":"the stars (subject of ٱنكَدَرَتْ - scattered/darkened)","transliteration":"l-nujūmu","root":"نجم","lemmaId":3974},{"id":"81:2:3","ayahNum":2,"wordNum":3,"word":"ٱنكَدَرَتْ","meaning":"it (feminine) scattered/darkened (referring to النجوم/the stars)","transliteration":"inkadarat","root":"كدر","lemmaId":null},{"id":"81:3:1","ayahNum":3,"wordNum":1,"word":"وَإِذَا","meaning":"and when (connecting this future event to what came before)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:3:2","ayahNum":3,"wordNum":2,"word":"ٱلْجِبَالُ","meaning":"the mountains (subject of سُيِّرَتْ)","transliteration":"l-jibālu","root":"جبل","lemmaId":1205},{"id":"81:3:3","ayahNum":3,"wordNum":3,"word":"سُيِّرَتْ","meaning":"it (feminine) was made to move (referring to الْجِبَالُ/the mountains)","transliteration":"suyyirat","root":"سير","lemmaId":null},{"id":"81:4:1","ayahNum":4,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time when العِشَارُ will be abandoned)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:4:2","ayahNum":4,"wordNum":2,"word":"ٱلْعِشَارُ","meaning":"the she-camels in the tenth month of pregnancy (subject of عُطِّلَتْ - were abandoned)","transliteration":"l-ʿishāru","root":"عشر","lemmaId":2650},{"id":"81:4:3","ayahNum":4,"wordNum":3,"word":"عُطِّلَتْ","meaning":"was abandoned (referring to she/it)","transliteration":"ʿuṭṭilat","root":"عطل","lemmaId":null},{"id":"81:5:1","ayahNum":5,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time when ٱلْوُحُوشُ حُشِرَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:5:2","ayahNum":5,"wordNum":2,"word":"ٱلْوُحُوشُ","meaning":"the wild beasts (subject of حُشِرَتْ - were gathered)","transliteration":"l-wuḥūshu","root":"وحش","lemmaId":null},{"id":"81:5:3","ayahNum":5,"wordNum":3,"word":"حُشِرَتْ","meaning":"she/it was gathered (referring to الْوُحُوشُ - the wild beasts)","transliteration":"ḥushirat","root":"حشر","lemmaId":null},{"id":"81:6:1","ayahNum":6,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time when ٱلْبِحَارُ سُجِّرَتْ - the seas are heated)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:6:2","ayahNum":6,"wordNum":2,"word":"ٱلْبِحَارُ","meaning":"the seas (subject of سُجِّرَتْ - were filled)","transliteration":"l-biḥāru","root":"بحر","lemmaId":727},{"id":"81:6:3","ayahNum":6,"wordNum":3,"word":"سُجِّرَتْ","meaning":"it (referring to البِحَارُ - the seas) was forcefully filled/heated","transliteration":"sujjirat","root":"سجر","lemmaId":null},{"id":"81:7:1","ayahNum":7,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces the time when النُّفُوسُ souls will be paired)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:7:2","ayahNum":7,"wordNum":2,"word":"ٱلنُّفُوسُ","meaning":"the souls","transliteration":"l-nufūsu","root":"نفس","lemmaId":null},{"id":"81:7:3","ayahNum":7,"wordNum":3,"word":"زُوِّجَتْ","meaning":"she was joined/paired (referring to النُّفُوسُ - the souls)","transliteration":"zuwwijat","root":"زوج","lemmaId":1903},{"id":"81:8:1","ayahNum":8,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introducing the time when ٱلْمَوْءُۥدَةُ سُئِلَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:8:2","ayahNum":8,"wordNum":2,"word":"ٱلْمَوْءُۥدَةُ","meaning":"the female who was buried alive","transliteration":"l-mawūdatu","root":"وأد","lemmaId":null},{"id":"81:8:3","ayahNum":8,"wordNum":3,"word":"سُئِلَتْ","meaning":"she was asked (referring to الْمَوْءُۥدَةُ - the buried alive girl)","transliteration":"su-ilat","root":"سأل","lemmaId":1964},{"id":"81:9:1","ayahNum":9,"wordNum":1,"word":"بِأَيِّ","meaning":"by which (asking about ذَنۢبٍ/sin)","transliteration":"bi-ayyi","root":"أيي","lemmaId":null},{"id":"81:9:2","ayahNum":9,"wordNum":2,"word":"ذَنۢبٍ","meaning":"sin/wrong (possessed by أَيّ)","transliteration":"dhanbin","root":"ذنب","lemmaId":null},{"id":"81:9:3","ayahNum":9,"wordNum":3,"word":"قُتِلَتْ","meaning":"she was killed violently (referring to المَوْءُۥدَةُ - the buried alive girl)","transliteration":"qutilat","root":"قتل","lemmaId":null},{"id":"81:10:1","ayahNum":10,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introducing a future condition)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:10:2","ayahNum":10,"wordNum":2,"word":"ٱلصُّحُفُ","meaning":"the scrolls (subject of نُشِرَتْ - were spread out)","transliteration":"l-ṣuḥufu","root":"صحف","lemmaId":null},{"id":"81:10:3","ayahNum":10,"wordNum":3,"word":"نُشِرَتْ","meaning":"it (f) was spread out (referring to الصُّحُفُ - the scrolls)","transliteration":"nushirat","root":"نشر","lemmaId":null},{"id":"81:11:1","ayahNum":11,"wordNum":1,"word":"وَإِذَا","meaning":"and when (introduces a condition about السَّمَآءُ كُشِطَتْ)","transliteration":"wa-idhā","root":"","lemmaId":4646},{"id":"81:11:2","ayahNum":11,"wordNum":2,"word":"ٱلسَّمَآءُ","meaning":"the sky (subject of كُشِطَتْ)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"81:11:3","ayahNum":11,"wordNum":3,"word":"كُشِطَتْ","meaning":"it (feminine) was stripped away (referring to السَّمَآءُ/the sky)","transliteration":"kushiṭat","root":"كشط","lemmaId":null},{"id":"81:12:1","ayahNum":12,"wor