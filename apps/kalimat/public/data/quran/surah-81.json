"lemmaId":null},{"id":"81:19:4","ayahNum":19,"wordNum":4,"word":"كَرِيمٍ","meaning":"a noble/generous/honorable (describing رَسُولٍ - messenger)","transliteration":"karīmin","root":"كرم","lemmaId":null},{"id":"81:20:1","ayahNum":20,"wordNum":1,"word":"ذِى","meaning":"owner of (العَرْشِ - the throne)","transliteration":"dhī","root":"","lemmaId":null},{"id":"81:20:2","ayahNum":20,"wordNum":2,"word":"قُوَّةٍ","meaning":"a strength (describing ذِى - one who has)","transliteration":"quwwatin","root":"قوي","lemmaId":null},{"id":"81:20:3","ayahNum":20,"wordNum":3,"word":"عِندَ","meaning":"in the presence of (ذِى ٱلْعَرْشِ - the Owner of the Throne)","transliteration":"ʿinda","root":"عند","lemmaId":null},{"id":"81:20:4","ayahNum":20,"wordNum":4,"word":"ذِى","meaning":"owner of, possessor of (قُوَّةٍ - power)","transliteration":"dhī","root":"","lemmaId":null},{"id":"81:20:5","ayahNum":20,"wordNum":5,"word":"ٱلْعَرْشِ","meaning":"of the throne (possessed by ذِى)","transliteration":"l-ʿarshi","root":"عرش","lemmaId":2536},{"id":"81:20:6","ayahNum":20,"wordNum":6,"word":"مَكِينٍ","meaning":"firmly established (describing the noble messenger mentioned earlier)","transliteration":"makīnin","root":"مكن","lemmaId":null},{"id":"81:21:1","ayahNum":21,"wordNum":1,"word":"مُّطَاعٍ","meaning":"one who is truly obeyed (in a general sense)","transliteration":"muṭāʿin","root":"طوع","lemmaId":null},{"id":"81:21:2","ayahNum":21,"wordNum":2,"word":"ثَمَّ","meaning":"there (location being discussed)","transliteration":"thamma","root":"","lemmaId":1171},{"id":"81:21:3","ayahNum":21,"wordNum":3,"word":"أَمِينٍ","meaning":"a trustworthy one (describing جِبْرِيل)","transliteration":"amīnin","root":"أمن","lemmaId":null},{"id":"81:22:1","ayahNum":22,"wordNum":1,"word":"وَمَا","meaning":"and not (negating صَاحِبُكُم بِمَجْنُونٍ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"81:22:2","ayahNum":22,"wordNum":2,"word":"صَاحِبُكُم","meaning":"your companion (subject of وَمَا)","transliteration":"ṣāḥibukum","root":"صحب","lemmaId":null},{"id":"81:22:3","ayahNum":22,"wordNum":3,"word":"بِمَجْنُونٍ","meaning":"with/by any hidden/covered one (in mind) (describing صَاحِبُكُم)","transliteration":"bimajnūnin","root":"جنن","lemmaId":null},{"id":"81:23:1","ayahNum":23,"wordNum":1,"word":"وَلَقَدْ","meaning":"and indeed certainly (connects to رَءَاهُ - he saw him)","transliteration":"walaqad","root":"","lemmaId":2994},{"id":"81:23:2","ayahNum":23,"wordNum":2,"word":"رَءَاهُ","meaning":"he saw him (referring to Prophet Muhammad ﷺ seeing Angel Jibreel)","transliteration":"raāhu","root":"رأي","lemmaId":null},{"id":"81:23:3","ayahNum":23,"wordNum":3,"word":"بِٱلْأُفُقِ","meaning":"in/at the horizon (location where رَءَاهُ/he saw him)","transliteration":"bil-ufuqi","root":"أفق","lemmaId":433},{"id":"81:23:4","ayahNum":23,"wordNum":4,"word":"ٱلْمُبِينِ","meaning":"the clear one (describing الأفق/the horizon mentioned before)","transliteration":"l-mubīni","root":"بين","lemmaId":810},{"id":"81:24:1","ayahNum":24,"wordNum":1,"word":"وَمَا","meaning":"and not (negates هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ)","transliteration":"wamā","root":"","lemmaId":3215},{"id":"81:24:2","ayahNum":24,"wordNum":2,"word":"هُوَ","meaning":"he (subject of بِضَنِينٍ)","transliteration":"huwa","root":"","lemmaId":4772},{"id":"81:24:3","ayahNum":24,"wordNum":3,"word":"عَلَى","meaning":"upon (connecting غَيْبِ with what comes before it)","transliteration":"ʿalā","root":"","lemmaId":2582},{"id":"81:24:4","ayahNum":24,"wordNum":4,"word":"ٱلْغَيْبِ","meaning":"the unseen (possessed by or connected to something after it)","transliteration":"l-ghaybi","root":"غيب","lemmaId":null},{"id":"81:24:5","ayahNum":24,"wordNum":5,"word":"بِضَنِينٍ","meaning":"with/by one who withholds (describing Muhammad ﷺ in عَلَى ٱلْغَيْبِ بِضَنِينٍ)","transliteration":"biḍanīnin","root":"ضنن","lemmaId":null},{"id":"81:25:1","ayahNum":25,"wordNum":1,"word":"وَمَا","meaning":"and not (negates هُوَ بِقَوْلِ شَيْطٰنٍ رَّجِيمٍ)","transl