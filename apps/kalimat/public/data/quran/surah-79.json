[{"id":"79:1:1","ayahNum":1,"wordNum":1,"word":"وَٱلنَّازِعٰتِ","meaning":"and the ones (feminine) who pull out forcefully","transliteration":"wal-nāziʿāti","root":"نزع","lemmaId":null},{"id":"79:1:2","ayahNum":1,"wordNum":2,"word":"غَرْقًا","meaning":"with a forceful pulling out (describes how النَّازِعٰتِ pull out)","transliteration":"gharqan","root":"غرق","lemmaId":null},{"id":"79:2:1","ayahNum":2,"wordNum":1,"word":"وَٱلنَّاشِطٰتِ","meaning":"and the ones (feminine) who pull out vigorously (referring to angels drawing forth souls)","transliteration":"wal-nāshiṭāti","root":"نشط","lemmaId":4013},{"id":"79:2:2","ayahNum":2,"wordNum":2,"word":"نَشْطًا","meaning":"with vigorous pulling (describing how the angels work)","transliteration":"nashṭan","root":"نشط","lemmaId":null},{"id":"79:3:1","ayahNum":3,"wordNum":1,"word":"السابحاتِ","meaning":"the female swimmers/gliders (owned)","transliteration":"wal-sābiḥāti","root":"سبح","lemmaId":null},{"id":"79:3:2","ayahNum":3,"wordNum":2,"word":"سَبْحًا","meaning":"with smooth gliding (describing السابحات)","transliteration":"sabḥan","root":"سبح","lemmaId":null},{"id":"79:4:1","ayahNum":4,"wordNum":1,"word":"فَٱلسَّابِقٰتِ","meaning":"so the female ones who race ahead (referring to angels racing to carry out Allah's commands)","transliteration":"fal-sābiqāti","root":"سبق","lemmaId":null},{"id":"79:4:2","ayahNum":4,"wordNum":2,"word":"سَبْقًا","meaning":"in racing ahead (describing how)","transliteration":"sabqan","root":"سبق","lemmaId":null},{"id":"79:5:1","ayahNum":5,"wordNum":1,"word":"فَٱلْمُدَبِّرٰتِ","meaning":"so/then the multiple managers (feminine) (who manage أَمْرًا - the matter)","transliteration":"fal-mudabirāti","root":"دبر","lemmaId":null},{"id":"79:5:2","ayahNum":5,"wordNum":2,"word":"أَمْرًا","meaning":"a command/matter (object of الْمُدَبِّرٰتِ)","transliteration":"amran","root":"أمر","lemmaId":null},{"id":"79:6:1","ayahNum":6,"wordNum":1,"word":"يَوْمَ","meaning":"a day (in accusative case)","transliteration":"yawma","root":"يوم","lemmaId":null},{"id":"79:6:2","ayahNum":6,"wordNum":2,"word":"تَرْجُفُ","meaning":"she shakes violently (present tense)","transliteration":"tarjufu","root":"رجف","lemmaId":null},{"id":"79:6:3","ayahNum":6,"wordNum":3,"word":"الراجِفَةُ","meaning":"the mighty quake","transliteration":"l-rājifatu","root":"رجف","lemmaId":null},{"id":"79:7:1","ayahNum":7,"wordNum":1,"word":"تَتْبَعُهَا","meaning":"she follows her/it (acted on)","transliteration":"tatbaʿuhā","root":"تبع","lemmaId":875},{"id":"79:7:2","ayahNum":7,"wordNum":2,"word":"ٱلرَّادِفَةُ","meaning":"the Following One (subject of تَتْبَعُهَا)","transliteration":"l-rādifatu","root":"ردف","lemmaId":null},{"id":"79:8:1","ayahNum":8,"wordNum":1,"word":"قُلُوبٌ","meaning":"hearts (subject of وَاجِفَةٌ)","transliteration":"qulūbun","root":"قلب","lemmaId":null},{"id":"79:8:2","ayahNum":8,"wordNum":2,"word":"يَوْمَئِذٍ","meaning":"on that day (when hearts will be trembling)","transliteration":"yawma-idhin","root":"يوم","lemmaId":null},{"id":"79:8:3","ayahNum":8,"wordNum":3,"word":"وَاجِفَةٌ","meaning":"trembling/throbbing (feminine, nominative)","transliteration":"wājifatun","root":"وجف","lemmaId":null},{"id":"79:9:1","ayahNum":9,"wordNum":1,"word":"أَبْصٰرُهَا","meaning":"her eyes (subject of خٰشِعَةٌ)","transliteration":"abṣāruhā","root":"بصر","lemmaId":null},{"id":"79:9:2","ayahNum":9,"wordNum":2,"word":"خٰشِعَةٌ","meaning":"humble (feminine, describing أَبْصٰرُهَا)","transliteration":"khāshiʿatun","root":"خشع","lemmaId":null},{"id":"79:10:1","ayahNum":10,"wordNum":1,"word":"يَقُولُونَ","meaning":"they say (referring to the disbelievers questioning resurrection)","transliteration":"yaqūlūna","root":"قول","lemmaId":null},{"id":"79:10:2","ayahNum":10,"wordNum":2,"word":"أَءِنَّا","meaning":"is it true that we...? (questioning what يَقُولُونَ/they say)","transliteration":"a-innā","root":"","lemmaId":502},{"id":"79:10:3","ayahNum":10,"wordNum":3,"word":"لَمَرْدُودُونَ","meaning":"surely we will be returned (in response to أَءِنَّا - 'will we')","transliteration":"lamardūdūna","root":"ردد","lemmaId":null},{"id":"79:10:4","ayahNum":10,"wordNum":4,"word":"فِى","meaning":"in (connects to ٱلْحَافِرَةِ - the first state)","transliteration":"fī","root":"","lemmaId":null},{"id":"79:10:5","ayahNum":10,"wordNum":5,"word":"ٱلْحَافِرَةِ","meaning":"in the original state (in response to يَقُولُونَ - they say)","transliteration":"l-ḥāfirati","root":"حفر","lemmaId":null},{"id":"79:11:1","ayahNum":11,"wordNum":1,"word":"أَءِذَا","meaning":"is it when? (expressing disbelief about عِظٰمًا نَّخِرَةً - decayed bones)","transliteration":"a-idhā","root":"","lemmaId":4646},{"id":"79:11:2","ayahNum":11,"wordNum":2,"word":"كُنَّا","meaning":"we were (subject of the sentence)","transliteration":"kunnā","root":"كون","lemmaId":null},{"id":"79:11:3","ayahNum":11,"wordNum":3,"word":"عِظٰمًا","meaning":"bones (object of كُنَّا - we were)","transliteration":"ʿiẓāman","root":"عظم","lemmaId":null},{"id":"79:11:4","ayahNum":11,"wordNum":4,"word":"نَّخِرَةً","meaning":"completely hollow and crumbling (describing عِظٰمًا/bones)","transliteration":"nakhiratan","root":"نخر","lemmaId":null},{"id":"79:12:1","ayahNum":12,"wordNum":1,"word":"قَالُوا۟","meaning":"they said","transliteration":"qālū","root":"قول","lemmaId":null},{"id":"79:12:2","ayahNum":12,"wordNum":2,"word":"تِلْكَ","meaning":"that (feminine) (pointing to كَرَّةٌ/return)","transliteration":"til'ka","root":"","lemmaId":1051},{"id":"79:12:3","ayahNum":12,"wordNum":3,"word":"إِذًا","meaning":"in that case/therefore (responding to قَالُوا - they said)","transliteration":"idhan","root":"","lemmaId":461},{"id":"79:12:4","ayahNum":12,"wordNum":4,"word":"كَرَّةٌ","meaning":"a return (indefinite)","transliteration":"karratun","root":"كرر","lemmaId":null},{"id":"79:12:5","ayahNum":12,"wordNum":5,"word":"خَاسِرَةٌ","meaning":"a losing (feminine, describes كَرَّةٌ)","transliteration":"khāsiratun","root":"خسر","lemmaId":null},{"id":"79:13:1","ayahNum":13,"wordNum":1,"word":"فَإِنَّمَا","meaning":"for indeed only/merely","transliteration":"fa-innamā","root":"","lemmaId":502},{"id":"79:13:2","ayahNum":13,"wordNum":2,"word":"هِىَ","meaning":"she/it (feminine subject pronoun)","transliteration":"hiya","root":"","lemmaId":4118},{"id":"79:13:3","ayahNum":13,"wordNum":3,"word":"زَجْرَةٌ","meaning":"a single shout/cry (that will resurrect everyone)","transliteration":"zajratun","root":"زجر","lemmaId":null},{"id":"79:13:4","ayahNum":13,"wordNum":4,"word":"وَاحِدَةٌ","meaning":"a single (feminine)","transliteration":"wāḥidatun","root":"وحد","lemmaId":null},{"id":"79:14:1","ayahNum":14,"wordNum":1,"word":"فَإِذَا","meaning":"and then when (followed by هُم بِٱلسَّاهِرَةِ)","transliteration":"fa-idhā","root":"","lemmaId":4646},{"id":"79:14:2","ayahNum":14,"wordNum":2,"word":"هُم","meaning":"they (referring to those who will be resurrected)","transliteration":"hum","root":"","lemmaId":4118},{"id":"79:14:3","ayahNum":14,"wordNum":3,"word":"بِٱلسَّاهِرَةِ","meaning":"on the wide open plain","transliteration":"bil-sāhirati","root":"سهر","lemmaId":null},{"id":"79:15:1","ayahNum":15,"wordNum":1,"word":"هَلْ","meaning":"Has (asking about أَتَىٰكَ - reached you)","transliteration":"hal","root":"","lemmaId":4144},{"id":"79:15:2","ayahNum":15,"wordNum":2,"word":"أَتَىٰكَ","meaning":"he came to you (question in هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ - Has the story of Moses come to you?)","transliteration":"atāka","root":"أتي","lemmaId":53},{"id":"79:15:3","ayahNum":15,"wordNum":3,"word":"حَدِيثُ","meaning":"story/account (of مُوسَىٰٓ - Moses)","transliteration":"ḥadīthu","root":"حدث","lemmaId":null},{"id":"79:15:4","ayahNum":15,"wordNum":4,"word":"مُوسَىٰٓ","meaning":"Moses (the prophet) (subject of حَدِيثُ)","transliteration":"mūsā","root":"","lemmaId":null},{"id":"79:16:1","ayahNum":16,"wordNum":1,"word":"إِذْ","meaning":"when (introducing the time when his Lord called him)","transliteration":"idh","root":"","lemmaId":461},{"id":"79:16:2","ayahNum":16,"wordNum":2,"word":"نَادَىٰهُ","meaning":"he called him (object of رَبُّهُ/his Lord)","transliteration":"nādāhu","root":"ندي","lemmaId":null},{"id":"79:16:3","ayahNum":16,"wordNum":3,"word":"رَبُّهُۥ","meaning":"his Lord (subject of نَادَىٰهُ)","transliteration":"rabbuhu","root":"ربب","lemmaId":null},{"id":"79:16:4","ayahNum":16,"wordNum":4,"word":"بِٱلْوَادِ","meaning":"in the valley (where Allah spoke to Moses)","transliteration":"bil-wādi","root":"ودي","lemmaId":null},{"id":"79:16:5","ayahNum":16,"wordNum":5,"word":"ٱلْمُقَدَّسِ","meaning":"the holy/sacred (describing وَادِ/valley)","transliteration":"l-muqadasi","root":"قدس","lemmaId":null},{"id":"79:16:6","ayahNum":16,"wordNum":6,"word":"طُوًى","meaning":"Tuwa (name of sacred valley)","transliteration":"ṭuwan","root":"طوي","lemmaId":null},{"id":"79:17:1","ayahNum":17,"wordNum":1,"word":"ٱذْهَبْ","meaning":"go! (command)","transliteration":"idh'hab","root":"ذهب","lemmaId":null},{"id":"79:17:2","ayahNum":17,"wordNum":2,"word":"إِلَىٰ","meaning":"to/towards (connects ٱذْهَبْ with فِرْعَوْنَ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"79:17:3","ayahNum":17,"wordNum":3,"word":"فِرْعَوْنَ","meaning":"Pharaoh (object of اذْهَبْ إِلَىٰ - go to)","transliteration":"fir'ʿawna","root":"","lemmaId":2879},{"id":"79:17:4","ayahNum":17,"wordNum":4,"word":"إِنَّهُۥ","meaning":"indeed he (subject of طَغَىٰ/transgressed)","transliteration":"innahu","root":"","lemmaId":502},{"id":"79:17:5","ayahNum":17,"wordNum":5,"word":"طَغَىٰ","meaning":"he transgressed (referring to فِرْعَوْنَ)","transliteration":"ṭaghā","root":"طغي","lemmaId":null},{"id":"79:18:1","ayahNum":18,"wordNum":1,"word":"فَقُلْ","meaning":"so say! (introducing what to say to فِرْعَوْنَ)","transliteration":"faqul","root":"قول","lemmaId":null},{"id":"79:18:2","ayahNum":18,"wordNum":2,"word":"هَل","meaning":"do/would (asking فرعون)","transliteration":"hal","root":"","lemmaId":4144},{"id":"79:18:3","ayahNum":18,"wordNum":3,"word":"لَّكَ","meaning":"surely for you (connected to فَقُلْ - then say)","transliteration":"laka","root":"","lemmaId":3146},{"id":"79:18:4","ayahNum":18,"wordNum":4,"word":"إِلَىٰٓ","meaning":"to/towards (connects to تَزَكَّىٰ)","transliteration":"ilā","root":"","lemmaId":485},{"id":"79:18:5","ayahNum":18,"wordNum":5,"word":"أَن","meaning":"that (connects to تَزَكَّىٰ)","transliteration":"an","root":"","lemmaId":368},{"id":"79:18:6","ayahNum":18,"wordNum":6,"word":"تَزَكَّىٰ","meaning":"to purify oneself","transliteration":"tazakkā","root":"زكو","lemmaId":null},{"id":"79:19:1","ayahNum":19,"wordNum":1,"word":"وَأَهْدِيَكَ","meaning":"and I guide you (to رَبِّكَ your Lord)","transliteration":"wa-ahdiyaka","root":"هدي","lemmaId":null},{"id":"79:19:2","ayahNum":19,"wordNum":2,"word":"إِلَىٰ","meaning":"to, towards (connects وَأَهْدِيَكَ with رَبِّكَ)","transliteration":"ilā","root":"","lemmaId":486},{"id":"79:19:3","ayahNum":19,"wordNum":3,"word":"رَبِّكَ","meaning":"your Lord (object of إِلَىٰ)","transliteration":"rabbika","root":"ربب","lemmaId":1742},{"id":"79:19:4","ayahNum":19,"wordNum":4,"word":"فَتَخْشَىٰ","meaning":"so that you fear/are in awe (result of أَهْدِيَكَ - guide you)","transliteration":"fatakhshā","root":"خشي","lemmaId":1535},{"id":"79:20:1","ayahNum":20,"wordNum":1,"word":"فَأَرَىٰهُ","meaning":"and then he showed him (the great sign)","transliteration":"fa-arāhu","root":"رأي","lemmaId":null},{"id":"79:20:2","ayahNum":20,"wordNum":2,"word":"ٱلْءَايَةَ","meaning":"the sign, the miracle (that Musa عليه السلام showed to Pharaoh)","transliteration":"l-āyata","root":"أيي","lemmaId":null},{"id":"79:20:3","ayahNum":20,"wordNum":3,"word":"ٱلْكُبْرَىٰ","meaning":"the greatest/biggest (feminine)","transliteration":"l-kub'rā","root":"كبر","lemmaId":3056},{"id":"79:21:1","ayahNum":21,"wordNum":1,"word":"فَكَذَّبَ","meaning":"and so he denied (followed by وَعَصَىٰ - and disobeyed)","transliteration":"fakadhaba","root":"كذب","lemmaId":3069},{"id":"79:21:2","ayahNum":21,"wordNum":2,"