rdNum":3,"word":"نَكَالَ","meaning":"exemplary punishment (object of أَخَذَ)","transliteration":"nakāla","root":"نكل","lemmaId":null},{"id":"79:25:4","ayahNum":25,"wordNum":4,"word":"ٱلْءَاخِرَةِ","meaning":"of the hereafter (possessed by نَكَالَ)","transliteration":"l-ākhirati","root":"أخر","lemmaId":null},{"id":"79:25:5","ayahNum":25,"wordNum":5,"word":"وَٱلْأُولَىٰٓ","meaning":"and the first (feminine)","transliteration":"wal-ūlā","root":"أول","lemmaId":384},{"id":"79:26:1","ayahNum":26,"wordNum":1,"word":"إِنَّ","meaning":"indeed/truly (emphasizes فِى ذٰلِكَ لَعِبْرَةً - 'in that is a lesson')","transliteration":"inna","root":"","lemmaId":502},{"id":"79:26:2","ayahNum":26,"wordNum":2,"word":"فِى","meaning":"in (connects to ذٰلِكَ - that)","transliteration":"fī","root":"","lemmaId":2761},{"id":"79:26:3","ayahNum":26,"wordNum":3,"word":"ذٰلِكَ","meaning":"that (pointing to something far) (refers to the previous statement)","transliteration":"dhālika","root":"","lemmaId":1677},{"id":"79:26:4","ayahNum":26,"wordNum":4,"word":"عِبْرَةً","meaning":"surely a lesson (object of إِنَّ فِى ذٰلِكَ - indeed in that is)","transliteration":"laʿib'ratan","root":"عبر","lemmaId":null},{"id":"79:26:5","ayahNum":26,"wordNum":5,"word":"لِّمَن","meaning":"indeed for whoever (subject of يَخْشَىٰٓ)","transliteration":"liman","root":"","lemmaId":null},{"id":"79:26:6","ayahNum":26,"wordNum":6,"word":"يَخْشَىٰٓ","meaning":"he fears/is fearing","transliteration":"yakhshā","root":"خشي","lemmaId":null},{"id":"79:27:1","ayahNum":27,"wordNum":1,"word":"ءَأَنتُمْ","meaning":"are you all?","transliteration":"a-antum","root":"","lemmaId":4640},{"id":"79:27:2","ayahNum":27,"wordNum":2,"word":"أَشَدُّ","meaning":"stronger/more intense (than خَلْقًا)","transliteration":"ashaddu","root":"شدد","lemmaId":2142},{"id":"79:27:3","ayahNum":27,"wordNum":3,"word":"خَلْقًا","meaning":"a creation (object of أَشَدُّ/stronger)","transliteration":"khalqan","root":"خلق","lemmaId":null},{"id":"79:27:4","ayahNum":27,"wordNum":4,"word":"أَمِ","meaning":"or (connecting to previous question ءَأَنتُمْ)","transliteration":"ami","root":"","lemmaId":439},{"id":"79:27:5","ayahNum":27,"wordNum":5,"word":"ٱلسَّمَآءُ","meaning":"the sky (subject of the sentence)","transliteration":"l-samāu","root":"سمو","lemmaId":null},{"id":"79:27:6","ayahNum":27,"wordNum":6,"word":"بَنَىٰهَا","meaning":"he built it (referring to Allah building the sky)","transliteration":"banāhā","root":"بني","lemmaId":null},{"id":"79:28:1","ayahNum":28,"wordNum":1,"word":"رَفَعَ","meaning":"he raised (subject of فَسَوَّىٰهَا)","transliteration":"rafaʿa","root":"رفع","lemmaId":null},{"id":"79:28:2","ayahNum":28,"wordNum":2,"word":"سَمْكَهَا","meaning":"its height (object of رَفَعَ/He raised)","transliteration":"samkahā","root":"سمك","lemmaId":null},{"id":"79:28:3","ayahNum":28,"wordNum":3,"word":"فَسَوَّىٰهَا","meaning":"and He made it perfect (referring to سَمْكَهَا - its height)","transliteration":"fasawwāhā","root":"سوي","lemmaId":null},{"id":"79:29:1","ayahNum":29,"wordNum":1,"word":"وَأَغْطَشَ","meaning":"and He made dark (acting on لَيْلَهَا)","transliteration":"wa-aghṭasha","root":"غطش","lemmaId":null},{"id":"79:29:2","ayahNum":29,"wordNum":2,"word":"لَيْلَهَا","meaning":"its night (object of أَغْطَشَ - He darkened)","transliteration":"laylahā","root":"ليل","lemmaId":null},{"id":"79:29:3","ayahNum":29,"wordNum":3,"word":"وَأَخْرَجَ","meaning":"and He brought out (acted on ضُحَىٰهَا)","transliteration":"wa-akhraja","root":"خرج","lemmaId":1523},{"id":"79:29:4","ayahNum":29,"wordNum":4,"word":"ضُحَىٰهَا","meaning":"its morning brightness (object of أَخْرَجَ - He brought forth)","transliteration":"ḍuḥāhā","root":"ضحو","lemmaId":null},{"id":"79:30:1","ayahNum":30,"wordNum":1,"word":"وَٱلْأَرْضَ","meaning":"and the earth (object of دَحَىٰهَآ/spread it out)","transliteration":"wal-arḍa","root":"أرض","lemmaId":149},{"id":"79:30:2","ayahNum":30,"wordNum":2,"word":"بَعْدَ","meaning":"after (connects to دَحَىٰهَآ - He spread it)","transliteration":"baʿda","root":"بعد","lemmaId":null},{"id":"79:30:3","ayahNum":30,"wordNum":3,"word":"ذٰلِكَ","meaning":"that (one)","transliteration":"dhālika","root":"","lemmaId":1677},{"id":"79:30:4","ayahNum":30,"wordNum":4,"word":"دَحَىٰهَآ","meaning":"he spread it out","transliteration":"daḥāhā","root":"دحو","lemmaId":null},{"id":"79:31:1","ayahNum":31,"wordNum":1,"word":"أَخْرَجَ","meaning":"he brought forth (مَآءَهَا وَمَرْعَىٰهَا - its water and its pasture)","transliteration":"akhraja","root":"خرج","lemmaId":1523},{"id":"79:31:2","ayahNum":31,"wordNum":2,"word":"مِنْهَا","meaning":"from it/her","transliteration":"min'hā","root":"","lemmaId":null},{"id":"79:31:3","ayahNum":31,"wordNum":3,"word":"مَآءَهَا","meaning":"its water (refers to the earth mentioned earlier)","transliteration":"māahā","root":"موه","lemmaId":null},{"id":"79:31:4","ayahNum":31,"wordNum":4,"word":"وَمَرْعَىٰهَا","meaning":"and its pasture (object of أَخْرَجَ)","transliteration":"wamarʿāhā","root":"رعي","lemmaId":null},{"id":"79:32:1","ayahNum":32,"wordNum":1,"word":"وَٱلْجِبَالَ","meaning":"and the mountains (object of أَرْسَىٰهَا - He fixed them)","transliteration":"wal-jibāla","root":"جبل","lemmaId":null},{"id":"79:32:2","ayahNum":32,"wordNum":2,"word":"أَرْسَىٰهَا","meaning":"He made it (the mountains) firmly fixed (connected to وَٱلْجِبَالَ)","transliteration":"arsāhā","root":"رسو","lemmaId":null},{"id":"79:33:1","ayahNum":33,"wordNum":1,"word":"مَتٰعًا","meaning":"as a provision/benefit (for لَّكُمْ وَلِأَنْعٰمِكُمْ - for you and your cattle)","transliteration":"matāʿan","root":"متع","lemmaId":null},{"id":"79:33:2","ayahNum":33,"wordNum":2,"word":"لَّكُمْ","meaning":"surely for you all (connected to مَتٰعًا - enjoyment)","transliteration":"lakum","root":"","lemmaId":3146},{"id":"79:33:3","ayahNum":33,"wordNum":3,"word":"وَلِأَنْعٰمِكُمْ","meaning":"and for your livestock","transliteration":"wali-anʿāmikum","root":"نعم","lemmaId":4032},{"id":"79:34:1","ayahNum":34,"wordNum