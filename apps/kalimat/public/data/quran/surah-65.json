 He makes great)","transliteration":"ajran","root":"أجر","lemmaId":74},{"id":"65:6:1","ayahNum":6,"wordNum":1,"word":"أَسْكِنُوهُنَّ","meaning":"you all (masculine) make them (feminine) settle/live","transliteration":"askinūhunna","root":"سكن","lemmaId":2018},{"id":"65:6:2","ayahNum":6,"wordNum":2,"word":"مِنْ","meaning":"from (connects أَسْكِنُوهُنَّ with حَيْثُ)","transliteration":"min","root":"","lemmaId":3464},{"id":"65:6:3","ayahNum":6,"wordNum":3,"word":"حَيْثُ","meaning":"wherever, where","transliteration":"ḥaythu","root":"حيث","lemmaId":null},{"id":"65:6:4","ayahNum":6,"wordNum":4,"word":"سَكَنتُم","meaning":"you all lived/stayed","transliteration":"sakantum","root":"سكن","lemmaId":null},{"id":"65:6:5","ayahNum":6,"wordNum":5,"word":"مِّن","meaning":"from","transliteration":"min","root":"","lemmaId":3464},{"id":"65:6:6","ayahNum":6,"wordNum":6,"word":"وُجْدِكُمْ","meaning":"your capacity (referring to the housing capacity mentioned in the ayah)","transliteration":"wuj'dikum","root":"وجد","lemmaId":null},{"id":"65:6:7","ayahNum":6,"wordNum":7,"word":"وَلَا","meaning":"and not (negates تُضَآرُّوهُنَّ)","transliteration":"walā","root":"","lemmaId":3147},{"id":"65:6:8","ayahNum":6,"wordNum":8,"word":"تُضَآرُّوهُنَّ","meaning":"you all harm them (feminine plural)","transliteration":"tuḍārrūhunna","root":"ضرر","lemmaId":2346},{"id":"65:6:9","ayahNum":6,"wordNum":9,"word":"لِتُضَيِّقُوا۟","meaning":"so that you all may make tight (against عَلَيْهِنَّ - against them)","transliteration":"lituḍayyiqū","root":"ضيق","lemmaId":2360},{"id":"65:6:10","ayahNum":6,"wordNum":10,"word":"عَلَيْهِنَّ","meaning":"upon them (feminine plural)","transliteration":"ʿalayhinna","root":"","lemmaId":2582},{"id":"65:6:11","ayahNum":6,"wordNum":11,"word":"وَإِن","meaning":"and if (connects this condition to previous rules about housing divorced women)","transliteration":"wa-in","root":"","lemmaId":502},{"id":"65:6:12","ayahNum":6,"wordNum":12,"word":"كُنَّ","meaning":"they (feminine) were"