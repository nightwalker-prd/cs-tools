:"65:12:16","ayahNum":12,"wordNum":16,"word":"كُلِّ","meaning":"of all/every (describing شَىْءٍ)","transliteration":"kulli","root":"كلل","lemmaId":null},{"id":"65:12:17","ayahNum":12,"wordNum":17,"word":"شَىْءٍ","meaning":"a thing (possessed by/belonging to اللَّهَ)","transliteration":"shayin","root":"شيأ","lemmaId":null},{"id":"65:12:18","ayahNum":12,"wordNum":18,"word":"قَدِيرٌ","meaning":"All-Powerful (describing اللَّهَ - Allah)","transliteration":"qadīrun","root":"قدر","lemmaId":2931},{"id":"65:12:19","ayahNum":12,"wordNum":19,"word":"وَأَنَّ","meaning":"and that (connecting to previous statement about Allah's power)","transliteration":"wa-anna","root":"","lemmaId":368},{"id":"65:12:20","ayahNum":12,"wordNum":20,"word":"ٱللَّهَ","meaning":"Allah (as the object being known about in this ayah)","transliteration":"l-laha","root":"أله","lemmaId":650},{"id":"65:12:21","ayahNum":12,"wordNum":21,"word":"قَدْ","meaning":"indeed/certainly (emphasizes أَحَاطَ)","transliteration":"qad","root":"","lemmaId":2994},{"id":"65:12:22","ayahNum":12,"wordNum":22,"word":"أَحَاطَ","meaning":"to cause to surround/encompass something","transliteration":"aḥāṭa","root":"حوط","lemmaId":null},{"id":"65:12:23","ayahNum":12,"wordNum":23,"word":"بِكُلِّ","meaning":"with every/all (possessed by شَىْءٍ)","transliteration":"bikulli","root":"كلل","lemmaId":null},{"id":"65:12:24","ayahNum":12,"wordNum":24,"word":"شَىْءٍ","meaning":"any thing (possessed by قَدِيرٌ)","transliteration":"shayin","root":"شيأ","lemmaId":null},{"id":"65:12:25","ayahNum":12,"wordNum":25,"word":"عِلْمًۢا","meaning":"knowledge (object of أَحَاطَ/encompassed)","transliteration":"ʿil'man","root":"علم","lemmaId":null}]