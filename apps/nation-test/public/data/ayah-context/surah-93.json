":93,"ayahNum":11,"wordNum":3,"arabic":"رَبّ","targetTranslation":"your Lord (possessed by نِعْمَة)","ayahArabic":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","ayahEnglish":"But as for the favor of your Lord, report [it].","blankPosition":-1,"distractors":["A warning","A balance","A path"],"pos":"N","lemma":"رَبّ","tier":"q100","transliteration":"rabbika"}]