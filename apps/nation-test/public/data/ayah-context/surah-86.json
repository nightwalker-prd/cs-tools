[{"id":"ac-86:2:2","surahNum":86,"ayahNum":2,"wordNum":2,"arabic":"أَدْرَى","targetTranslation":"made you know","ayahArabic":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","ayahEnglish":"And what can make you know what is the night comer?","blankPosition":-1,"distractors":["More learning","More fearing","More seeing"],"pos":"V","lemma":"أَدْرَى","tier":"q600","transliteration":"adrāka"},{"id":"ac-86:2:3","surahNum":86,"ayahNum":2,"wordNum":3,"arabic":"ما","targetTranslation":"what (asking about الطَّارِقُ)","ayahArabic":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","ayahEnglish":"And what can make you know what is the night comer?","blankPosition":-1,"distractors":["when","where","who"],"pos":"N","lemma":"ما","tier":"q100","transliteration":"mā"},{"id":"ac-86:4:2","surahNum":86,"ayahNum":4,"wordNum":2,"arabic":"كُلّ","targetTranslation":"every (describes نَفْسٍ)","ayahArabic":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","ayahEnglish":"There is no soul but that it has over it a protector.","blankPosition":-1,"distractors":["some","other","few"],"pos":"N","lemma":"كُلّ","tier":"q100","transliteration":"kullu"},{"id":"ac-86:4:3","surahNum":86,"ayahNum":4,"wordNum":3,"arabic":"نَفْس","targetTranslation":"a soul/self (possessed by كُلُّ)","ayahArabic":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","ayahEnglish":"There is no soul but that it has over it a protector.","blankPosition":-1,"distractors":["garment","provisions","banner"],"pos":"N","lemma":"نَفْس","tier":"q100","transliteration":"nafsin"},{"id":"ac-86:4:6","surahNum":86,"ayahNum":4,"wordNum":6,"arabic":"حافِظ","targetTranslation":"a protector (describing كُلُّ نَفْسٍ)","ayahArabic":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","ayahEnglish":"There is no soul but that it has over it a protector.","blankPosition":-1,"distractors":["preservers","guardians","keepers"],"pos":"N","lemma":"حافِظ","tier":"q1000","transliteration":"ḥāfiẓun"},{"id":"ac-86:5:4","surahNum":86,"ayahNum":5,"wordNum":4,"arabic":"خَلَقَ","targetTranslation":"he was cre