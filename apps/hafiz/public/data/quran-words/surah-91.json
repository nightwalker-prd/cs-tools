 definitely/certainly (in the past)","transliteration":"waqad","root":"","lemmaId":1},{"id":"91:10:2","ayahNum":10,"wordNum":2,"word":"خَابَ","meaning":"he failed/was disappointed","transliteration":"khāba","root":"خيب","lemmaId":1513},{"id":"91:10:3","ayahNum":10,"wordNum":3,"word":"مَن","meaning":"whoever","transliteration":"man","root":"","lemmaId":18},{"id":"91:10:4","ayahNum":10,"wordNum":4,"word":"دَسَّىٰهَا","meaning":"he thoroughly buried it/her","transliteration":"dassāhā","root":"دسو","lemmaId":3467},{"id":"91:11:1","ayahNum":11,"wordNum":1,"word":"كَذَّبَتْ","meaning":"she denied/rejected intensively","transliteration":"kadhabat","root":"كذب","lemmaId":70},{"id":"91:11:2","ayahNum":11,"wordNum":2,"word":"ثَمُودُ","meaning":"Thamud","transliteration":"thamūdu","root":"","lemmaId":409},{"id":"91:11:3","ayahNum":11,"wordNum":3,"word":"بِطَغْوَىٰهَآ","meaning":"by/because of its transgression","transliteration":"biṭaghwāhā","root":"طغي","lemmaId":3802},{"id":"91:12:1","ayahNum":12,"wordNum":1,"word":"إِذِ","meaning":"when","transliteration":"idhi","root":"","lemmaId":43},{"id":"91:12:2","ayahNum":12,"wordNum":2,"word":"ٱنۢبَعَثَ","meaning":"rose up by itself","transliteration":"inbaʿatha","root":"بعث","lemmaId":3046},{"id":"91:12:3","ayahNum":12,"wordNum":3,"word":"أَشْقَىٰهَا","meaning":"their most wretched one","transliteration":"ashqāhā","root":"شقو","lemmaId":1700},{"id":"91:13:1","ayahNum":13,"wordNum":1,"word":"فَقَالَ","meaning":"then he said","transliteration":"faqāla","root":"قول","lemmaId":12},{"id":"91:13:2","ayahNum":13,"wordNum":2,"word":"لَهُمْ","meaning":"to/for them (referring to the disbelievers mentioned earlier)","transliteration":"lahum","root":"","lemmaId":3},{"id":"91:13:3","ayahNum":13,"wordNum":3,"word":"رَسُولُ","meaning":"messenger","transliteration":"rasūlu","root":"رسل","lemmaId":40},{"id":"91:13:4","ayahNum":13,"wordNum":4,"word":"ٱللَّهِ","meaning":"of Allah","transliteration":"l-lahi","root":"أله","lemmaId":6},{"id":"91:13:5","a