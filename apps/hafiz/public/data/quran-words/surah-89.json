inine, with emphasis)","transliteration":"yāayyatuhā","root":"أيي","lemmaId":61},{"id":"89:27:2","ayahNum":27,"wordNum":2,"word":"ٱلنَّفْسُ","meaning":"the soul/self (in subject form)","transliteration":"l-nafsu","root":"نفس","lemmaId":44},{"id":"89:27:3","ayahNum":27,"wordNum":3,"word":"ٱلْمُطْمَئِنَّةُ","meaning":"O soul that feels complete peace","transliteration":"l-muṭ'ma-inatu","root":"طمأن","lemmaId":2677},{"id":"89:28:1","ayahNum":28,"wordNum":1,"word":"اِرْجِعِيٓ","meaning":"return! (command to one female)","transliteration":"ir'jiʿī","root":"رجع","lemmaId":142},{"id":"89:28:2","ayahNum":28,"wordNum":2,"word":"إِلَىٰ","meaning":"to/toward","transliteration":"ilā","root":"","lemmaId":19},{"id":"89:28:3","ayahNum":28,"wordNum":3,"word":"رَبِّكِ","meaning":"your Lord","transliteration":"rabbiki","root":"ربب","lemmaId":17},{"id":"89:28:4","ayahNum":28,"wordNum":4,"word":"رَاضِيَةً","meaning":"being content/pleased (describing state while returning)","transliteration":"rāḍiyatan","root":"رضو","lemmaId":1523},{"id":"89:28:5","ayahNum":28,"wordNum":5,"word":"مَرْضِيَّةً","meaning":"pleased/content (feminine, indefinite)","transliteration":"marḍiyyatan","root":"رضو","lemmaId":4147},{"id":"89:29:1","ayahNum":29,"wordNum":1,"word":"فَٱدْخُلِى","meaning":"so enter! (feminine)","transliteration":"fa-ud'khulī","root":"دخل","lemmaId":149},{"id":"89:29:2","ayahNum":29,"wordNum":2,"word":"فِى","meaning":"in/within/inside","transliteration":"fī","root":"","lemmaId":10},{"id":"89:29:3","ayahNum":29,"wordNum":3,"word":"عِبٰدِى","meaning":"my servants","transliteration":"ʿibādī","root":"عبد","lemmaId":93},{"id":"89:30:1","ayahNum":30,"wordNum":1,"word":"وَٱدْخُلِى","meaning":"and enter! (feminine)","transliteration":"wa-ud'khulī","root":"دخل","lemmaId":149},{"id":"89:30:2","ayahNum":30,"wordNum":2,"word":"جَنَّتِى","meaning":"my garden","transliteration":"jannatī","root":"جنن","lemmaId":82}]